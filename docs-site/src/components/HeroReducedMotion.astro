<script>
	// SMIL animations don't honour prefers-reduced-motion on their own. When the
	// user asks for less motion we don't just pause (that would freeze the fold at
	// t=0, i.e. mid-build) — we seek past the end so the crane shows its finished
	// state, then pause so nothing runs. The intro is one-shot with fill="freeze",
	// so any time past ~1.2s is the final frame. Inlined SVG (not <object>), so
	// the timeline API is available as soon as the element exists.
	const crane = document.getElementById('of-hero-crane');
	if (crane instanceof SVGSVGElement && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		crane.setCurrentTime(5);
		crane.pauseAnimations();
	}
</script>
