---
/**
 * The macOS download CTA — one component, rendered in the hero and the final
 * fold so the two instances can never drift. Plain <a href> so it downloads
 * with zero JS; the "Starting download…" feedback and non-Mac swap are additive
 * enhancers wired up in index.astro.
 *
 * Icon: a neutral "arrow into tray" download glyph in the Folding Studio line
 * style, with a folded corner on the tray so it reads as Orifold's mark, not
 * clip art. Deliberately NOT the Apple logo or an SF Symbol — both are
 * license-restricted for web use (see docs/MACOS_DOWNLOAD_EXPERIENCE_PLAN.md §3.2).
 */
interface Props {
	id: string;
	href: string;
}
const { id, href } = Astro.props;
---

<a class="btn btn-primary dl-btn" id={id} href={href}>
	<svg
		class="btn-icon"
		viewBox="0 0 20 20"
		width="20"
		height="20"
		fill="none"
		stroke="currentColor"
		stroke-width="1.8"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<path d="M10 2.5v9" />
		<path d="M6.25 8.25 10 12l3.75-3.75" />
		<path d="M3.75 12.5v3a1 1 0 0 0 1 1h10.5a1 1 0 0 0 1-1v-3" />
		<path d="M3.75 15.5 5.5 13.75" opacity="0.55" />
	</svg>
	<span class="btn-label">
		<span class="btn-main">Download for macOS</span>
		<span class="btn-sub">Apple Silicon + Intel</span>
	</span>
</a>
