---
/**
 * A documentation companion note. Gami (dog) for beginner/user encouragement,
 * Ori (cat) for developer/edge-case precision. Built on callout styling.
 *
 * Rules enforced by convention, not code (see the docs makeover plan):
 *  - at most one per page, in normal document flow (never floating/fixed)
 *  - Gami never on developer pages; Ori never on Get-Started pages
 *  - the mark is decorative (aria-hidden); identity is carried by the label
 *  - idle motion only plays when the reader allows motion
 *
 * Usage: <PetTip who="gami">One encouraging line.</PetTip>
 */
import gamiMark from '../../public/assets/gami-mark.svg?raw';
import oriMark from '../../public/assets/ori-mark.svg?raw';

interface Props {
	who: 'gami' | 'ori';
}
const { who } = Astro.props;
const mark = who === 'gami' ? gamiMark : oriMark;
const label = who === 'gami' ? "Gami's tip" : "Ori's note";
---

<div class={`of-pettip of-pettip-${who}`} role="note" aria-label={label}>
	<span class="of-pettip-mark" aria-hidden="true" set:html={mark} />
	<div class="of-pettip-body">
		<span class="of-pettip-label">{label}</span>
		<slot />
	</div>
</div>
