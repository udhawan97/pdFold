---
interface Props {
	variant?: 'pro' | 'new' | 'platform';
}
const { variant = 'platform' } = Astro.props;
const text: Record<string, string> = {
	pro: 'Advanced workflow',
	new: 'New in v0.8.8',
	platform: 'macOS 14+',
};
---

<span class={`of-badge of-badge-${variant}`}><slot>{text[variant]}</slot></span>
