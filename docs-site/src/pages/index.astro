							<span class="ff-eyebrow" id="fortune-eyebrow"><span class="ff-eyebrow-dot" aria-hidden="true"></span>Today's fold</span>
							<p class="fortune-line" id="fortune-line" aria-live="polite">One sheet, folded with stubborn optimism.</p>
						</div>
						<button type="button" class="ff-refold" id="fortune-refold" aria-label="Refold — a new paper fortune">
							<span class="fortune-ico" aria-hidden="true">
								<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 3.8h2.2v2.2"/><path d="M16.4 5.9A6.6 6.6 0 1 0 17 10"/></svg>
							</span>
							<span>Refold</span>
