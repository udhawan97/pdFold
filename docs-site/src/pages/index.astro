---
/**
 * Orifold landing — "One sheet, folded into flight" (WEBSITE_REDESIGN_PLAN.md, Rev 4).
 * A bare, non-Starlight route at the site root. One sheet of washi folds, act by
 * act, into a crane that takes flight; Gami guides the user arc, Ori the trust/dev arc.
 *
 * Bespoke SVG (crane, feature icons, pets) carries the brand story; the four product
 * moments — gather/shape/seal/keep — are illustrated with real app screenshots framed
 * in figure.shot/.chrome, "mixed well" Apple-product-page style (Rev 5).
 * Timestamp claims stay stubbed (the §2.7 TSA re-fix is not confirmed on main).
 */
import '../styles/tokens.css';
import '../styles/theme.css';
import '../styles/landing.css';
import '../styles/landing-premium.css';
import '../styles/landing-redesign.css';
import site from '../data/site.json';
import stats from '../data/stats.json';
import { getRelease } from '../lib/release';

import craneFold from '../assets/orifold-crane-fold.svg?raw';
import gamiWag from '../assets/pets/gami-wag.svg?raw';
import oriTwitch from '../assets/pets/ori-twitch.svg?raw';

import icOcr from '../assets/icons/ocr.svg?raw';
import icCompress from '../assets/icons/compress.svg?raw';
import icForms from '../assets/icons/forms.svg?raw';
import icStamps from '../assets/icons/stamps.svg?raw';
import icReader from '../assets/icons/reader.svg?raw';
import icLanguages from '../assets/icons/languages.svg?raw';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const rel = await getRelease();

const downloadHref = rel.dmgMissing ? rel.zipUrl : rel.dmgUrl;
const assetKind = rel.dmgMissing ? '.zip' : '.dmg';
const sizePart = rel.dmgSize ? ` · ${rel.dmgSize}` : '';
const subLabel = `macOS ${site.minMacOS}+ · v${rel.version}${sizePart}`;
const releasedDate = rel.publishedAt
	? new Date(rel.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
	: null;

const cap = (name: string, dir: 'screenshots' | 'gifs' | 'landing' = 'screenshots') =>
	`${base}/assets/${dir}/${name}`;

const cards = [
	{ t: 'On-device OCR', p: 'Vision makes a scan searchable — ⌘F finds the thing your printer emailed you.', href: 'edit/ocr/', icon: icOcr },
	{ t: 'Compress', p: 'Repack oversized images losslessly so attachments stop bouncing off size limits.', href: 'export/compress/', icon: icCompress },
	{ t: 'Fill & flatten forms', p: 'Detect fields, type answers, lock them — no third-party e-sign service.', href: 'fill-sign/forms/', icon: icForms },
	{ t: 'Stamps & Bates', p: 'Numbered, stamped, and ready for the file room.', href: 'annotate/stamps/', icon: icStamps },
	{ t: 'Reader mode', p: 'The toolbar folds away. The page stays.', href: 'reading/reader-mode/', icon: icReader },
	{ t: 'Six languages', p: 'The whole workspace — menus to tooltips — in six languages.', href: 'settings/language/', icon: icLanguages },
];

const icoDownload =
	'<svg class="btn-ico" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 3v9m0 0 3.5-3.6M10 12 6.5 8.4M4 15.6h12"/></svg>';
const icoBook =
	'<svg class="btn-ico" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 5.4C8.6 4.1 6.2 3.9 4 4.4v10.8c2.2-.5 4.6-.3 6 1 1.4-1.3 3.8-1.5 6-1V4.4c-2.2-.5-4.6-.3-6 1Zm0 0v11.8"/></svg>';
const icoChevron =
	'<svg class="arrow-ico" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.5 4.5 13 10l-5.5 5.5"/></svg>';
const icoClipboard =
	'<svg class="btn-ico" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.5 3.5h5a1 1 0 0 1 1 1V5h1.5a1 1 0 0 1 1 1v9.5a1 1 0 0 1-1 1h-9a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1H6.5V4.5a1 1 0 0 1 1-1Z"/><path d="M7.5 4.5v-1a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1v1"/></svg>';
// The "Copied" check glyph is a literal <svg> inline in the copy-button script
// below (~line 648), not a frontmatter const: <script is:inline> is a static
// string, not an Astro expression context, so it can't reference frontmatter
// values directly, and define:vars would be overkill for one tiny glyph.
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<title>Orifold — Fold chaos into one clean PDF</title>
		<meta
			name="description"
			content="A free, open-source PDF workspace for macOS. Drop in up to 50 messy files — edit, sign, and export one polished document. Nothing ever leaves your Mac."
		/>
		<script is:inline>
			// First in <head>, pre-paint: set html.js + theme + the synchronous UA gate,
			// so no reveal-state flash and no CTA flash-and-shift on non-Mac devices.
			(function () {
				var d = document.documentElement;
				d.classList.add('js');
				try {
					var t = localStorage.getItem('starlight-theme');
					if (t === 'light' || t === 'dark') d.dataset.theme = t;
					else if (window.matchMedia('(prefers-color-scheme: light)').matches) d.dataset.theme = 'light';
				} catch (e) {}
				try {
					var p = (navigator.userAgentData && navigator.userAgentData.platform) || navigator.platform || '';
					var isMac = /mac/i.test(p) && !(navigator.maxTouchPoints > 1);
					if (!isMac) d.classList.add('not-mac');
				} catch (e) {}
			})();
		</script>
		<style is:global>
			/* No-JS + reduced-motion pet safety (WCAG 2.2.2): the inlined SMIL pets (act pets
			   AND the #ma guides) loop forever (begin="0s" repeatCount="indefinite") and only
			   JS can pause them. html.js is set synchronously pre-paint above, so gate on it:
			   JS present shows the (JS-gated, on-screen-only) animated figure; JS absent OR
			   reduced motion shows only a static poster and hides the SMIL — no perpetual motion. */
			.pet-anim, .guide-fig { display: none; }
			.pet-poster, .guide-poster { display: block; }
			html.js .pet-anim, html.js .guide-fig { display: block; }
			html.js .pet-poster, html.js .guide-poster { display: none; }
		</style>
		<style is:global>
			@media (prefers-reduced-motion: reduce) {
				html.js .pet-anim, html.js .guide-fig { display: none; }
				html.js .pet-poster, html.js .guide-poster { display: block; }
			}
		</style>
	</head>
	<body
		class="landing"
		data-guide="gami"
		data-repo={site.repo}
		data-repo-url={site.repoUrl}
		data-dmg-asset={site.dmgAsset}
	>
		<a class="skip-link" href="#gather">Skip to content</a>

		<!-- Nav -->
		<nav class="nav" aria-label="Primary">
			<a class="brand" href={`${base}/`}>
				<img src={`${base}/assets/orifold-app-icon-32.png`} alt="" width="30" height="30" />
				<span>Orifold</span>
			</a>
			<div class="links">
				<a class="only-wide" href="#features">Features</a>
				<a class="only-wide" href="#final-fold">Download</a>
				<a href={`${base}/get-started/what-is-orifold/`}>Docs</a>
				<a href={site.repoUrl}>GitHub</a>
			</div>
		</nav>

		<main>
			<!-- Hero -->
			<section id="sheet" class="fold">
				<div class="studio-grain" aria-hidden="true">
					<svg width="100%" height="100%" preserveAspectRatio="none">
						<filter id="washi-grain"><feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" stitchTiles="stitch" /></filter>
						<rect width="100%" height="100%" filter="url(#washi-grain)" opacity="0.05" />
					</svg>
				</div>
				<div class="wrap">
					<div class="hero-grid">
						<div class="hero-copy">
							<p class="eyebrow">Orifold — free, open source, for macOS</p>
							<h1>Fold chaos into one clean&nbsp;PDF.</h1>
							<p class="sub">
								A calm PDF workspace for macOS. Drop in up to fifty messy files — merge, edit,
								sign, and protect them — and fold the pile into one polished document. Nothing
								ever leaves your Mac.
							</p>
							<div class="btn-row">
								<a class="btn btn-primary" id="cta-hero" href={downloadHref}>
									<span class="btn-face"><Fragment set:html={icoDownload} /><span class="btn-main">Download for Mac</span></span>
									<span class="btn-sub">{subLabel}</span>
								</a>
								<a class="btn btn-ghost" href={`${base}/get-started/what-is-orifold/`}>
									<Fragment set:html={icoBook} /><span>Read the docs</span>
								</a>
							</div>
							<script is:inline>
								// Synchronous, still mid-parse: the hero CTA above already exists but the
								// page has not painted. Swap it now so non-Mac visitors never see the Mac
								// copy flash to "View on GitHub" (the .not-mac gate ran pre-paint in <head>).
								(function () {
									if (!document.documentElement.classList.contains('not-mac')) return;
									var a = document.getElementById('cta-hero');
									if (!a) return;
									a.setAttribute('href', (document.body && document.body.dataset.repoUrl) || a.href);
									var main = a.querySelector('.btn-main');
									var sub = a.querySelector('.btn-sub');
									if (main) main.textContent = 'View on GitHub';
									if (sub) sub.textContent = 'Orifold is a Mac app';
								})();
							</script>
							<p class="meta-row tabnum">
								<span>v{rel.version}</span>
								{releasedDate && <span>· released {releasedDate}</span>}
								<span>· {site.arch}</span>
								<span>· Free &amp; MIT</span>
								<span>· beta, built in public</span>
							</p>
							<p class="inoc">
								Not notarized yet — first launch takes one calm extra step. <a class="arrow-link" href="#final-fold">Here's how<span class="arrow-ico-wrap"><Fragment set:html={icoChevron} /></span></a>
							</p>
						</div>
						<div class="hero-crane" id="hero-crane" set:html={craneFold}></div>
					</div>
				</div>
			</section>

			<!-- Gather -->
			<section id="gather" class="fold">
				<div class="wrap">
					<div class="act-head crease">
						<p class="kicker">First fold · Gather</p>
						<h2>Fifty messy files. One quiet stack.</h2>
						<p class="lede">
							A "simple PDF task" is rarely one file. It's six PDFs, two screenshots, a Word
							document, a scan, and one determined file named <code>final_final_revised_ACTUAL.pdf</code>.
							Drag the whole pile in — Orifold repairs broken files on the way and stacks them into
							one workspace.
						</p>
					</div>
					<figure class="shot shot-hero crease">
						<div class="chrome">
							<div class="bar"><i></i><i></i><i></i></div>
							<img src={cap('import-files-overview.png')} width="1600" height="1013" loading="lazy" decoding="async" alt="Orifold's import screen, mid drag-and-drop, with a file about to drop into the 'Release to import files' zone and Gami greeting in the corner." />
						</div>
						<figcaption class="tabnum">Real capture — Orifold v{rel.version}. Drag anything in; broken PDFs are repaired on the way.</figcaption>
					</figure>

					<div class="pet crease" data-pet="gami">
						<span class="fig pet-arrive-target">
							<span class="pet-anim" set:html={gamiWag} aria-hidden="true"></span>
							<img class="pet-poster" src={`${base}/assets/gami-figure.svg`} width="128" height="128" alt="" aria-hidden="true" />
						</span>
						<p class="bubble">Bring the whole messy pile. I'll keep it straight.</p>
					</div>
				</div>
			</section>

			<hr class="crease-line" />

			<!-- Shape -->
			<section id="shape" class="fold">
				<div class="wrap">
					<div class="act-head crease">
						<p class="kicker">Second fold · Shape</p>
						<h2>Edit the page itself.</h2>
						<p class="lede">
							Click the text and fix the typo. Orifold edits the real glyph geometry — not a
							sticky note floating over a picture of the page. Then protect with AES-256,
							compress, or sanitize, and export one clean file.
						</p>
					</div>
					<figure class="shot shot-banner crease">
						<div class="chrome">
							<img src={cap('shape-edit-tight.png', 'landing')} width="1470" height="180" loading="lazy" decoding="async" alt="A floating text-formatting toolbar — font, size, style, alignment, color, Match/Copy/Paste/Reset — hovering directly over a real PDF page mid-edit." />
						</div>
						<figcaption class="tabnum">Real capture — Orifold v{rel.version}. The format toolbar appears right where you click.</figcaption>
					</figure>

					<div id="features" class="feature-band crease">
						<div class="card-grid">
							{cards.map((c) => (
								<a class="of-card" href={`${base}/${c.href}`}>
									<span class="glyph" aria-hidden="true" set:html={c.icon} />
									<h3>{c.t}</h3>
									<p>{c.p}</p>
								</a>
							))}
						</div>
						<p class="guides-row">
							More jobs: <a href={`${base}/import/combine/`}>Combine</a> ·
							<a href={`${base}/annotate/stamps/`}>Stamps &amp; Bates</a> ·
							<a href={`${base}/export/protect/`}>Protect</a> ·
							<a class="arrow-link" href={`${base}/fill-sign/signatures/`}>Sign<span class="arrow-ico-wrap"><Fragment set:html={icoChevron} /></span></a>
						</p>
					</div>

					<div class="pet crease" data-pet="gami" data-handoff="true">
						<span class="fig pet-arrive-target">
							<span class="pet-anim" set:html={gamiWag} aria-hidden="true"></span>
							<img class="pet-poster" src={`${base}/assets/gami-figure.svg`} width="128" height="128" alt="" aria-hidden="true" />
						</span>
						<p class="bubble">Signatures are Ori's craft. Over to her.</p>
					</div>
				</div>
			</section>

			<hr class="crease-line" />

			<!-- Seal -->
			<section id="seal" class="fold">
				<div class="wrap">
					<div class="act-head crease">
						<p class="kicker">Third fold · Seal</p>
						<h2>A signature that holds up.</h2>
						<p class="lede">
							A drawn mark is a picture. A digital signature is math — a tamper-evident seal
							over the exact bytes you signed. Orifold produces standards-based PAdES
							signatures with Keychain and .p12 identities, verifiable anywhere PAdES is
							understood. <a class="arrow-link" href={`${base}/fill-sign/signatures/`}>How signing works<span class="arrow-ico-wrap"><Fragment set:html={icoChevron} /></span></a>
						</p>
					</div>
					<figure class="shot shot-card crease">
						<div class="chrome">
							<img src={cap('seal-signatures-tight.png', 'landing')} width="415" height="745" loading="lazy" decoding="async" alt="The Signatures panel with Digital selected, a self-signed identity chosen, and a live cursive signature preview reading 'Umang D.' with a 'Signed: Jul 7, 2026 at 9:12 PM' timestamp below, before Sign & Export." />
						</div>
						<figcaption class="tabnum">Real capture — Orifold v{rel.version}. PAdES signing, right where you're already working.</figcaption>
					</figure>

					<div class="pet crease" data-pet="ori">
						<span class="fig pet-arrive-target">
							<span class="pet-anim" set:html={oriTwitch} aria-hidden="true"></span>
							<img class="pet-poster" src={`${base}/assets/ori-figure.svg`} width="128" height="128" alt="" aria-hidden="true" />
						</span>
						<p class="bubble">Real cryptography. Not a picture of ink.</p>
					</div>
				</div>
			</section>

			<hr class="crease-line" />

			<!-- Keep -->
			<section id="keep" class="fold">
				<div class="wrap">
					<div class="act-head crease">
						<p class="kicker">Fourth fold · Keep</p>
						<h2>The studio has no windows.</h2>
						<p class="lede">Everything happens on your Mac. The cloud was not consulted.</p>
					</div>
					<figure class="shot shot-card crease">
						<div class="chrome">
							<img src={cap('keep-export-tight.png', 'landing')} width="640" height="475" loading="lazy" decoding="async" alt="The Export dialog with Protect with password, Reduce file size, and Sanitize for sharing options, ready before export." />
						</div>
						<figcaption class="tabnum">Real capture — Orifold v{rel.version}. Sanitize strips what you didn't mean to share.</figcaption>
					</figure>
					<div class="stat-row crease">
						<div class="stat"><b>0</b><span>The app asks the network for nothing.</span></div>
						<div class="stat"><b>AES-256</b><span>Real encryption, not a "protected" flag a reader can ignore.</span></div>
						<div class="stat"><b>Sanitize</b><span>A file that carries nothing you didn't intend to send.</span></div>
						<div class="stat"><b>{stats.tests}</b><span>tests gate every release.</span></div>
						<div class="stat"><b>MIT</b><span>Free forever, open source.</span></div>
						<div class="stat"><b>6</b><span>languages, everything on-device.</span></div>
					</div>
					<p class="fine-print">
						This page asks GitHub for the latest version number so the button below is always
						current. The app never does.
					</p>

					<div class="pet crease" data-pet="ori">
						<span class="fig pet-arrive-target">
							<span class="pet-anim" set:html={oriTwitch} aria-hidden="true"></span>
							<img class="pet-poster" src={`${base}/assets/ori-figure.svg`} width="128" height="128" alt="" aria-hidden="true" />
						</span>
						<p class="bubble">Don't trust me. <a href={site.repoUrl}>Read the source.</a> I did.</p>
					</div>
				</div>
			</section>

			<hr class="crease-line" />

			<!-- Ma — why + the living guides -->
			<section id="ma" class="fold">
				<div class="wrap">
					<div class="crease" style="text-align:center">
						<p class="kicker" style="margin-inline:auto"><span lang="ja" aria-hidden="true">間</span><span class="sr-only">Ma — the margin</span> · The margin</p>
						<h2>Why it folds this way.</h2>
						<p class="ma-body">
							Basic file work on a Mac shouldn't require a subscription, an upload, or a small
							ceremony. Preview is excellent until the job gets complicated; the more capable tools
							rent your own files back to you. So Orifold is the workspace I wanted: native, local,
							and free — where merging, editing, signing, and protecting a document are one calm
							sequence, not six errands across five apps. Still a beta, built in the open, one honest
							fold at a time.
						</p>
					</div>

					<div class="guides crease">
						<div class="guide" data-pet="gami">
							<span class="guide-fig" set:html={gamiWag} aria-hidden="true"></span>
							<img class="guide-poster" src={`${base}/assets/gami-figure.svg`} width="96" height="96" alt="" aria-hidden="true" />
							<div class="guide-copy">
								<h3>Gami</h3>
								<p>A calm paper Bernedoodle — your everyday guide. Shows up when something needs you, then folds back into the corner.</p>
							</div>
						</div>
						<div class="guide" data-pet="ori">
							<span class="guide-fig" set:html={oriTwitch} aria-hidden="true"></span>
							<img class="guide-poster" src={`${base}/assets/ori-figure.svg`} width="96" height="96" alt="" aria-hidden="true" />
							<div class="guide-copy">
								<h3>Ori</h3>
								<p>A clever paper Siberian — precise and a touch bossy. She keeps an eye on the technical corners: signing, privacy, the fine print.</p>
							</div>
						</div>
					</div>

					<figure class="shot shot-proof crease">
						<div class="chrome">
							<div class="bar"><i></i><i></i><i></i></div>
							<img src={cap('language-switcher.png')} width="1200" height="752" loading="lazy" decoding="async" alt="Orifold's welcome screen: the app open with Gami in the corner and a language menu showing English, Español, Français, हिन्दी, 简体中文, 日本語." />
						</div>
						<figcaption class="tabnum">Real capture — Orifold v{rel.version}. Not a render — Gami greets you in the app, in six languages.</figcaption>
					</figure>
				</div>
			</section>

			<hr class="crease-line" />

			<!-- Download — take flight -->
			<section id="final-fold" class="fold download-fold">
				<div class="wrap">
					<div class="act-head crease" style="text-align:center">
						<p class="kicker" style="margin-inline:auto">Final fold · Take flight</p>
						<h2>Take it home.</h2>
					</div>
					<div class="final-crane crease" aria-hidden="true">
						<img src={`${base}/assets/orifold-app-icon-512.png`} width="512" height="512" loading="lazy" decoding="async" alt="" />
					</div>
					<div class="dl-grid">
						<div class="dl-user crease" style="min-width:0">
							<a class="btn btn-primary btn-lg" id="cta-final" href={downloadHref}>
								<span class="btn-face"><Fragment set:html={icoDownload} /><span class="btn-main">Download for Mac</span></span>
								<span class="btn-sub">{subLabel}</span>
							</a>
							<p class="meta-row tabnum">
								<span id="asset-kind-label">{assetKind} · v{rel.version}</span>
								{rel.dmgSize && <span id="asset-size-label">· {rel.dmgSize}</span>}
								<span>· {site.arch} · macOS {site.minMacOS}+</span>
							</p>
							<p class="lede">
								Needs a Mac with an Apple M-series chip — any Mac from 2020 on
								(→ About This Mac to check). Intel Macs aren't supported
								<a href={`${site.repoUrl}/issues`}>yet</a>.
							</p>

							<div class="pet" data-pet="gami">
								<span class="fig pet-arrive-target">
									<span class="pet-anim" set:html={gamiWag} aria-hidden="true"></span>
									<img class="pet-poster" src={`${base}/assets/gami-figure.svg`} width="104" height="104" alt="" aria-hidden="true" />
								</span>
								<p class="bubble">One-time thing. Two seconds. Here's how —</p>
							</div>
							<div class="callout-note">
								<p>Orifold is free and open source, so builds aren't notarized by Apple yet. One-time first launch:</p>
								<p><b>macOS 14:</b> right-click Orifold → Open → Open.</p>
								<p><b>macOS 15:</b> open Orifold once (it's blocked), then System Settings → Privacy &amp; Security → <b>Open Anyway</b> → password.</p>
								<p>Prefer zero dialogs? The one-line installer below clears quarantine for you.</p>
							</div>

							<details class="details">
								<summary>Other ways to install</summary>
								<div class="chip-cmd" style="margin-top:0.8rem">
									<code>brew install --cask orifold</code>
									<button type="button" class="copy-btn" data-copy="brew install --cask orifold" aria-label="Copy Homebrew command">
										<Fragment set:html={icoClipboard} /><span class="copy-btn-label">Copy</span>
									</button>
								</div>
								<p class="fine-print" style="margin-top:0.8rem">
									Or the one-line installer (no dialogs — it clears quarantine automatically), or the
									direct <a href={rel.zipUrl}>.zip</a>. <a class="arrow-link" href={rel.allReleasesUrl}>All releases<span class="arrow-ico-wrap"><Fragment set:html={icoChevron} /></span></a>
								</p>
							</details>
						</div>

						<div class="dl-dev crease" style="min-width:0">
							<h3>Build it yourself</h3>
							<div class="term-card">
								<div style="overflow-wrap:anywhere"><span class="prompt">❯</span> git clone {site.repoUrl}.git</div>
								<div><span class="prompt">❯</span> cd Orifold</div>
								<div><span class="prompt">❯</span> ./scripts/install-mac.command</div>
							</div>
							<div class="pet" data-pet="ori">
								<span class="fig pet-arrive-target">
									<span class="pet-anim" set:html={oriTwitch} aria-hidden="true"></span>
									<img class="pet-poster" src={`${base}/assets/ori-figure.svg`} width="104" height="104" alt="" aria-hidden="true" />
								</span>
								<p class="bubble">Doubt me? Build it yourself.</p>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>

		<footer class="landing-footer">
			<div class="wrap">
				<p class="row">
					<strong>Folded by hand. MIT licensed.</strong>
					<span class="marks" aria-hidden="true">
						<img src={`${base}/assets/gami-mark.svg`} alt="" />
						<img src={`${base}/assets/ori-mark.svg`} alt="" />
					</span>
				</p>
				<p class="row">
					<a href={`${base}/get-started/what-is-orifold/`}>Docs</a>
					<a href={`${base}/releases/`}>What's New</a>
					<a href={`${base}/settings/privacy/`}>Privacy</a>
					<a href={site.repoUrl}>GitHub</a>
					<a href={`${site.repoUrl}/blob/main/LICENSE`}>License</a>
					<a class="tabnum" href={rel.releaseUrl}>v{rel.version}{releasedDate ? ` · released ${releasedDate}` : ''}</a>
				</p>
				<p class="sig">
					Since nothing you do in Orifold ever leaves your Mac, stars are the only telemetry we
					get. ⭐
				</p>
			</div>
		</footer>

		<script is:inline>
			(function () {
				var d = document.documentElement;
				var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				var body = document.body;

				// ── reveal observer ──────────────────────────────────────────
				if ('IntersectionObserver' in window && !reduce) {
					var revIO = new IntersectionObserver(
						function (entries) {
							entries.forEach(function (e) {
								if (e.isIntersecting) {
									e.target.classList.add('is-revealed');
									revIO.unobserve(e.target);
								}
							});
						},
						{ threshold: 0.14 }
					);
					document.querySelectorAll('.crease').forEach(function (el) { revIO.observe(el); });
				} else {
					document.querySelectorAll('.crease').forEach(function (el) { el.classList.add('is-revealed'); });
				}

				// ── pet controller: pets play while on screen, pause off-screen (smooth) ─
				function petSvg(el) { return el.querySelector('.pet-anim svg') || el.querySelector('.guide-fig svg'); }
				// Pause every pet's SMIL on load (they carry begin="0s" repeatCount="indefinite",
				// which only JS can stop). We then unpause a pet only while it's on screen and
				// re-pause it when it leaves — so at most the visible pets ever animate, and
				// reduced-motion visitors (who see the static poster instead) never trigger a play.
				document.querySelectorAll('.pet-anim svg, .guide-fig svg').forEach(function (svg) {
					if (svg.pauseAnimations) { try { svg.pauseAnimations(); } catch (e) {} }
				});
				if ('IntersectionObserver' in window) {
					var petIO = new IntersectionObserver(
						function (entries) {
							entries.forEach(function (e) {
								var svg = petSvg(e.target);
								if (e.isIntersecting) {
									e.target.classList.add('pet-arrived');
									if (!reduce && svg && svg.unpauseAnimations) { try { svg.unpauseAnimations(); } catch (er) {} }
								} else if (svg && svg.pauseAnimations) {
									try { svg.pauseAnimations(); } catch (er) {}
								}
							});
						},
						{ threshold: 0.4 }
					);
					document.querySelectorAll('.pet, .guide').forEach(function (p) { petIO.observe(p); });
				} else {
					document.querySelectorAll('.pet, .guide').forEach(function (p) { p.classList.add('pet-arrived'); });
				}

				// ── Gami→Ori handoff tint (with hysteresis) ──────────────────
				var handoff = document.querySelector('.pet[data-handoff]');
				if (handoff && 'IntersectionObserver' in window) {
					var flipped = false;
					var hoIO = new IntersectionObserver(
						function (entries) {
							entries.forEach(function (e) {
								if (e.isIntersecting && !flipped) { body.dataset.guide = 'ori'; flipped = true; }
								else if (!e.isIntersecting && flipped && e.boundingClientRect.top > 0) {
									body.dataset.guide = 'gami'; flipped = false;
								}
							});
						},
						{ rootMargin: '-45% 0px -45%' }
					);
					hoIO.observe(handoff);
				}

				// ── nav: scroll-linked active-section state ───────────────────
				if ('IntersectionObserver' in window) {
					var navLinks = {};
					document.querySelectorAll('.nav .links a[href^="#"]').forEach(function (a) {
						navLinks[a.getAttribute('href').slice(1)] = a;
					});
					var navSections = Object.keys(navLinks)
						.map(function (id) { return document.getElementById(id); })
						.filter(Boolean);
					if (navSections.length) {
						var navIO = new IntersectionObserver(
							function (entries) {
								entries.forEach(function (e) {
									var link = navLinks[e.target.id];
									if (!link) return;
									if (e.isIntersecting) {
										Object.keys(navLinks).forEach(function (id) {
											navLinks[id].classList.remove('is-active');
											navLinks[id].removeAttribute('aria-current');
										});
										link.classList.add('is-active');
										link.setAttribute('aria-current', 'true');
									}
								});
							},
							{ rootMargin: '-45% 0px -50%' }
						);
						navSections.forEach(function (s) { navIO.observe(s); });
					}
				}

				// ── hero crane: play once, then freeze (also gates reduced-motion) ──
				// This is the real brand mark (orifold-crane-fold.svg — the same animated
				// logo used in the README and docs), not a bespoke one-off. Its 65 SMIL
				// animations all loop indefinitely over a 7.6s cycle with no begin offset,
				// so the settle time must land on the fully-formed crane pose (WITH its
				// tancho crown visible), not mid-transition or already folding onward into
				// the app-icon shape. Verified frame-by-frame: the sheet is still flat at
				// 0.1s, a recognizable crane appears by ~2.5s, and it holds a stable,
				// crown-visible pose across at least 3.1s–3.4s before continuing to fold
				// toward the icon — 3.2s sits centered in that held window. That window is
				// only ~300ms wide, and a plain setTimeout can drift past it under real
				// page-load contention (fires late relative to the SVG's own SMIL clock),
				// so instead we poll the SVG's actual getCurrentTime() every animation
				// frame and pause the instant it crosses the target — that stays locked to
				// the real clock regardless of load, rather than an independent timer.
				var heroCrane = document.getElementById('hero-crane');
				var heroCraneSvg = heroCrane && heroCrane.querySelector('svg');
				if (heroCraneSvg && heroCraneSvg.pauseAnimations) {
					var settleTime = 3.2;
					if (reduce) {
						heroCraneSvg.setCurrentTime(settleTime);
						heroCraneSvg.pauseAnimations();
					} else {
						(function watchSettle() {
							try {
								if (heroCraneSvg.getCurrentTime() >= settleTime) {
									heroCraneSvg.pauseAnimations();
									return;
								}
							} catch (e) {
								return;
							}
							requestAnimationFrame(watchSettle);
						})();
					}
				}

				// ── copy buttons ─────────────────────────────────────────────
				document.querySelectorAll('.copy-btn').forEach(function (btn) {
					var icon = btn.querySelector('.btn-ico');
					var label = btn.querySelector('.copy-btn-label');
					var originalIcon = icon ? icon.outerHTML : '';
					var originalLabel = label ? label.textContent : 'Copy';
					btn.addEventListener('click', function () {
						var txt = btn.getAttribute('data-copy');
						if (navigator.clipboard) navigator.clipboard.writeText(txt);
						if (icon) icon.outerHTML = '<svg class="btn-ico" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 10.5 8 14l7.5-8.5"/></svg>';
						icon = btn.querySelector('.btn-ico');
						if (label) label.textContent = 'Copied';
						setTimeout(function () {
							if (icon) icon.outerHTML = originalIcon;
							icon = btn.querySelector('.btn-ico');
							if (label) label.textContent = originalLabel;
						}, 1400);
					});
				});

				// ── release enhancer: confirm-or-upgrade only ─────────────────
				var repo = body.dataset.repo;
				if (repo && 'fetch' in window) {
					fetch('https://api.github.com/repos/' + repo + '/releases/latest', {
						headers: { Accept: 'application/vnd.github+json' },
					})
						.then(function (r) { return r.ok ? r.json() : null; })
						.catch(function () { return null; })
						.then(function (data) {
							if (!data || !data.tag_name) return;
							var v = data.tag_name.replace(/^release-/, '').replace(/^v/, '');
							var dmgAsset = body.dataset.dmgAsset || 'Orifold.dmg';
							var dmg = (data.assets || []).filter(function (a) { return a.name === dmgAsset; })[0];
							document.querySelectorAll('.btn-sub').forEach(function (el) {
								el.textContent = el.textContent.replace(/v[0-9][^\s·]*/, 'v' + v);
							});
							var kindLabel = document.getElementById('asset-kind-label');
							if (kindLabel) kindLabel.textContent = kindLabel.textContent.replace(/v[0-9][^\s·]*/, 'v' + v);
							if (dmg && !d.classList.contains('not-mac')) {
								document.querySelectorAll('#cta-hero, #cta-final').forEach(function (a) {
									a.setAttribute('href', dmg.browser_download_url);
								});
								if (kindLabel) kindLabel.textContent = kindLabel.textContent.replace(/^\.[a-z0-9]+/i, '.dmg');
								var sizeLabel = document.getElementById('asset-size-label');
								var mb = dmg.size ? (dmg.size / (1024 * 1024)).toFixed(1) + ' MB' : null;
								if (mb) {
									if (sizeLabel) sizeLabel.textContent = '· ' + mb;
									else if (kindLabel && kindLabel.parentNode) {
										var span = document.createElement('span');
										span.id = 'asset-size-label';
										span.textContent = '· ' + mb;
										kindLabel.insertAdjacentElement('afterend', span);
									}
								}
							}
						});
				}

				// ── non-Mac CTA swap (detection ran pre-paint in <head>) ─────
				if (d.classList.contains('not-mac')) {
					document.querySelectorAll('#cta-hero, #cta-final').forEach(function (a) {
						a.setAttribute('href', body.dataset.repoUrl || a.href);
						var main = a.querySelector('.btn-main');
						var sub = a.querySelector('.btn-sub');
						if (main) main.textContent = 'View on GitHub';
						if (sub) sub.textContent = 'Orifold is a Mac app';
					});
				}
			})();
		</script>
	</body>
</html>
