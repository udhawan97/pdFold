---
/**
 * Orifold landing — "Fold chaos into one clean PDF."
 * The full original story — hero, gather 一, shape 二 (+ feature cards),
 * seal 三, keep 四, ma 間, horizon, updates, the final fold, and the paper
 * fortune, with Gami and Ori talking throughout — reset on an ukiyo-e system:
 * indigo-on-cream paper, Shippori Mincho display, the app icon's own
 * indigo→ice gradient as the identity, and red reserved for the tancho crown.
 *
 * Light (paper) is the default — origami starts on paper — with a full
 * ink-night dark theme on the shared `starlight-theme` key. All motion is
 * transform/opacity and settles fully under prefers-reduced-motion.
 */
import '../styles/landing-washi.css';
import site from '../data/site.json';
import stats from '../data/stats.json';
import { getRelease } from '../lib/release';

import craneFold from '../assets/orifold-crane-fold.svg?raw';
import differenceFlight from '../assets/orifold-difference.svg?raw';
import differenceFlightMobile from '../assets/orifold-difference-mobile.svg?raw';
import gamiWag from '../assets/pets/gami-wag.svg?raw';
import oriTwitch from '../assets/pets/ori-twitch.svg?raw';

import icOcr from '../assets/icons/ocr.svg?raw';
import icCompress from '../assets/icons/compress.svg?raw';
import icForms from '../assets/icons/forms.svg?raw';
import icStamps from '../assets/icons/stamps.svg?raw';
import icReader from '../assets/icons/reader.svg?raw';
import icLanguages from '../assets/icons/languages.svg?raw';

// Roadmap ("Horizon") glyphs — same line-art grammar as the feature icons.
import icRedact from '../assets/icons/redact.svg?raw';
import icBatch from '../assets/icons/batch.svg?raw';
import icCompare from '../assets/icons/compare.svg?raw';
import icFast from '../assets/icons/fast.svg?raw';
import icGlobe from '../assets/icons/globe.svg?raw';
import icUnlock from '../assets/icons/unlock.svg?raw';

// "How updates work" glyphs.
import icNotify from '../assets/icons/notify.svg?raw';
import icConsent from '../assets/icons/consent.svg?raw';
import icOnDevice from '../assets/icons/on-device.svg?raw';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const rel = await getRelease();

const downloadHref = rel.dmgMissing ? rel.zipUrl : rel.dmgUrl;
const assetKind = rel.dmgMissing ? '.zip' : '.dmg';
const sizePart = rel.dmgSize ? ` · ${rel.dmgSize}` : '';
const subLabel = `macOS ${site.minMacOS}+ · v${rel.version}${sizePart}`;
const releasedDate = rel.publishedAt
	? new Date(rel.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
	: null;

const cap = (name: string, dir: 'screenshots' | 'gifs' | 'landing' = 'screenshots') =>
	`${base}/assets/${dir}/${name}`;

// The six everyday folds — each card carries a faint origami kanji watermark.
const cards = [
	{ t: 'On-device OCR', k: '読', km: 'read', p: 'Vision makes a scan searchable — ⌘F finds the thing your printer emailed you.', href: 'edit/ocr/', icon: icOcr },
	{ t: 'Compress', k: '縮', km: 'shrink', p: 'Repack oversized images losslessly so attachments stop bouncing off size limits.', href: 'export/compress/', icon: icCompress },
	{ t: 'Fill & flatten forms', k: '記', km: 'record', p: 'Detect fields, type answers, lock them — no third-party e-sign service.', href: 'fill-sign/forms/', icon: icForms },
	{ t: 'Stamps & Bates', k: '判', km: 'seal', p: 'Numbered, stamped, and ready for the file room.', href: 'annotate/stamps/', icon: icStamps },
	{ t: 'Reader mode', k: '静', km: 'quiet', p: 'The toolbar folds away. The page stays.', href: 'reading/reader-mode/', icon: icReader },
	{ t: 'Six languages', k: '語', km: 'language', p: 'The whole workspace — menus to tooltips — in six languages.', href: 'settings/language/', icon: icLanguages },
];

const icoBook =
	'<svg class="btn-ico" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 5.4C8.6 4.1 6.2 3.9 4 4.4v10.8c2.2-.5 4.6-.3 6 1 1.4-1.3 3.8-1.5 6-1V4.4c-2.2-.5-4.6-.3-6 1Zm0 0v11.8"/></svg>';
const icoChevron =
	'<svg class="arrow-ico" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.5 4.5 13 10l-5.5 5.5"/></svg>';
const icoClipboard =
	'<svg class="btn-ico" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.5 3.5h5a1 1 0 0 1 1 1V5h1.5a1 1 0 0 1 1 1v9.5a1 1 0 0 1-1 1h-9a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1H6.5V4.5a1 1 0 0 1 1-1Z"/><path d="M7.5 4.5v-1a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1v1"/></svg>';
// Theme-toggle glyphs. The toggle shows the icon of the theme it will switch TO
// (moon while in light, sun while in dark); CSS swaps them on [data-theme].
const icoSun =
	'<svg class="ico-sun" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="10" cy="10" r="3.4"/><path d="M10 2.2v2.1M10 15.7v2.1M2.2 10h2.1M15.7 10h2.1M4.5 4.5l1.5 1.5M14 14l1.5 1.5M15.5 4.5 14 6M6 14l-1.5 1.5"/></svg>';
const icoMoon =
	'<svg class="ico-moon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16.2 11.8A6.5 6.5 0 0 1 8.2 3.8a6.5 6.5 0 1 0 8 8Z"/></svg>';
const icoNoteClose =
	'<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8"/></svg>';

// Apple logo — leads the primary "Download for Mac" CTA. Solid fill:currentColor
// so it inherits the button's ink in both themes.
const icoApple =
	'<svg class="btn-ico btn-ico-apple" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M11.182.008C11.148-.03 9.923.023 8.857 1.18c-1.066 1.156-.902 2.482-.878 2.516.024.034 1.52.087 2.475-1.258.955-1.345.762-2.391.728-2.43zm3.314 11.733c-.048-.096-2.325-1.234-2.113-3.422.212-2.189 1.675-2.789 1.698-2.854.023-.065-.597-.79-1.254-1.157a3.7 3.7 0 0 0-1.563-.434c-.108-.003-.483-.095-1.254.116-.508.139-1.653.589-1.968.607-.316.018-1.256-.522-2.267-.665-.647-.125-1.333.131-1.824.328-.49.196-1.422.754-2.074 2.237-.652 1.482-.311 3.83-.067 4.56s.625 1.924 1.273 2.796c.576.984 1.34 1.667 1.659 1.899.319.232 1.219.386 1.843.067.502-.308 1.408-.485 1.766-.472.357.013 1.061.154 1.782.539.571.197 1.111.115 1.652-.105.541-.221 1.324-1.059 2.238-2.758.347-.79.505-1.217.473-1.282z"/></svg>';
// Icon-style meta badges — small stroke glyphs tinted by .badge-ico.
const badgeIco = {
	// version — a luggage/price tag
	tag: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3.3 3.3h5.3l7.9 7.9-5.3 5.3-7.9-7.9V3.3Z"/><circle cx="6.5" cy="6.5" r="1"/></svg>',
	// released date — calendar
	calendar: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.3" y="4.6" width="13.4" height="12.1" rx="2.2"/><path d="M3.3 8.2h13.4M6.8 2.8v3M13.2 2.8v3"/></svg>',
	// architecture — a silicon chip
	chip: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5.6" y="5.6" width="8.8" height="8.8" rx="1.8"/><rect x="8.2" y="8.2" width="3.6" height="3.6" rx="0.8"/><path d="M8 2.6v2.4M12 2.6v2.4M8 15v2.4M12 15v2.4M2.6 8h2.4M2.6 12h2.4M15 8h2.4M15 12h2.4"/></svg>',
	// licence — a checkmark seal
	license: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.4l1.9 1.25 2.28-.13.72 2.17 1.9 1.27-.62 2.2.62 2.2-1.9 1.27-.72 2.17-2.28-.13L10 17.6l-1.9-1.25-2.28.13-.72-2.17-1.9-1.27.62-2.2-.62-2.2 1.9-1.27.72-2.17 2.28.13L10 2.4Z"/><path d="M7.4 10l1.8 1.8 3.4-3.8"/></svg>',
	// beta — a sparkle
	beta: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.8l1.7 4.4 4.5 1.4-4.5 1.4L10 14.6l-1.7-4.6L3.8 8.6l4.5-1.4L10 2.8Z"/></svg>',
	// download kind (.dmg) — a package box
	package: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2.6 16.6 6.2v7.6L10 17.4 3.4 13.8V6.2L10 2.6Z"/><path d="M3.6 6.3 10 9.9l6.4-3.6M10 9.9v7.4"/></svg>',
	// file size — a hard drive
	drive: '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.2" y="6.4" width="13.6" height="7.2" rx="2.2"/><path d="M6 10h3.4"/><circle cx="13.2" cy="10" r="1"/></svg>',
	// macOS requirement — the Apple mark reused at badge size
	apple: '<svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M11.182.008C11.148-.03 9.923.023 8.857 1.18c-1.066 1.156-.902 2.482-.878 2.516.024.034 1.52.087 2.475-1.258.955-1.345.762-2.391.728-2.43zm3.314 11.733c-.048-.096-2.325-1.234-2.113-3.422.212-2.189 1.675-2.789 1.698-2.854.023-.065-.597-.79-1.254-1.157a3.7 3.7 0 0 0-1.563-.434c-.108-.003-.483-.095-1.254.116-.508.139-1.653.589-1.968.607-.316.018-1.256-.522-2.267-.665-.647-.125-1.333.131-1.824.328-.49.196-1.422.754-2.074 2.237-.652 1.482-.311 3.83-.067 4.56s.625 1.924 1.273 2.796c.576.984 1.34 1.667 1.659 1.899.319.232 1.219.386 1.843.067.502-.308 1.408-.485 1.766-.472.357.013 1.061.154 1.782.539.571.197 1.111.115 1.652-.105.541-.221 1.324-1.059 2.238-2.758.347-.79.505-1.217.473-1.282z"/></svg>',
};

// The hero's release facts as icon badges.
const heroBadges = [
	{ icon: badgeIco.tag, label: `v${rel.version}` },
	...(releasedDate ? [{ icon: badgeIco.calendar, label: releasedDate }] : []),
	{ icon: badgeIco.chip, label: site.arch },
	{ icon: badgeIco.license, label: 'Free & Apache 2.0' },
	{ icon: badgeIco.beta, label: 'Beta' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<meta name="theme-color" content="#f6f3ea" />
		<title>Orifold — Fold chaos into one clean PDF</title>
		<meta
			name="description"
			content="A free, open-source PDF workspace for macOS. Drop in up to 50 messy files — edit, sign, and export one polished document. Nothing ever leaves your Mac."
		/>
		<meta property="og:title" content="Orifold — Fold chaos into one clean PDF" />
		<meta
			property="og:description"
			content="A calm, local-first PDF workspace for macOS. Free, open source, and entirely on-device."
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600;700&family=Shippori+Mincho:wght@500;600&display=swap"
		/>
		<script is:inline>
			// First in <head>, pre-paint: set html.js + theme + the synchronous UA gate,
			// so no reveal-state flash and no CTA flash-and-shift on non-Mac devices.
			(function () {
				var d = document.documentElement;
				d.classList.add('js');
				try {
					// Orifold's metaphor is paper/origami, so the site opens "on paper":
					// LIGHT by default on a first visit, deliberately NOT following the OS
					// color scheme. Only an explicit prior choice of 'dark' departs from
					// light; the shared 'starlight-theme' key keeps the landing page and the
					// Starlight docs in lockstep. data-theme is always resolved here (never
					// left unset) so the first paint is already the correct theme — no flash.
					var t = localStorage.getItem('starlight-theme');
					d.dataset.theme = t === 'dark' ? 'dark' : 'light';
					// The first-visit theme note shows only until the visitor makes a choice
					// (toggles a theme) or dismisses it — resolved pre-paint so returning
					// visitors never get a flash of the note.
					var chosen = t === 'light' || t === 'dark';
					var dismissed = localStorage.getItem('orifold-theme-note') === 'dismissed';
					if (!chosen && !dismissed) d.classList.add('theme-unchosen');
				} catch (e) {
					d.dataset.theme = 'light';
				}
				try {
					var p = (navigator.userAgentData && navigator.userAgentData.platform) || navigator.platform || '';
					var isMac = /mac/i.test(p) && !(navigator.maxTouchPoints > 1);
					if (!isMac) d.classList.add('not-mac');
				} catch (e) {}
			})();
		</script>
		<style is:global>
			/* No-JS + reduced-motion pet safety (WCAG 2.2.2): the inlined SMIL pets (act pets
			   AND the #ma guides) loop forever (begin="0s" repeatCount="indefinite") and only
			   JS can pause them. html.js is set synchronously pre-paint above, so gate on it:
			   JS present shows the (JS-gated, on-screen-only) animated figure; JS absent OR
			   reduced motion shows only a static poster and hides the SMIL — no perpetual motion. */
			.pet-anim, .guide-fig { display: none; }
			.pet-poster, .guide-poster { display: block; }
			html.js .pet-anim, html.js .guide-fig { display: block; }
			html.js .pet-poster, html.js .guide-poster { display: none; }
		</style>
		<style is:global>
			@media (prefers-reduced-motion: reduce) {
				html.js .pet-anim, html.js .guide-fig { display: none; }
				html.js .pet-poster, html.js .guide-poster { display: block; }
			}
		</style>
	</head>
	<body
		class="landing"
		data-guide="gami"
		data-repo={site.repo}
		data-repo-url={site.repoUrl}
		data-dmg-asset={site.dmgAsset}
	>
		<a class="skip-link" href="#gather">Skip to content</a>
		<div class="route-progress" aria-hidden="true"></div>
		<div class="grain" aria-hidden="true"></div>

		<!-- Nav -->
		<nav class="nav" aria-label="Primary">
			<a class="brand" href={`${base}/`}>
				<img src={`${base}/assets/orifold-app-icon-32.png`} alt="" width="30" height="30" />
				<span>ORIFOLD</span>
			</a>
			<div class="links">
				<a class="only-wide" href="#features">Features</a>
				<a class="only-wide" href="#final-fold">Download</a>
				<a href={`${base}/get-started/what-is-orifold/`}>Docs</a>
				<a href={site.repoUrl}>GitHub</a>
				<button
					type="button"
					class="theme-toggle"
					aria-label="Switch to dark mode"
					aria-pressed="false"
					title="Switch to dark mode"
				>
					<Fragment set:html={icoSun} />
					<Fragment set:html={icoMoon} />
				</button>
			</div>
		</nav>

		<main>
			<!-- Hero -->
			<section id="sheet" class="fold">
				<div class="wrap">
					<div class="hero-grid">
						<div class="hero-copy">
							<p class="eyebrow" data-load="1">Orifold — free, open source, for macOS</p>
							<h1 aria-label="Fold chaos into one clean PDF.">
								<span class="hl" data-load="2"><span>Fold chaos into</span></span>
								<span class="hl" data-load="3"><span><em>one clean PDF</em>.</span></span>
							</h1>
							<p class="sub" data-load="4">
								A calm PDF workspace for macOS. Drop in up to fifty messy files — merge, edit,
								sign, and protect them — and fold the pile into one polished document. Nothing
								ever leaves your Mac.
							</p>
							<div class="btn-row" data-load="5">
								<a class="btn btn-primary" id="cta-hero" href={downloadHref}>
									<span class="btn-face"><Fragment set:html={icoApple} /><span class="btn-main">Download for Mac</span></span>
									<span class="btn-sub">{subLabel}</span>
								</a>
								<a class="btn btn-ghost" href={`${base}/get-started/what-is-orifold/`}>
									<Fragment set:html={icoBook} /><span>Read the docs</span>
								</a>
							</div>
							<script is:inline>
								// Synchronous, still mid-parse: the hero CTA above already exists but the
								// page has not painted. Swap it now so non-Mac visitors never see the Mac
								// copy flash to "View on GitHub" (the .not-mac gate ran pre-paint in <head>).
								(function () {
									if (!document.documentElement.classList.contains('not-mac')) return;
									var a = document.getElementById('cta-hero');
									if (!a) return;
									a.setAttribute('href', (document.body && document.body.dataset.repoUrl) || a.href);
									var main = a.querySelector('.btn-main');
									var sub = a.querySelector('.btn-sub');
									if (main) main.textContent = 'View on GitHub';
									if (sub) sub.textContent = 'Orifold is a Mac app';
								})();
							</script>
							<p class="meta-row tabnum" data-load="6" aria-label="Release details">
								{heroBadges.map((b) => (
									<span class="badge"><span class="badge-ico" set:html={b.icon} />{b.label}</span>
								))}
							</p>
							<p class="inoc" data-load="7">
								Not notarized yet — first launch takes one calm extra step. <a class="arrow-link" href="#final-fold">Here's how<span class="arrow-ico-wrap"><Fragment set:html={icoChevron} /></span></a>
							</p>
							<!-- First-visit theme note. Hidden by default; the pre-paint script in
							     <head> reveals it (html.theme-unchosen) only for visitors who have
							     not yet picked a theme or dismissed it. -->
							<p class="theme-note" role="note">
								<span
									>Origami starts on paper, so we start in light mode. Prefer saving your retinas?
									Dark mode is up top.</span
								>
								<button type="button" class="theme-note-dismiss" aria-label="Dismiss this note">
									<Fragment set:html={icoNoteClose} />
								</button>
							</p>
						</div>
						<figure class="hero-blueprint" id="hero-crane" aria-labelledby="hero-blueprint-caption" data-load="8">
							<div class="blueprint-orbit" aria-hidden="true"></div>
							<div class="blueprint-shell">
								<img class="theme-art" src={`${base}/assets/hero-banner-light.svg`} width="1080" height="536" alt="Fifty messy files flow through Orifold's local merge, OCR, signing, compression, and encryption tools to become one polished, searchable, password-protected PDF. Up to 50 files per workspace, zero files uploaded, 12-plus PDF tools, and free forever." />
								<div class="mobile-svg-story" aria-label="Orifold workflow and product facts">
									<p class="mobile-story-kicker">Nothing leaves your Mac</p>
									<div class="mobile-story-flow">
										<div><b>50 messy files</b><span>PDFs, scans, notes</span></div>
										<span aria-hidden="true">→</span>
										<div><b>Orifold</b><span>Merge · OCR · Sign · Protect</span></div>
										<span aria-hidden="true">→</span>
										<div><b>One clean PDF</b><span>Searchable and secured</span></div>
									</div>
									<dl class="mobile-story-stats">
										<div><dt>50</dt><dd>files</dd></div><div><dt>0</dt><dd>uploads</dd></div>
										<div><dt>12+</dt><dd>tools</dd></div><div><dt>$0</dt><dd>forever</dd></div>
									</dl>
								</div>
								<span class="blueprint-glass" aria-hidden="true"></span>
							</div>
							<figcaption id="hero-blueprint-caption" class="blueprint-caption">
								<span><i aria-hidden="true"></i> One local workspace</span>
								<span>50 files in · one polished PDF out</span>
							</figcaption>
						</figure>
					</div>
					<ul class="kanji-rail" aria-hidden="true">
						<li><span class="kj">折</span><span class="gl">ori · fold</span></li>
						<li><span class="kj">鶴</span><span class="gl">tsuru · crane</span></li>
						<li><span class="kj">間</span><span class="gl">ma · interval</span></li>
						<li><span class="kj">朱</span><span class="gl">shu · vermilion</span></li>
					</ul>
					<a class="scroll-cue" href="#gather" aria-label="Scroll to content"><span></span></a>
				</div>
			</section>

			<!-- The window — one real product frame before the story starts -->
			<section class="window-peek" aria-label="The Orifold workspace">
				<div class="wrap">
					<figure class="shot" data-reveal>
						<div class="frame">
							<img src={cap('the-orifold-window-annotated.png')} width="1600" height="1000" loading="lazy" decoding="async" alt="The Orifold workspace: a document sidebar on the left, a PDF open on the canvas, a floating markup toolbar across the top, and the paper companion resting in the corner." />
						</div>
						<figcaption class="tabnum">Real capture — Orifold v{rel.version}. Sidebar, canvas, markup toolbar — and a paper companion keeping an eye on things.</figcaption>
					</figure>
				</div>
			</section>

			<!-- The promise — the second supplied SVG becomes a quiet, full-width
			     product manifesto between the opening proof and the workflow story. -->
			<section class="promise-stage snap-stage" aria-labelledby="promise-title">
				<div class="wrap">
					<div class="promise-copy" data-reveal>
						<p class="kicker">The quiet promise</p>
						<h2 id="promise-title">Your document stays yours.</h2>
