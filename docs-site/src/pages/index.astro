					</div>
				</div>
			</section>
		</main>

		<footer class="landing-footer">
			<div class="wrap">
				<p class="row">
					<strong>Folded by hand. Apache 2.0 licensed.</strong>
					<span class="palette" aria-hidden="true">
						<span title="Washi #F6F3EA" style="background:#f6f3ea"></span>
						<span title="Ink #1E1C17" style="background:#1e1c17"></span>
						<span title="Ai indigo #2B4566" style="background:#2b4566"></span>
						<span title="Ice #75BFD4" style="background:#75bfd4"></span>
						<span title="Tancho #C13A2A — the one reserved red" style="background:#c13a2a"></span>
					</span>
				</p>
