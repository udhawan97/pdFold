					Since nothing you do in Orifold ever leaves your Mac, stars are the only telemetry we
					get. ⭐
				</p>
			</div>
		</footer>

		<script is:inline>
			(function () {
				var d = document.documentElement;
				var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				var body = document.body;

				// ── theme toggle (light ⇄ dark) ────────────────────────────
				// The initial theme was already resolved pre-paint in <head>; this only
				// wires the nav toggle and persists changes to the shared 'starlight-theme'
				// key (so the choice carries into the Starlight docs too). Picking a theme
				// also retires the first-visit note — a choice has been made.
				var themeToggle = document.querySelector('.theme-toggle');
				function syncToggle(theme) {
					if (!themeToggle) return;
					var toDark = theme !== 'dark';
					var label = toDark ? 'Switch to dark mode' : 'Switch to light mode';
					themeToggle.setAttribute('aria-label', label);
					themeToggle.setAttribute('title', label);
					themeToggle.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
				}
				function setTheme(theme) {
					d.dataset.theme = theme;
					try { localStorage.setItem('starlight-theme', theme); } catch (e) {}
					d.classList.remove('theme-unchosen');
					syncToggle(theme);
				}
				syncToggle(d.dataset.theme === 'dark' ? 'dark' : 'light');
				if (themeToggle) {
					themeToggle.addEventListener('click', function () {
						setTheme(d.dataset.theme === 'dark' ? 'light' : 'dark');
					});
				}
				// Dismissing the note (without picking a theme) also hides it for good.
				var noteDismiss = document.querySelector('.theme-note-dismiss');
				if (noteDismiss) {
					noteDismiss.addEventListener('click', function () {
						try { localStorage.setItem('orifold-theme-note', 'dismissed'); } catch (e) {}
						d.classList.remove('theme-unchosen');
					});
				}

				// ── reveal observer ──────────────────────────────────────────
				var revealed = document.querySelectorAll('[data-reveal]');
				if ('IntersectionObserver' in window && !reduce) {
					var revIO = new IntersectionObserver(
						function (entries) {
							entries.forEach(function (e) {
								if (e.isIntersecting) {
									e.target.classList.add('in');
									revIO.unobserve(e.target);
								}
							});
						},
						{ threshold: 0.14 }
					);
					revealed.forEach(function (el) { revIO.observe(el); });
				} else {
					revealed.forEach(function (el) { el.classList.add('in'); });
				}

				// ── final fold: restart the real crane sequence on arrival ─────
				// The SVG uses SMIL. Pause it while off-screen so the visitor sees the
				// complete sheet → crane → app-icon fold, then replay it if they return.
				var finalFlight = document.getElementById('final-flight');
				var finalFlightSvg = finalFlight && finalFlight.querySelector('svg');
				if (finalFlight && finalFlightSvg && finalFlightSvg.pauseAnimations) {
					try { finalFlightSvg.pauseAnimations(); } catch (e) {}
					if (!reduce && 'IntersectionObserver' in window) {
						var flightIO = new IntersectionObserver(function (entries) {
							entries.forEach(function (entry) {
								if (entry.isIntersecting) {
									finalFlight.classList.add('flight-active');
									try {
										finalFlightSvg.setCurrentTime(0);
										finalFlightSvg.unpauseAnimations();
									} catch (e) {}
								} else {
									finalFlight.classList.remove('flight-active');
									try { finalFlightSvg.pauseAnimations(); } catch (e) {}
								}
							});
						}, { threshold: 0.35 });
						flightIO.observe(finalFlight);
					}
				}

				// ── route-progress thread — drawn by the reader, not a timer ──
				var thread = document.querySelector('.route-progress');
				var threadRaf = 0;
				function drawThread() {
					threadRaf = 0;
					if (!thread) return;
					var doc = document.documentElement;
					var max = doc.scrollHeight - doc.clientHeight;
					thread.style.transform = 'scaleX(' + (max > 0 ? doc.scrollTop / max : 0) + ')';
				}
				addEventListener('scroll', function () { if (!threadRaf) threadRaf = requestAnimationFrame(drawThread); }, { passive: true });
				drawThread();

				// ── pet controller: pets play while on screen, pause off-screen ─
				function petSvg(el) { return el.querySelector('.pet-anim svg') || el.querySelector('.guide-fig svg'); }
				// Pause every pet's SMIL on load (they carry begin="0s" repeatCount="indefinite",
				// which only JS can stop). We then unpause a pet only while it's on screen and
				// re-pause it when it leaves — so at most the visible pets ever animate, and
				// reduced-motion visitors (who see the static poster instead) never trigger a play.
				document.querySelectorAll('.pet-anim svg, .guide-fig svg').forEach(function (svg) {
					if (svg.pauseAnimations) { try { svg.pauseAnimations(); } catch (e) {} }
				});
				if ('IntersectionObserver' in window) {
					var petIO = new IntersectionObserver(
						function (entries) {
							entries.forEach(function (e) {
								var svg = petSvg(e.target);
								if (e.isIntersecting) {
									e.target.classList.add('pet-arrived');
									if (!reduce && svg && svg.unpauseAnimations) { try { svg.unpauseAnimations(); } catch (er) {} }
								} else if (svg && svg.pauseAnimations) {
									try { svg.pauseAnimations(); } catch (er) {}
								}
							});
						},
						{ threshold: 0.4 }
					);
					document.querySelectorAll('.pet, .guide, .ff-pet').forEach(function (p) { petIO.observe(p); });
				} else {
					document.querySelectorAll('.pet, .guide, .ff-pet').forEach(function (p) { p.classList.add('pet-arrived'); });
				}

				// ── Gami→Ori handoff tint (with hysteresis) ──────────────────
				var handoff = document.querySelector('.pet[data-handoff]');
				if (handoff && 'IntersectionObserver' in window) {
					var flipped = false;
					var hoIO = new IntersectionObserver(
						function (entries) {
							entries.forEach(function (e) {
								if (e.isIntersecting && !flipped) { body.dataset.guide = 'ori'; flipped = true; }
								else if (!e.isIntersecting && flipped && e.boundingClientRect.top > 0) {
									body.dataset.guide = 'gami'; flipped = false;
								}
							});
						},
						{ rootMargin: '-45% 0px -45%' }
					);
					hoIO.observe(handoff);
				}

				// ── nav: scroll-linked active-section state ───────────────────
				if ('IntersectionObserver' in window) {
					var navLinks = {};
					document.querySelectorAll('.nav .links a[href^="#"]').forEach(function (a) {
						navLinks[a.getAttribute('href').slice(1)] = a;
					});
					var navSections = Object.keys(navLinks)
						.map(function (id) { return document.getElementById(id); })
						.filter(Boolean);
					if (navSections.length) {
						var navIO = new IntersectionObserver(
							function (entries) {
								entries.forEach(function (e) {
									var link = navLinks[e.target.id];
									if (!link) return;
									if (e.isIntersecting) {
										Object.keys(navLinks).forEach(function (id) {
											navLinks[id].classList.remove('is-active');
											navLinks[id].removeAttribute('aria-current');
										});
										link.classList.add('is-active');
										link.setAttribute('aria-current', 'true');
									}
								});
							},
							{ rootMargin: '-45% 0px -50%' }
						);
						navSections.forEach(function (s) { navIO.observe(s); });
					}
				}

				// ── copy buttons ─────────────────────────────────────────────
				// Only claim success once navigator.clipboard.writeText actually resolves —
				// it can be unavailable (non-secure origin, restrictive Permissions-Policy,
				// older WebKit) or reject (document not focused), and a fire-and-forget call
				// would show "Copied" either way, leaving the user with nothing on their
				// clipboard.
				document.querySelectorAll('.copy-btn').forEach(function (btn) {
					var icon = btn.querySelector('.btn-ico');
					var label = btn.querySelector('.copy-btn-label');
					var originalIcon = icon ? icon.outerHTML : '';
					var originalLabel = label ? label.textContent : 'Copy';
					var revert = function () {
						setTimeout(function () {
							if (icon) icon.outerHTML = originalIcon;
							icon = btn.querySelector('.btn-ico');
							if (label) label.textContent = originalLabel;
						}, 1400);
					};
					var showCopied = function () {
						if (icon) icon.outerHTML = '<svg class="btn-ico" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 10.5 8 14l7.5-8.5"/></svg>';
						icon = btn.querySelector('.btn-ico');
						if (label) label.textContent = 'Copied';
						revert();
					};
					var showFailed = function () {
						if (label) label.textContent = 'Copy failed';
						revert();
					};
					btn.addEventListener('click', function () {
						var txt = btn.getAttribute('data-copy');
						if (navigator.clipboard && navigator.clipboard.writeText) {
							navigator.clipboard.writeText(txt).then(showCopied, showFailed);
						} else {
							showFailed();
						}
					});
				});

				// ── release enhancer: confirm-or-upgrade only ─────────────────
				var repo = body.dataset.repo;
				if (repo && 'fetch' in window) {
					fetch('https://api.github.com/repos/' + repo + '/releases/latest', {
						headers: { Accept: 'application/vnd.github+json' },
					})
						.then(function (r) { return r.ok ? r.json() : null; })
						.catch(function () { return null; })
						.then(function (data) {
							if (!data || !data.tag_name) return;
							var v = data.tag_name.replace(/^release-/, '').replace(/^v/, '');
							var dmgAsset = body.dataset.dmgAsset || 'Orifold.dmg';
							var dmg = (data.assets || []).filter(function (a) { return a.name === dmgAsset; })[0];
							document.querySelectorAll('.btn-sub').forEach(function (el) {
								el.textContent = el.textContent.replace(/v[0-9][^\s·]*/, 'v' + v);
							});
							var kindLabel = document.getElementById('asset-kind-label');
							if (kindLabel) kindLabel.textContent = kindLabel.textContent.replace(/v[0-9][^\s·]*/, 'v' + v);
							if (dmg && !d.classList.contains('not-mac')) {
								document.querySelectorAll('#cta-hero, #cta-final').forEach(function (a) {
									a.setAttribute('href', dmg.browser_download_url);
								});
								if (kindLabel) kindLabel.textContent = kindLabel.textContent.replace(/^\.[a-z0-9]+/i, '.dmg');
								var sizeLabel = document.getElementById('asset-size-label');
								var mb = dmg.size ? (dmg.size / (1024 * 1024)).toFixed(1) + ' MB' : null;
								if (mb) {
									if (sizeLabel) {
										// The size lives in its own icon badge, so no leading "·".
										sizeLabel.textContent = mb;
									} else if (kindLabel && kindLabel.parentNode) {
										// Build a matching size badge and slot it after the kind badge
										// (kindLabel's parent is the .badge wrapping it).
										var sizeBadge = document.createElement('span');
										sizeBadge.className = 'badge';
										sizeBadge.innerHTML = '<span class="badge-ico"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.2" y="6.4" width="13.6" height="7.2" rx="2.2"/><path d="M6 10h3.4"/><circle cx="13.2" cy="10" r="1"/></svg></span><span id="asset-size-label"></span>';
										sizeBadge.querySelector('#asset-size-label').textContent = mb;
										kindLabel.parentNode.insertAdjacentElement('afterend', sizeBadge);
									}
									// The hero/final CTA .btn-sub is baked in at build time as
									// "macOS 14+ · vX.Y.Z[ · N MB]" — the size segment is only
									// present if the build-time release lookup had a dmg size.
									// Backfill it once here if it's missing.
									document.querySelectorAll('.btn-sub').forEach(function (el) {
										if (el.textContent.indexOf(' MB') === -1) el.textContent += ' · ' + mb;
									});
								}
							}
						});
				}

				// ── non-Mac CTA swap (detection ran pre-paint in <head>) ─────
				if (d.classList.contains('not-mac')) {
					document.querySelectorAll('#cta-hero, #cta-final').forEach(function (a) {
						a.setAttribute('href', body.dataset.repoUrl || a.href);
						var main = a.querySelector('.btn-main');
						var sub = a.querySelector('.btn-sub');
						if (main) main.textContent = 'View on GitHub';
						if (sub) sub.textContent = 'Orifold is a Mac app';
					});
				}
			})();
		</script>

		<script is:inline>
			// ── flair layer: nav shadow, hero parallax, cursor-lit panel, magnetic
			// CTAs, and stat count-ups — the buttery, scroll-driven feel of a premium
			// product page. All of it is transform/opacity only and every branch is
			// gated on reduced motion (below the nav-shadow, which is harmless) so a
			// reduced-motion visitor gets a completely still page.
			(function () {
				var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

				// nav hairline appears once you leave the very top
				var nav = document.querySelector('.nav');
				var onScroll = function () { if (nav) nav.classList.toggle('scrolled', window.scrollY > 8); };
				addEventListener('scroll', onScroll, { passive: true });
				onScroll();

				var fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

				// count-up stats when they enter view (runs even under reduced motion,
				// but instantly — no animation, just the final number).
				if ('IntersectionObserver' in window) {
					var counters = document.querySelectorAll('[data-count]');
					var cIO = new IntersectionObserver(function (entries) {
						entries.forEach(function (en) {
							if (!en.isIntersecting) return;
							cIO.unobserve(en.target);
							var el = en.target;
							var target = parseInt(el.getAttribute('data-count'), 10);
							if (isNaN(target)) return;
							if (reduce) { el.textContent = String(target); return; }
							var dur = 1100, t0 = null;
							var step = function (ts) {
								if (t0 === null) t0 = ts;
								var p = Math.min((ts - t0) / dur, 1);
								var eased = 1 - Math.pow(1 - p, 3);
								el.textContent = String(Math.round(eased * target));
								if (p < 1) requestAnimationFrame(step);
								else el.textContent = String(target);
							};
							requestAnimationFrame(step);
						});
					}, { threshold: 0.6 });
					counters.forEach(function (el) {
						if (!reduce) el.textContent = '0';
						cIO.observe(el);
					});
				}

				if (reduce) return;

				// hero parallax — the blueprint panel drifts slower than the page
				var crane = document.getElementById('hero-crane');
				var pRaf = 0;
				var parallax = function () {
					pRaf = 0;
					if (!crane) return;
					var y = window.scrollY;
					if (y < 1000) crane.style.setProperty('--py', (y * -0.05).toFixed(1) + 'px');
				};
				addEventListener('scroll', function () { if (!pRaf) pRaf = requestAnimationFrame(parallax); }, { passive: true });
				parallax();

				// cursor-lit wash on the panel (fine pointers only) — write two CSS
				// custom props as %; the rect is cached on enter/resize so no per-move reflow.
				if (crane && fine) {
					var rect = null, gRaf = 0, cx = 0, cy = 0;
					var measure = function () { rect = crane.getBoundingClientRect(); };
					crane.addEventListener('pointerenter', measure);
					crane.addEventListener('pointermove', function (e) {
						cx = e.clientX; cy = e.clientY;
						if (!gRaf) gRaf = requestAnimationFrame(function () {
							gRaf = 0;
							if (!rect || !rect.width) return;
							crane.style.setProperty('--gx', ((cx - rect.left) / rect.width * 100).toFixed(1) + '%');
							crane.style.setProperty('--gy', ((cy - rect.top) / rect.height * 100).toFixed(1) + '%');
						});
					});
					addEventListener('resize', function () { if (rect) measure(); }, { passive: true });
					addEventListener('scroll', function () { if (rect) measure(); }, { passive: true });
				}

				// magnetic CTAs — the primary buttons lean toward the cursor, then release
				if (fine) {
					document.querySelectorAll('.btn-primary').forEach(function (btn) {
						var r = null;
						btn.addEventListener('pointerenter', function () { r = btn.getBoundingClientRect(); });
						btn.addEventListener('pointermove', function (e) {
							if (!r) r = btn.getBoundingClientRect();
							var mx = (e.clientX - (r.left + r.width / 2)) / r.width;
							var my = (e.clientY - (r.top + r.height / 2)) / r.height;
							btn.style.transform = 'translate(' + (mx * 8).toFixed(1) + 'px,' + (my * 8 - 2).toFixed(1) + 'px)';
						});
						btn.addEventListener('pointerleave', function () { btn.style.transform = ''; });
					});
				}
			})();
		</script>

		<script is:inline>
			// ── paper fortune spotlight: a witty on-brand one-liner, promoted to its
			// own closing stage. Progressive: the SSR line is already a real joke, so
			// no-JS and pre-hydration visitors see something real. On load we swap in a
			// random line; the Refold button shuffles to a different one, never repeating
			// back-to-back; and while the section is on screen we gently auto-refold.
			// Each refold toggles .is-refolded on the section to re-fire the finite
			// one-shot pop (the global reduced-motion rule neutralizes it). We skip the
			// auto-cycle entirely under reduced motion, when the tab is hidden, when the
			// section is off screen, or while it holds focus — so it never interrupts a
			// keyboard/screen-reader visitor mid-interaction or spams the aria-live line.
			(function () {
				var section = document.getElementById('fortune-fold');
				if (!section) return;
				var line = document.getElementById('fortune-line');
				var refold = document.getElementById('fortune-refold');
				if (!line || !refold) return;
				var lines = [
					'One sheet, folded with stubborn optimism.',
					'The cloud was not consulted. It never is.',
					'Nothing on this page phoned home — not even this joke.',
					"Your files never left your Mac. You're welcome.",
					"Somewhere, a subscription is confused about why you're smiling.",
					"Fold responsibly — cranes don't grow back.",
					'No trackers, no cookies. We fold our own snacks.',
					'PDFs are Pretty Difficult, Frankly. We disagree — politely.',
					"This card folded itself. It's quietly proud.",
					'A crane a day keeps the file room away.',
					'Made of one sheet, two paper pets, and zero telemetry.',
				];
				var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				// Seed "last" with the SSR line so the first random pick won't repeat it.
				var last = lines.indexOf(line.textContent.trim());
				function pick() {
					if (lines.length < 2) return 0;
					var i = Math.floor(Math.random() * lines.length);
					if (i === last) i = (i + 1) % lines.length;
					last = i;
					return i;
				}
				function refoldTo(animate) {
					line.textContent = lines[pick()];
					if (animate && !reduce) {
						section.classList.remove('is-refolded');
						void section.offsetWidth; // reflow so the one-shot pop restarts
						section.classList.add('is-refolded');
					}
				}
				// Fresh line on every load (no animation — it's the initial paint).
				refoldTo(false);
				refold.addEventListener('click', function () { refoldTo(true); });

				// Gentle auto-refold, but only while it can be seen and won't disturb anyone.
				if (!reduce) {
					var onScreen = false;
					if ('IntersectionObserver' in window) {
						new IntersectionObserver(function (entries) {
							onScreen = entries[0].isIntersecting;
						}, { threshold: 0.5 }).observe(section);
					}
					setInterval(function () {
						if (document.hidden || !onScreen) return;
						if (section.contains(document.activeElement)) return;
						refoldTo(true);
					}, 8500);
				}
			})();
		</script>
	</body>
</html>
