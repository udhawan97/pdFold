    "error.export.structurallyUnsound": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold wrote the PDF but a structural check found it invalid, so the export was discarded. Try exporting again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold escribió el PDF, pero una verificación estructural lo encontró inválido, por lo que se descartó la exportación. Intenta exportar de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold a écrit le PDF, mais une vérification structurelle l'a jugé invalide ; l'exportation a donc été annulée. Réessayez d'exporter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold ने PDF लिखा, लेकिन संरचनात्मक जांच में यह अमान्य पाया गया, इसलिए निर्यात रद्द कर दिया गया। फिर से निर्यात करने का प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OrifoldはPDFを書き出しましたが、構造チェックで無効と判定されたため、書き出しは破棄されました。もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 已写入 PDF，但结构检查发现其无效，因此该导出已被丢弃。请重新尝试导出。"
          }
        }
      }
    },
    "error.export.unsupportedPDFStructure": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold can't safely sign this PDF yet — its internal structure (a modern cross-reference stream) isn't one Orifold's signer supports. Try exporting/flattening it in Orifold first, then signing the result."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold aún no puede firmar este PDF de forma segura: su estructura interna (un flujo de referencia cruzada moderno) no es compatible con el firmante de Orifold. Intenta exportarlo o aplanarlo primero en Orifold y luego firma el resultado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold ne peut pas encore signer ce PDF en toute sécurité : sa structure interne (un flux de références croisées moderne) n'est pas prise en charge par le signataire d'Orifold. Essayez de l'exporter/l'aplatir d'abord dans Orifold, puis signez le résultat."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold अभी इस PDF पर सुरक्षित रूप से हस्ताक्षर नहीं कर सकता — इसकी आंतरिक संरचना (एक आधुनिक क्रॉस-रेफ़रेंस स्ट्रीम) Orifold के हस्ताक्षरकर्ता द्वारा समर्थित नहीं है। पहले इसे Orifold में निर्यात/फ़्लैटन करने का प्रयास करें, फिर परिणाम पर हस्ताक्षर करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはこのファイルの内部構造（最新のクロスリファレンスストリーム）に対応していないため、安全に署名できません。まずOrifoldでエクスポート/フラット化してから、その結果に署名してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 目前无法安全地签署此 PDF——其内部结构（现代交叉引用流）尚不受 Orifold 签名器支持。请先在 Orifold 中导出/展平该文件，然后再对结果进行签署。"
          }
        }
      }
    },
    "error.export.verifyReducedPDFFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not verify the reduced PDF. Try exporting without reducing file size."
          }
        },
        "es": {
