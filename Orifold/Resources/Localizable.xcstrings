    "pet.event.addFile.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tip: drag pages between files to reshuffle them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consejo: arrastra páginas entre archivos para reorganizarlas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Astuce : faites glisser des pages entre les fichiers pour les réorganiser."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सुझाव: फ़ाइलों के बीच पेज खींचकर उन्हें फिर से व्यवस्थित करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ヒント：ページをファイル間でドラッグすると並べ替えられます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提示：在文件之间拖动页面即可重新排列。"
          }
        }
      }
    },
    "pet.event.comment.1": {
