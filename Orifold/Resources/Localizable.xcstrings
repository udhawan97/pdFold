    "documentComfort.reduceGlare.info": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Softens harsh bright areas so white pages feel gentler on the eyes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Suaviza las zonas muy brillantes para que las páginas blancas sean más suaves para la vista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Adoucit les zones très lumineuses pour que les pages blanches soient plus douces pour les yeux."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "तेज़ चमकदार हिस्सों को नरम करता है ताकि सफ़ेद पेज आँखों को कम चुभें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "強い明るさを和らげ、白いページが目に優しく感じられるようにします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "柔化过亮区域，让白色页面对眼睛更友好。"
          }
        }
      }
    },
