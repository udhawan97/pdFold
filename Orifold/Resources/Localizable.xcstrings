    "settings.updates.automatic.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold checks GitHub for a newer version about once a day. Nothing about you or your files is ever sent."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold consulta GitHub en busca de una versión más reciente aproximadamente una vez al día. Nunca se envía nada sobre ti ni sobre tus archivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold vérifie sur GitHub s’il existe une version plus récente environ une fois par jour. Rien vous concernant ni concernant vos fichiers n’est jamais envoyé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold लगभग दिन में एक बार GitHub पर नए संस्करण की जाँच करता है। आपके या आपकी फ़ाइलों के बारे में कुछ भी कभी नहीं भेजा जाता।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 大约每天一次向 GitHub 查询是否有新版本。绝不会发送任何关于你或你文件的信息。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold は 1 日に 1 回ほど GitHub で新しいバージョンを確認します。あなたやファイルに関する情報が送信されることはありません。"
          }
        }
      }
    },
