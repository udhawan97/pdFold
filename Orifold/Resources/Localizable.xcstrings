        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold ж— жі•жё…зҗҶжӯӨ PDFгҖӮиҜ·еңЁеҜјеҮәж—¶е…ій—ӯвҖңжё…зҗҶеҗҺеҶҚеҲҶдә«вҖқпјҢжҲ–йҮҚиҜ•гҖӮ"
