    "emptyState.folderAccessHint.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choosing a folder asks macOS for access to that folder only. Prefer Choose Files to grant access one file at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elegir una carpeta solicita a macOS acceso solo a esa carpeta. Prefiere Elegir archivos para conceder acceso de uno en uno."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisir un dossier demande à macOS l'accès à ce dossier uniquement. Préférez Choisir des fichiers pour accorder l'accès un par un."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ोल्डर चुनने पर macOS केवल उस फ़ोल्डर तक पहुँच माँगता है। एक-एक करके पहुँच देने के लिए फ़ाइलें चुनें को प्राथमिकता दें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フォルダを選択すると、macOSはそのフォルダのみへのアクセスを求めます。1つずつアクセスを許可するには「ファイルを選択」をお勧めします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择文件夹只会向 macOS 请求该文件夹的访问权限。若想逐个文件授权，建议使用“选择文件”。"
          }
        }
      }
    },
    "emptyState.headline": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
