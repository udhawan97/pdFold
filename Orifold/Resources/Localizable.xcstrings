    "documentComfort.warmth.info": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adds a warm, amber tint to reduce blue light in low light."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade un tono cálido ámbar para reducir la luz azul en ambientes con poca luz."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute une teinte chaude ambrée pour réduire la lumière bleue en faible luminosité."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कम रोशनी में नीली रोशनी घटाने के लिए गर्म, एम्बर टिंट जोड़ता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "暖色系（アンバー）の色味を加え、暗い場所でのブルーライトを軽減します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加温暖的琥珀色调，在弱光环境下减少蓝光。"
          }
        }
      }
    },
