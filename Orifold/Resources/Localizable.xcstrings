    "pet.event.tag.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tagged. Organized people are just tidy worriers with labels."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Etiquetado. Las personas organizadas solo son personas ansiosas con etiquetas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Étiqueté. Les gens organisés sont juste des inquiets méticuleux avec des étiquettes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टैग कर दिया। व्यवस्थित लोग बस लेबल वाले करीने से परेशान होने वाले लोग हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タグを付けましたね。整理好きな人は、ラベル好きな心配性なだけ。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打上标签了。爱整理的人不过是贴着标签的操心人。"
          }
        }
      }
    },
    "pet.event.tag.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tip: reuse tags and your filters will thank you."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
