    "guideFeature.editText.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjust detected PDF text or add new text boxes directly on the page."
          }
        },
        "es": {
