            "value": "署名を配置してから、「署名してエクスポート」で完了してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "放置签名，然后使用“签名并导出”完成。"
          }
        }
      }
    },
    "signaturePalette.digital.reason.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional. Why you're signing this document (e.g. “Approval”)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Opcional. Por qué firmas este documento (p. ej. “Aprobación”)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Facultatif. Pourquoi vous signez ce document (par ex. « Approbation »)."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वैकल्पिक। आप इस दस्तावेज़ पर हस्ताक्षर क्यों कर रहे हैं (जैसे “स्वीकृति”)।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "任意。この文書に署名する理由（例：「承認」）。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选。您签署此文档的原因（例如“批准”）。"
          }
