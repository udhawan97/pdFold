    "petBuddy.welcome.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start with Choose Files or drop up to 50 files. Once a document is open, I will keep tips brief and stay out of the way."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza con Elegir archivos o suelta hasta 50 archivos. Una vez que abras un documento, mantendré los consejos breves y no molestaré."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez par Choisir des fichiers ou déposez jusqu'à 50 fichiers. Une fois un document ouvert, je garderai mes conseils brefs et je resterai discret."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइलें चुनें से शुरू करें या 50 तक फ़ाइलें छोड़ें। दस्तावेज़ खुलने के बाद, मैं सुझाव संक्षिप्त रखूँगा और आड़े नहीं आऊँगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「ファイルを選択」から始めるか、最大50個のファイルをドロップしてください。ドキュメントを開いたら、ヒントは手短にして邪魔をしないようにします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从“选择文件”开始，或拖入最多 50 个文件。文档打开后，我会保持提示简短，尽量不打扰你。"
          }
        }
      }
    },
