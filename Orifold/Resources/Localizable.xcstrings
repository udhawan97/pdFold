    "petPicker.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Two companions, one sheet of paper — together, they make Origami. You can switch anytime."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dos compañeros, una sola hoja de papel — juntos hacen Origami. Puedes cambiar cuando quieras."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Deux compagnons, une seule feuille de papier — ensemble, ils font Origami. Vous pouvez changer à tout moment."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दो साथी, एक ही कागज़ की शीट — मिलकर वे बनाते हैं Origami। आप कभी भी बदल सकते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "二匹の相棒、一枚の紙——合わせて Origami。いつでも切り替えられます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "两个伙伴，同一张纸——合起来就是 Origami。你可以随时切换。"
          }
        }
      }
    },
