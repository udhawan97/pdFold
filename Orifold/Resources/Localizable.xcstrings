    "pet.event.comment.3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tip: tag a comment now and you'll find it in seconds later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consejo: etiqueta un comentario ahora y lo encontrarás en segundos después."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Astuce : étiquetez un commentaire maintenant, vous le retrouverez en quelques secondes."
          }
        },
        "hi": {
