    "status.sign.timestampUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Timestamp authority unavailable; exported as PAdES B-B without trusted timestamp."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Autoridad de sellado de tiempo no disponible; exportado como PAdES B-B sin sello de tiempo confiable."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorité d'horodatage indisponible ; exporté en PAdES B-B sans horodatage de confiance."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टाइमस्टैम्प प्राधिकरण अनुपलब्ध; विश्वसनीय टाइमस्टैम्प के बिना PAdES B-B के रूप में निर्यात किया गया।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タイムスタンプ局が利用できないため、信頼できるタイムスタンプなしのPAdES B-Bとして書き出しました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "时间戳授权机构不可用；已导出为不含可信时间戳的 PAdES B-B。"
          }
        }
      }
    },
