    "documentComfort.contrast.info": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Makes text lighter or bolder against the page for easier reading."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hace que el texto sea más claro o más marcado sobre la página para facilitar la lectura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rend le texte plus clair ou plus marqué sur la page pour faciliter la lecture."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पढ़ने में आसानी के लिए पेज पर टेक्स्ट को हल्का या गाढ़ा बनाता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "読みやすくするため、ページ上のテキストを薄くしたり濃くしたりします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让文字相对页面更浅或更粗，方便阅读。"
          }
        }
      }
    },
    "documentComfort.contrast.title": {
