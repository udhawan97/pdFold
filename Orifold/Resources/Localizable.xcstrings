        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この書類でテキストの検索と選択ができるようになりました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "现在可以在此文档中搜索和选择文本了。"
          }
