    "status.readerMode.blockedEditText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reader Mode keeps the document text locked. Turn it off to edit PDF text."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo lectura mantiene bloqueado el texto del documento. Desactívalo para editar el texto del PDF."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le mode lecture garde le texte du document verrouillé. Désactivez-le pour modifier le texte du PDF."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रीडर मोड दस्तावेज़ के टेक्स्ट को लॉक रखता है। PDF टेक्स्ट संपादित करने के लिए इसे बंद करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
