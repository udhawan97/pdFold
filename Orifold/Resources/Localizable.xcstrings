    "pet.event.export.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tip: flatten before sharing so annotations stick."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consejo: aplana el documento antes de compartirlo para que las anotaciones se mantengan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Astuce : aplatissez avant de partager pour que les annotations restent en place."
          }
