          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法为此 PDF 应用装饰。请添加文字，或关闭该装饰。"
          }
        }
      }
    },
    "error.decoration.invalidPDF": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
