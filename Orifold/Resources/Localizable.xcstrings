        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择文件，我会帮你把 PDF 相关的琐事处理妥当。"
          }
        }
      }
    },
    "emptyState.pill.accessibilityHint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use Choose Files to continue."
          }
        },
        "es": {
          "stringUnit": {
