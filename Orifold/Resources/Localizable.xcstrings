          "stringUnit": {
            "state": "translated",
            "value": "タグを付けましたね。整理好きな人は、ラベル好きな心配性なだけ。"
          }
        }
      }
    },
    "pet.event.tag.2": {
      "extractionState": "manual",
      "localizations": {
