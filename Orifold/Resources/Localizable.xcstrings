    "contentView.importBatchPanel.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select up to 50 files. Larger batches can be added after this import finishes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona hasta 50 archivos. Puedes añadir más una vez que termine esta importación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez jusqu’à 50 fichiers. Vous pourrez en ajouter d’autres une fois cette importation terminée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "50 फ़ाइलों तक चुनें। बड़े बैच इस आयात के पूरा होने के बाद जोड़े जा सकते हैं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最多选择 50 个文件。此次导入完成后可再添加更多文件。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最大50個のファイルを選択してください。それ以上は今回の読み込み完了後に追加できます。"
          }
        }
      }
    },
    "contentView.importBatchLimit.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only 50 files can be added at a time. The first 50 from this selection will be added. To add more, run Add Files again after this import finishes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo se pueden añadir 50 archivos a la vez. Se añadirán los primeros 50 de esta selección. Para añadir más, vuelve a usar Añadir archivos cuando termine esta importación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "50 fichiers peuvent être ajoutés à la fois. Les 50 premiers de cette sélection seront ajoutés. Pour en ajouter d’autres, relancez Ajouter des fichiers une fois cette importation terminée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक बार में केवल 50 फ़ाइलें जोड़ी जा सकती हैं। इस चयन में से पहली 50 फ़ाइलें जोड़ी जाएंगी। और जोड़ने के लिए, यह आयात पूरा होने के बाद फिर से फ़ाइलें जोड़ें चलाएं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一次最多只能添加 50 个文件。系统将添加所选内容中的前 50 个。如需添加更多，请在此次导入完成后再次执行“添加文件”。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一度に追加できるのは50個までです。選択した項目のうち先頭の50個を追加します。残りは今回の読み込み完了後に「ファイルを追加」をもう一度実行してください。"
          }
        }
      }
    },
    "contentView.importDropProviderLimit.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold prepared 50 files from this drop. If you expected more, run another import after this one finishes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold preparó 50 archivos de este contenido. Si esperabas más, realiza otra importación cuando esta termine."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold a préparé 50 fichiers à partir de cet élément déposé. Si vous en attendiez davantage, lancez une nouvelle importation une fois celle-ci terminée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold ने इस ड्रॉप से 50 फ़ाइलें तैयार की हैं। अगर आपको और उम्मीद थी, तो यह पूरा होने के बाद एक और आयात चलाएं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 已从此次拖放中准备了 50 个文件。如果还有更多文件，请在此次导入完成后再次导入。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはドロップされた項目から50個のファイルを準備しました。まだ追加したいファイルがある場合は、この読み込みの完了後にもう一度実行してください。"
          }
        }
      }
    },
