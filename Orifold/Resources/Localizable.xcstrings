    },
    "signaturePalette.digital.timestamp.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Requests a free trusted timestamp over the internet so the signing time remains provable even if this certificate later expires. Only a fingerprint of the signature is sent — never your document."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicita por internet una marca de tiempo confiable gratuita para que la hora de firma siga siendo demostrable aunque este certificado caduque más adelante. Solo se envía una huella de la firma, nunca su documento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Demande via Internet un horodatage fiable gratuit afin que l'heure de signature reste prouvable même si ce certificat expire plus tard. Seule une empreinte de la signature est envoyée — jamais votre document."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इंटरनेट के माध्यम से एक निःशुल्क विश्वसनीय टाइमस्टैम्प का अनुरोध करता है ताकि यह प्रमाणपत्र बाद में समाप्त होने पर भी हस्ताक्षर का समय सिद्ध किया जा सके। केवल हस्ताक्षर का फ़िंगरप्रिंट भेजा जाता है — आपका दस्तावेज़ कभी नहीं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この証明書が後で失効しても署名時刻を証明できるよう、インターネット経由で無料の信頼できるタイムスタンプを要求します。送信されるのは署名のフィンガープリントのみで、文書自体は送信されません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过互联网请求一个免费的可信时间戳，这样即使此证书日后过期，签名时间仍可证明。仅发送签名的指纹，绝不发送您的文档。"
          }
        }
      }
    },
    "signaturePalette.digital.timestamp.toggle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Timestamp"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Marca de tiempo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Horodatage"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टाइमस्टैम्प"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タイムスタンプ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "时间戳"
          }
        }
      }
    },
    "signaturePalette.digital.tsaProvider.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Which free timestamp authority to ask first. If it's unreachable, Orifold automatically tries the others before falling back to an unstamped signature."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Qué autoridad de marca de tiempo gratuita consultar primero. Si no está disponible, Orifold prueba automáticamente con las demás antes de recurrir a una firma sin marca de tiempo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelle autorité d'horodatage gratuite interroger en premier. Si elle est injoignable, Orifold essaie automatiquement les autres avant de revenir à une signature sans horodatage."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहले किस मुफ़्त टाइमस्टैंप प्राधिकरण से संपर्क किया जाए। यदि यह अनुपलब्ध है, तो Orifold बिना टाइमस्टैंप वाले हस्ताक्षर पर वापस जाने से पहले स्वचालित रूप से अन्य को आज़माता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最初に問い合わせる無料タイムスタンプ局。到達できない場合、Orifoldはタイムスタンプなしの署名にフォールバックする前に自動的に他の局を試します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "首先请求的免费时间戳颁发机构。如果无法访问，Orifold 会在回退到无时间戳签名之前自动尝试其他机构。"
          }
        }
      }
    },
    "signaturePalette.digital.tsaProvider.picker": {
