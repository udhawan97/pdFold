        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वैकल्पिक। कोई प्राप्तकर्ता इस हस्ताक्षर के बारे में आपसे कैसे संपर्क कर सकता है।"
          }
        },
        "ja": {
