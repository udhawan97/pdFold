          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déposez jusqu’à 50 fichiers PDF, Word, HTML, Markdown, texte, données ou images à la fois."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक साथ 50 PDF, Word, HTML, Markdown, टेक्स्ट, डेटा फ़ाइलें या इमेज तक जोड़ें।"
          }
        },
        "zh-Hans": {
