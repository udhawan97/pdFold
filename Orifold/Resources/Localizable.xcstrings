    "petBuddy.welcome.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Foldy is here to help"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Foldy está aquí para ayudar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Foldy est là pour vous aider"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मदद के लिए Foldy यहाँ है"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Foldy 随时为你效劳"
          }
        },
        "ja": {
          "stringUnit": {
