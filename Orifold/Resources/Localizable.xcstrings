    "certificateSheet.createSelfSigned.notice": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Free, and generated once on this Mac. Signatures made with it are cryptographically valid and tamper-evident, but recipients will see “identity not verified” until they trust it once."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gratis, y generado una sola vez en este Mac. Las firmas hechas con él son criptográficamente válidas y a prueba de manipulaciones, pero los destinatarios verán “identidad no verificada” hasta que confíen en él una vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gratuit, généré une seule fois sur ce Mac. Les signatures réalisées avec celui-ci sont cryptographiquement valides et inviolables, mais les destinataires verront « identité non vérifiée » jusqu'à ce qu'ils lui fassent confiance une fois."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मुफ़्त, और इस Mac पर एक बार बनाया गया। इससे किए गए हस्ताक्षर क्रिप्टोग्राफ़िक रूप से मान्य और छेड़छाड़-रोधी होते हैं, लेकिन प्राप्तकर्ताओं को “पहचान असत्यापित” तब तक दिखेगा जब तक वे इस पर एक बार भरोसा नहीं करते।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無料で、このMac上で一度だけ生成されます。これで作成された署名は暗号学的に有効で改ざん検知可能ですが、受信者が一度信頼するまでは「本人確認されていません」と表示されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "免费，且仅在此 Mac 上生成一次。用它签署的签名在密码学上有效且可防篡改，但收件人在信任它之前会看到“身份未验证”。"
          }
        }
      }
    },
    "certificateSheet.createSelfSigned.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create a self-signed Digital ID"
          }
        },
        "es": {
