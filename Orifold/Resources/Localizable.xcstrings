    "signaturePalette.digital.place.help.ready": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Place the signature, then use “Sign & Export” to finish."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloca la firma y luego usa “Firmar y exportar” para terminar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Placez la signature, puis utilisez « Signer et exporter » pour terminer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हस्ताक्षर रखें, फिर समाप्त करने के लिए “साइन करें और निर्यात करें” का उपयोग करें।"
          }
        },
        "ja": {
          "stringUnit": {
