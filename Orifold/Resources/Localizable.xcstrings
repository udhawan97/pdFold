    "guideFeature.sign.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Place visual signatures or create cryptographically signed PDF output."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloca firmas visuales o crea un PDF con firma criptográfica."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Placez des signatures visuelles ou créez un PDF signé cryptographiquement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "विज़ुअल हस्ताक्षर लगाएं या क्रिप्टोग्राफ़िक रूप से हस्ताक्षरित PDF आउटपुट बनाएं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "視覚的な署名を配置するか、暗号化されたデジタル署名付きPDFを作成できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "放置视觉签名，或生成经过加密签名的 PDF 输出。"
          }
        }
      }
    },
