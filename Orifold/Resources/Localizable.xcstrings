      }
    },
    "certificateSheet.importPassword.wrongPassword": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That password didn't unlock this file. Passwords are case-sensitive — try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esa contraseña no desbloqueó este archivo. Las contraseñas distinguen mayúsculas y minúsculas: inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce mot de passe n'a pas déverrouillé ce fichier. Les mots de passe sont sensibles à la casse — réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उस पासवर्ड ने इस फ़ाइल को अनलॉक नहीं किया। पासवर्ड केस-सेंसिटिव होते हैं — फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのパスワードではこのファイルを解除できませんでした。パスワードは大文字小文字を区別します。もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该密码未能解锁此文件。密码区分大小写——请重试。"
          }
        }
      }
    },
    "certificateSheet.manage.checkTrust": {
      "extractionState": "manual",
      "localizations": {
        "en": {
