    "error.import.unsupportedFileType": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This file type is not supported yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este tipo de archivo aún no es compatible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce type de fichier n'est pas encore pris en charge."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह फ़ाइल प्रकार अभी समर्थित नहीं है।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂不支持此文件类型。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このファイル形式はまだサポートされていません。"
          }
        }
      }
    },
    "error.import.passwordProtected": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This PDF is password-protected. Add it to an open workspace with Add Files or drag-and-drop so Orifold can prompt for the password."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este PDF está protegido con contraseña. Agrégalo a un espacio de trabajo abierto con Agregar archivos o arrastrándolo, para que Orifold pueda solicitar la contraseña."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce PDF est protégé par un mot de passe. Ajoutez-le à un espace de travail ouvert via Ajouter des fichiers ou par glisser-déposer afin qu'Orifold puisse demander le mot de passe."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह PDF पासवर्ड-सुरक्षित है। इसे किसी खुले वर्कस्पेस में फ़ाइलें जोड़ें या खींचकर छोड़ें से जोड़ें, ताकि Orifold पासवर्ड माँग सके।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此 PDF 已设置密码保护。请通过“添加文件”或拖放将其加入已打开的工作区，以便 Orifold 提示输入密码。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このPDFはパスワードで保護されています。「ファイルを追加」またはドラッグ＆ドロップで開いているワークスペースに追加すると、Orifoldがパスワードの入力を求めます。"
          }
        }
      }
    },
    "error.import.unreadableDocument": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file could not be read. It may be corrupt, encrypted, or incomplete."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo leer el archivo. Puede estar dañado, cifrado o incompleto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier n'a pas pu être lu. Il est peut-être corrompu, chiffré ou incomplet."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल पढ़ी नहीं जा सकी। यह ख़राब, एन्क्रिप्टेड या अधूरी हो सकती है।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法读取该文件，它可能已损坏、已加密或不完整。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルを読み込めませんでした。破損、暗号化、または不完全な可能性があります。"
          }
        }
      }
    },
    "error.import.emptyDocument": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file is empty."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo está vacío."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier est vide."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल खाली है।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该文件为空。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルが空です。"
          }
        }
      }
    },
    "error.import.binaryDataMislabelledAsText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This looks like binary data, not a supported text document. Check the file type and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto parece ser datos binarios, no un documento de texto compatible. Verifica el tipo de archivo e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela ressemble à des données binaires, pas à un document texte pris en charge. Vérifiez le type de fichier et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह बाइनरी डेटा जैसा लगता है, समर्थित टेक्स्ट दस्तावेज़ नहीं। फ़ाइल प्रकार जाँचें और फिर से प्रयास करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这看起来是二进制数据，而非受支持的文本文档。请检查文件类型后重试。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これはサポートされているテキスト文書ではなく、バイナリデータのようです。ファイル形式を確認してもう一度お試しください。"
          }
        }
      }
    },
    "error.import.renderingFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file opened, but Orifold could not render it into a PDF."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo se abrió, pero Orifold no pudo convertirlo en un PDF."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier s'est ouvert, mais Orifold n'a pas pu le convertir en PDF."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल खुल गई, लेकिन Orifold इसे PDF में रेंडर नहीं कर सका।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文件已打开，但 Orifold 无法将其渲染为 PDF。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルは開けましたが、OrifoldがPDFに変換できませんでした。"
          }
        }
      }
    },
    "error.import.renderTimedOut": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file took too long to render. Try exporting it to PDF from its original app, then import the PDF."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo tardó demasiado en procesarse. Intenta exportarlo a PDF desde su aplicación original y luego importa el PDF."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier a mis trop de temps à s'afficher. Essayez de l'exporter en PDF depuis son application d'origine, puis importez le PDF."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल को रेंडर होने में बहुत समय लगा। इसे मूल ऐप से PDF में एक्सपोर्ट करने का प्रयास करें, फिर PDF आयात करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文件渲染耗时过长。请尝试先在原始应用中将其导出为 PDF，然后再导入该 PDF。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルのレンダリングに時間がかかりすぎました。元のアプリからPDFとして書き出してから、そのPDFを読み込んでください。"
          }
        }
      }
    },
    "error.editing.emptySelection": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not find editable text at that location."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo encontrar texto editable en esa ubicación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a trouvé aucun texte modifiable à cet emplacement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold को उस स्थान पर संपादन योग्य टेक्स्ट नहीं मिला।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 在该位置未找到可编辑文本。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "その位置に編集可能なテキストが見つかりませんでした。"
          }
        }
      }
    },
    "error.editing.invalidSelectionBounds": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That PDF text selection has invalid bounds, so Orifold added a normal text box instead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esa selección de texto del PDF tiene límites no válidos, por lo que Orifold agregó un cuadro de texto normal en su lugar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette sélection de texte du PDF a des limites non valides ; Orifold a donc ajouté une zone de texte normale à la place."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उस PDF टेक्स्ट चयन की सीमाएँ अमान्य हैं, इसलिए Orifold ने इसके बजाय एक सामान्य टेक्स्ट बॉक्स जोड़ा।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该 PDF 文本选区边界无效，因此 Orifold 改为添加了一个普通文本框。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのPDFテキスト選択範囲は無効なため、Orifoldは代わりに通常のテキストボックスを追加しました。"
          }
        }
      }
    },
    "error.editing.invalidAnnotationBounds": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That annotation has invalid geometry and could not be edited safely."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esa anotación tiene una geometría no válida y no pudo editarse de forma segura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette annotation a une géométrie non valide et n'a pas pu être modifiée en toute sécurité."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उस एनोटेशन की ज्यामिति अमान्य है और इसे सुरक्षित रूप से संपादित नहीं किया जा सका।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该注释的几何信息无效，无法安全编辑。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この注釈は形状が無効なため、安全に編集できませんでした。"
          }
        }
      }
    },
    "error.editing.annotationCreationFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not create an annotation on that page."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo crear una anotación en esa página."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu créer d'annotation sur cette page."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold उस पृष्ठ पर एनोटेशन नहीं बना सका।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法在该页面上创建注释。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはそのページに注釈を作成できませんでした。"
          }
        }
      }
    },
    "error.editing.unsupportedReplacement": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not safely replace that PDF text. A normal text box was added instead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo reemplazar ese texto del PDF de forma segura. En su lugar, se agregó un cuadro de texto normal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu remplacer ce texte du PDF en toute sécurité. Une zone de texte normale a été ajoutée à la place."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold उस PDF टेक्स्ट को सुरक्षित रूप से बदल नहीं सका। इसके बजाय एक सामान्य टेक्स्ट बॉक्स जोड़ा गया।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法安全替换该 PDF 文本，已改为添加普通文本框。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OrifoldはそのPDFテキストを安全に置き換えられなかったため、代わりに通常のテキストボックスを追加しました。"
          }
        }
      }
    },
    "error.editing.serializationFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not serialize the edited PDF. Your workspace remains open."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo serializar el PDF editado. Tu espacio de trabajo permanece abierto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu enregistrer le PDF modifié. Votre espace de travail reste ouvert."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold संपादित PDF को सीरियलाइज़ नहीं कर सका। आपका वर्कस्पेस खुला रहता है।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法序列化已编辑的 PDF。你的工作区仍保持打开状态。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは編集後のPDFを保存できませんでした。ワークスペースは開いたままです。"
          }
        }
      }
    },
    "error.editing.colorConversionFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not preserve the original text color, so it used the default document text color."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo conservar el color de texto original, por lo que usó el color de texto predeterminado del documento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu conserver la couleur de texte d'origine ; il a donc utilisé la couleur de texte par défaut du document."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold मूल टेक्स्ट रंग बनाए नहीं रख सका, इसलिए इसने दस्तावेज़ के डिफ़ॉल्ट टेक्स्ट रंग का उपयोग किया।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法保留原始文本颜色，因此使用了文档默认文本颜色。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは元のテキストカラーを維持できなかったため、文書の既定のテキストカラーを使用しました。"
          }
        }
      }
    },
    "error.editing.fontConversionFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not preserve the original font, so it used a system font."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo conservar la fuente original, por lo que usó una fuente del sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu conserver la police d'origine ; il a donc utilisé une police système."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold मूल फ़ॉन्ट बनाए नहीं रख सका, इसलिए इसने एक सिस्टम फ़ॉन्ट का उपयोग किया।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法保留原始字体，因此使用了系统字体。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは元のフォントを維持できなかったため、システムフォントを使用しました。"
          }
        }
      }
    },
    "error.signingIdentity.missingCertificate": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The identity did not include a certificate."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La identidad no incluía un certificado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'identité ne comportait pas de certificat."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहचान में कोई प्रमाणपत्र शामिल नहीं था।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该身份未包含证书。"
          }
