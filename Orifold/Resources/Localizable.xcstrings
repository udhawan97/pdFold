    "certificateSheet.delete.confirmMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes it from Orifold and your Keychain. PDFs you already signed with it remain validly signed — only future signing with this identity becomes unavailable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto lo elimina de Orifold y de tu llavero. Los PDF que ya firmaste con él siguen siendo válidos; solo dejará de estar disponible para firmar en el futuro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela le supprime d'Orifold et de votre Trousseau. Les PDF déjà signés avec celui-ci restent valablement signés — seule la signature future avec cette identité devient indisponible."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह इसे Orifold और आपकी कीचेन से हटा देता है। इससे पहले से हस्ताक्षरित PDF मान्य रूप से हस्ताक्षरित रहेंगे — केवल इस पहचान से भविष्य में हस्ताक्षर करना अनुपलब्ध हो जाएगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これによりOrifoldとキーチェーンから削除されます。すでにこれで署名されたPDFは引き続き有効な署名のままです。今後このIDで署名できなくなるだけです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会将其从 Orifold 和钥匙串中移除。已用它签署的 PDF 仍保持有效签名——只是今后无法再用此身份签名。"
          }
        }
      }
    },
    "certificateSheet.delete.confirmTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
