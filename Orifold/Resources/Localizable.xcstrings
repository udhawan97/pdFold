            "state": "translated",
            "value": "Devuelve todos los ajustes de comodidad de este panel a su valor predeterminado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ramène tous les réglages de confort de ce panneau à leur valeur par défaut."
          }
