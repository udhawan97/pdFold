    "status.signature.editInvalidates": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Editing after a digital signature invalidates existing signatures."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Editar después de una firma digital invalida las firmas existentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toute modification après une signature numérique invalide les signatures existantes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिजिटल हस्ताक्षर के बाद संपादन करने से मौजूदा हस्ताक्षर अमान्य हो जाते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デジタル署名の後に編集すると、既存の署名が無効になります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在数字签名之后进行编辑会使现有签名失效。"
          }
        }
      }
    },
    "status.signature.thirdPartyEditInvalidates": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This document already contains a digital signature from another source. Editing it will invalidate that signature."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este documento ya contiene una firma digital de otro origen. Editarlo invalidará esa firma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce document contient déjà une signature numérique provenant d’une autre source. Le modifier invalidera cette signature."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस दस्तावेज़ में पहले से ही किसी अन्य स्रोत का डिजिटल हस्ताक्षर मौजूद है। इसे संपादित करने से वह हस्ताक्षर अमान्य हो जाएगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この書類には既に他の作成元によるデジタル署名が含まれています。編集するとその署名が無効になります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此文档已包含来自其他来源的数字签名。编辑将使该签名失效。"
          }
        }
      }
    },
    "status.signature.timestampUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Timestamp authority unavailable; exported as PAdES B-B without trusted timestamp."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La autoridad de sellado de tiempo no está disponible; se exportó como PAdES B-B sin marca de tiempo verificada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorité d’horodatage indisponible ; exporté au format PAdES B-B sans horodatage de confiance."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टाइमस्टैम्प प्राधिकरण उपलब्ध नहीं है; भरोसेमंद टाइमस्टैम्प के बिना PAdES B-B के रूप में एक्सपोर्ट किया गया।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タイムスタンプ局を利用できないため、信頼できるタイムスタンプなしのPAdES B-Bとして書き出しました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "时间戳颁发机构不可用；已导出为不含可信时间戳的 PAdES B-B。"
          }
        }
      }
    },
    "status.textEdit.copiedNearbyFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copied nearby PDF text style. Click another text edit to paste it automatically, or press Paste style here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se copió el estilo de texto del PDF cercano. Haz clic en otra edición de texto para pegarlo automáticamente, o pulsa Pegar estilo aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Style de texte PDF voisin copié. Cliquez sur une autre modification de texte pour le coller automatiquement, ou appuyez sur Coller le style ici."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नज़दीकी PDF टेक्स्ट स्टाइल कॉपी की गई। इसे अपने आप पेस्ट करने के लिए किसी अन्य टेक्स्ट एडिट पर क्लिक करें, या यहाँ स्टाइल पेस्ट करें दबाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "近くのPDFテキストのスタイルをコピーしました。別のテキスト編集をクリックすると自動的に貼り付けられます。ここで「スタイルを貼り付け」を押すこともできます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已复制附近PDF文本的样式。点击另一处文本编辑即可自动粘贴,或在此处按“粘贴样式”。"
          }
        }
      }
    },
    "status.textEdit.copiedNearbyFormatPinned": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copied nearby PDF text style — pinned. Click any text edit to paste it; click Copy again to unpin."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estilo de texto del PDF cercano copiado y fijado. Haz clic en cualquier edición de texto para pegarlo; vuelve a pulsar Copiar para desactivarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Style de texte PDF voisin copié et épinglé. Cliquez sur n'importe quelle modification de texte pour le coller ; cliquez de nouveau sur Copier pour désépingler."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नज़दीकी PDF टेक्स्ट स्टाइल कॉपी करके पिन कर दी गई। इसे पेस्ट करने के लिए किसी भी टेक्स्ट एडिट पर क्लिक करें; अनपिन करने के लिए फिर से कॉपी दबाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "近くのPDFテキストのスタイルをコピーして固定しました。任意のテキスト編集をクリックすると貼り付けられます。固定を解除するには、もう一度「コピー」を押してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已复制并固定附近PDF文本的样式。点击任意文本编辑即可粘贴;再次点击“复制”可取消固定。"
          }
        }
      }
    },
    "status.textEdit.copyFormatFirst": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy a format first, then open another text edit and press Paste style."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Primero copia un formato y luego abre otra edición de texto y pulsa Pegar estilo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiez d’abord un format, puis ouvrez une autre modification de texte et appuyez sur Coller le style."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहले एक फ़ॉर्मेट कॉपी करें, फिर किसी अन्य टेक्स्ट एडिट को खोलें और स्टाइल पेस्ट करें दबाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まず書式をコピーしてから、別のテキスト編集を開いて「スタイルを貼り付け」を押してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先复制一种格式,然后打开另一处文本编辑并按“粘贴样式”。"
          }
        }
      }
    },
    "status.textEdit.editorLostPage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This page changed while you were editing, so the edit couldn’t be applied. Click the text again to edit it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta página cambió mientras editabas, por lo que no se pudo aplicar la edición. Haz clic en el texto de nuevo para editarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette page a changé pendant votre modification, l’édition n’a donc pas pu être appliquée. Cliquez à nouveau sur le texte pour le modifier."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "संपादन के दौरान यह पृष्ठ बदल गया, इसलिए संपादन लागू नहीं किया जा सका। इसे संपादित करने के लिए फिर से टेक्स्ट पर क्लिक करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "編集中にこのページが変更されたため、編集を適用できませんでした。編集するにはテキストをもう一度クリックしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "编辑时此页面已更改，因此无法应用编辑。请再次点击文本以进行编辑。"
          }
        }
      }
    },
    "status.textEdit.formatMismatch": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Edited text formatting does not match nearby document text. Use Match before Done to copy the nearby format."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El formato del texto editado no coincide con el texto cercano del documento. Usa Igualar antes de Listo para copiar el formato cercano."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le formatage du texte modifié ne correspond pas au texte voisin du document. Utilisez Faire correspondre avant Terminé pour copier le format voisin."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "संपादित टेक्स्ट की फ़ॉर्मेटिंग नज़दीकी दस्तावेज़ टेक्स्ट से मेल नहीं खाती। नज़दीकी फ़ॉर्मेट कॉपी करने के लिए हो गया से पहले मिलान करें का उपयोग करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "編集したテキストの書式が近くの文書テキストと一致していません。近くの書式をコピーするには、「完了」を押す前に「一致させる」を使用してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "编辑后的文本格式与附近文档文本不一致。按“完成”前请使用“匹配”以复制附近的格式。"
          }
        }
      }
    },
    "status.textEdit.matchedNearbyFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Matched nearby text style, margins, and wrapping. Press Done to save it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se igualaron el estilo, los márgenes y el ajuste de texto cercanos. Pulsa Listo para guardarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Style, marges et retour à la ligne du texte voisin appliqués. Appuyez sur Terminé pour enregistrer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नज़दीकी टेक्स्ट स्टाइल, मार्जिन और रैपिंग से मिलान किया गया। इसे सहेजने के लिए हो गया दबाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "近くのテキストのスタイル、余白、折り返しに合わせました。保存するには「完了」を押してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已匹配附近文本的样式、边距和换行方式。按“完成”以保存。"
          }
        }
      }
    },
    "status.textEdit.nothingToUndo": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nothing to undo in this text box. Press Done or Cancel before undoing document changes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay nada que deshacer en este cuadro de texto. Pulsa Listo o Cancelar antes de deshacer cambios del documento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rien à annuler dans cette zone de texte. Appuyez sur Terminé ou Annuler avant d’annuler les modifications du document."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस टेक्स्ट बॉक्स में पूर्ववत करने के लिए कुछ नहीं है। दस्तावेज़ में बदलाव पूर्ववत करने से पहले हो गया या रद्द करें दबाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このテキストボックスには元に戻す操作がありません。文書の変更を元に戻す前に「完了」または「キャンセル」を押してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此文本框中没有可撤销的操作。撤销文档更改前,请先按“完成”或“取消”。"
          }
        }
      }
    },
    "status.textEdit.pastedStyle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasted copied style. Press Done to save it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estilo copiado pegado. Pulsa Listo para guardarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Style copié collé. Appuyez sur Terminé pour enregistrer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कॉपी की गई स्टाइल पेस्ट की गई। इसे सहेजने के लिए हो गया दबाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
