    "guideFeature.markUp.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Highlight, underline, strike out, draw ink, erase marks, and add notes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Resalta, subraya, tacha, dibuja a mano alzada, borra marcas y añade notas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Surlignez, soulignez, barrez, dessinez à l’encre, effacez des marques et ajoutez des notes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हाइलाइट करें, अंडरलाइन करें, स्ट्राइक करें, स्याही से चित्र बनाएं, निशान मिटाएं और नोट्स जोड़ें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ハイライト、下線、取り消し線、フリーハンド描画、消しゴム、ノートの追加ができます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "高亮、下划线、删除线、手绘墨迹、擦除标记并添加备注。"
          }
        }
      }
    },
