        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "иҝ‘гҒҸгҒ®PDFгғҶгӮӯгӮ№гғҲгҒ®гӮ№гӮҝгӮӨгғ«гӮ’гӮігғ”гғјгҒ—гҒҰгҖҒеҲҘгҒ®гғҶгӮӯгӮ№гғҲз·ЁйӣҶгҒ«иІјгӮҠд»ҳгҒ‘гӮүгӮҢгӮӢгӮҲгҒҶгҒ«гҒ—гҒҫгҒҷгҖӮ"
          }
