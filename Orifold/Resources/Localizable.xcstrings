    "pet.species.dog.tagline": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Origami dog · loyal, excited, endlessly encouraging."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Perro de origami · leal, entusiasta, siempre alentador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chien en origami · loyal, enthousiaste, toujours encourageant."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ओरिगामी कुत्ता · वफ़ादार, उत्साही, हमेशा हौसला बढ़ाने वाला।"
          }
        },
        "ja": {
          "stringUnit": {
