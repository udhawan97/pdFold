    },
    "error.signatureAppearance.emptyText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Type a name before creating a signature."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
