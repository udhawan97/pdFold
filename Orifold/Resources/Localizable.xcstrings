            "value": "Choose a Digital ID first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige primero una identificación digital."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez d'abord une identité numérique."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहले एक डिजिटल आईडी चुनें।"
