    "gami.sibling.switch": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ori's my sister — same sheet, fancier creases!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ori es mi hermana: la misma hoja, con pliegues más elegantes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ori, c'est ma sœur — même feuille, plis plus chics !"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ओरी मेरी बहन है — वही कागज़, बस ज़्यादा शानदार सिलवटें!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オリは僕の妹。同じ紙から、もっと洒落た折り方をしただけ！"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Ori 是我妹妹——同一张纸，只是折得更讲究。"
          }
        }
      }
    },
    "gami.warning.1": {
      "extractionState": "manual",
      "localizations": {
