    "gami.intro.greeting": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi, I'm Gami — your Orifold guide."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hola, soy Gami: tu guía de Orifold."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bonjour, je suis Gami, votre guide Orifold."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नमस्ते, मैं गामी हूँ — आपका Orifold गाइड।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "こんにちは、ガミです。Orifold のガイド役です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你好，我是 Gami——你的 Orifold 向导。"
          }
        }
      }
    },
    "gami.intro.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everything stays on this Mac. I'll share the occasional tip — never your files."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo permanece en este Mac. Compartiré algún consejo de vez en cuando, nunca tus archivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout reste sur ce Mac. Je partagerai quelques conseils à l'occasion, jamais vos fichiers."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सब कुछ इसी Mac पर रहता है। मैं कभी-कभार सुझाव दूँगा — कभी आपकी फ़ाइलें नहीं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてこの Mac の中に留まります。たまにヒントをお伝えしますが、書類を外に出すことはありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一切都保留在这台 Mac 上。我偶尔会分享一些小提示——但绝不会碰你的文件。"
          }
        }
      }
    },
