    "sidebar.deletePages.confirmation.messageSingular": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes the page and any page-bound signatures, stamps, and anchors."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina la página y cualquier firma, sello o anclaje asociado a ella."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette action supprime la page ainsi que les signatures, tampons et repères qui lui sont associés."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इससे पेज के साथ-साथ उससे जुड़े हस्ताक्षर, स्टैम्प और एंकर भी हट जाएंगे।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このページと、それに紐づく署名、スタンプ、アンカーもすべて削除されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将删除该页面以及所有与该页面绑定的签名、图章和锚点。"
          }
        }
      }
    },
