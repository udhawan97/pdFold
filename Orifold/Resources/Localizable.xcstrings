    "documentComfort.reduceAnimations.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Minimizes motion for a calmer interface."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Minimiza el movimiento para una interfaz más tranquila."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réduit le mouvement pour une interface plus calme."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "शांत इंटरफ़ेस के लिए गति को कम करता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "動きを抑えて、より落ち着いたインターフェースにします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "减少动效，营造更平静的界面。"
          }
        }
      }
    },
    "documentComfort.reduceAnimations.info": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turns off motion and mascot animation for a calmer, steadier interface."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactiva el movimiento y la animación de la mascota para una interfaz más tranquila y estable."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactive les animations et la mascotte animée pour une interface plus calme et stable."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "शांत और स्थिर इंटरफ़ेस के लिए गति और मैस्कॉट एनिमेशन बंद करता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
