    "gami.save.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tip: Autosave keeps edits safe between sessions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consejo: el autoguardado protege tus cambios entre sesiones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Astuce : l'enregistrement automatique protège vos modifications entre les sessions."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सुझाव: ऑटोसेव सत्रों के बीच आपके बदलाव सुरक्षित रखता है।"
          }
        },
        "ja": {
