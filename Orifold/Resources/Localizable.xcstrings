    "status.annotation.onlyNotesEditable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only notes and text boxes can be edited directly. Use delete to remove this markup."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo las notas y los cuadros de texto se pueden editar directamente. Usa eliminar para quitar esta marca."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seules les notes et les zones de texte peuvent être modifiées directement. Utilisez supprimer pour retirer cette annotation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल नोट्स और टेक्स्ट बॉक्स सीधे संपादित किए जा सकते हैं। इस मार्कअप को हटाने के लिए हटाएँ का उपयोग करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "直接編集できるのはメモとテキストボックスのみです。このマークアップを削除するには削除を使用してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只能直接编辑备注和文本框。要移除此标记,请使用删除。"
          }
        }
      }
    },
