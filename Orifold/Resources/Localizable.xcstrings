    "sidebar.removePages.confirmation.plural": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes %lld pages and their page-bound signatures, stamps, and anchors."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina %lld páginas y sus firmas, sellos y anclas asociados a la página."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime %lld pages ainsi que leurs signatures, tampons et ancrages associés."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इससे %lld पृष्ठ और उनसे जुड़े हस्ताक्षर, स्टैम्प और एंकर हट जाएंगे।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld ページと、それらに紐づく署名、スタンプ、アンカーが削除されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将删除 %lld 个页面及其页面绑定的签名、印章和锚点。"
          }
        }
      }
    },
