    "gami.save.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Saved. Your work stays private, on this device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guardado. Tu trabajo permanece privado, en este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistré. Votre travail reste privé, sur cet appareil."
          }
