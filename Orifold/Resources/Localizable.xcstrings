    "pet.feedback.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Psst — Orifold is brand new. The developer would genuinely love your thoughts: umangdhawan97@gmail.com"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Psst, Orifold es totalmente nuevo. Al desarrollador le encantaría conocer tu opinión: umangdhawan97@gmail.com"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Psst — Orifold est tout nouveau. Le développeur adorerait sincèrement avoir votre avis : umangdhawan97@gmail.com"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सुनिए — Orifold बिल्कुल नया है। डेवलपर को वाकई आपकी राय पसंद आएगी: umangdhawan97@gmail.com"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ちょっと一言。Orifoldは生まれたばかりです。開発者は本気であなたの感想を聞きたがっています: umangdhawan97@gmail.com"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "悄悄说一句——Orifold 才刚刚起步。开发者真心想听听你的想法：umangdhawan97@gmail.com"
          }
        }
      }
    },
    "pet.feedback.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enjoying this? Tell the human who made it: umangdhawan97@gmail.com — they read every message."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Te está gustando? Cuéntaselo a quien lo creó: umangdhawan97@gmail.com — lee todos los mensajes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous appréciez l’expérience ? Dites-le à la personne qui l’a créée : umangdhawan97@gmail.com — chaque message est lu."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह पसंद आ रहा है? इसे बनाने वाले इंसान को बताएं: umangdhawan97@gmail.com — वे हर संदेश पढ़ते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "楽しんでいただけていますか? 作った人に伝えてあげてください: umangdhawan97@gmail.com — すべてのメッセージに目を通しています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用得还开心吗？告诉做出它的那个人吧：umangdhawan97@gmail.com——每条消息都会被认真读到。"
          }
        }
      }
    },
    "pet.feedback.3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You've done real work today. Worth a quick note? umangdhawan97@gmail.com"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoy hiciste un trabajo de verdad. ¿Vale la pena una nota rápida? umangdhawan97@gmail.com"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez bien travaillé aujourd’hui. Ça vaut bien un petit mot ? umangdhawan97@gmail.com"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपने आज वाकई अच्छा काम किया है। एक छोटा नोट भेजना चाहेंगे? umangdhawan97@gmail.com"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日はよく頑張りましたね。一言メモを残してみませんか? umangdhawan97@gmail.com"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今天做了不少实事呢。要不要留句话？umangdhawan97@gmail.com"
          }
        }
      }
    },
    "pet.inspiration.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Progress counts, even when it arrives wearing a loading spinner."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El progreso cuenta, aunque llegue con un indicador de carga."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le progrès compte, même quand il arrive avec une roue qui tourne."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रगति मायने रखती है, भले ही वह लोडिंग स्पिनर पहनकर आए।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進捗はローディングスピナーをまとっていても、ちゃんと進捗です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "进度依然算数，哪怕它是顶着加载图标出现的。"
          }
        }
      }
    },
    "pet.inspiration.10": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Today's masterpiece may be tomorrow's attachment. Keep going."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La obra maestra de hoy puede ser el adjunto de mañana. Sigue adelante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le chef-d’œuvre d’aujourd’hui sera peut-être la pièce jointe de demain. Continuez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आज की उत्कृष्ट कृति कल की अटैचमेंट हो सकती है। लगे रहें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日の傑作は、明日の添付ファイルになるかもしれません。続けていきましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今天的杰作，也许就是明天的附件。继续前进吧。"
          }
        }
      }
    },
    "pet.inspiration.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make the next page better. The whole document will get the hint."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejora la próxima página. Todo el documento lo notará."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Améliorez la prochaine page. Tout le document en profitera."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगले पेज को बेहतर बनाएं। पूरे दस्तावेज़ को इशारा समझ आ जाएगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次のページを少し良くしましょう。書類全体がそれに気づきます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "把下一页做得更好，整份文档都会感受到。"
          }
        }
      }
    },
    "pet.inspiration.3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clarity is a power move. So is saving before experimenting."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La claridad es un gran movimiento. Guardar antes de experimentar, también."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La clarté, c’est puissant. Enregistrer avant d’expérimenter aussi."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्पष्टता एक ताकतवर कदम है। प्रयोग करने से पहले सेव करना भी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "明快さは強さです。実験の前に保存するのも同じくらい強さです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清晰是一种强大的姿态，保存后再实验也是。"
          }
        }
      }
    },
    "pet.inspiration.4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One clean edit beats twelve heroic explanations."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una edición limpia vale más que doce explicaciones heroicas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une modification propre vaut mieux que douze explications héroïques."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक साफ़-सुथरा संपादन बारह वीरतापूर्ण स्पष्टीकरणों से बेहतर है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1つのきれいな編集は、12個の英雄的な言い訳に勝ります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一次干净的编辑，胜过十二次英勇的解释。"
          }
        }
      }
    },
    "pet.inspiration.5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your future self called. They appreciate the filenames."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu yo futuro llamó. Agradece los nombres de archivo bien puestos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre futur vous a appelé. Il apprécie les noms de fichiers clairs."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके भविष्य वाले स्वरूप ने फ़ोन किया था। उन्हें फ़ाइल के नाम पसंद आए।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未来のあなたから電話がありました。わかりやすいファイル名に感謝していました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未来的你打来了电话，感谢你取的这些文件名。"
          }
        }
      }
    },
    "pet.inspiration.6": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Small tidy choices compound. Annoyingly practical, deeply effective."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las pequeñas decisiones ordenadas se acumulan. Molestamente prácticas, profundamente efectivas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les petits choix soignés s’accumulent. Ennuyeusement pratique, terriblement efficace."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "छोटे-छोटे व्यवस्थित फैसले जुड़ते जाते हैं। परेशान करने की हद तक व्यावहारिक, गहराई से असरदार।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "小さな整理の積み重ねは効いてきます。地味に実用的で、驚くほど効果的。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "微小而整洁的选择会不断累积。烦人地实用，却也无比有效。"
          }
        }
      }
    },
    "pet.inspiration.7": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Done is not the enemy of great. It is great's project manager."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminado no es el enemigo de excelente. Es su gestor de proyectos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fini n’est pas l’ennemi du parfait. C’est son chef de projet."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पूरा होना बढ़िया का दुश्मन नहीं है। यह बढ़िया का प्रोजेक्ट मैनेजर है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「完了」は「完璧」の敵ではありません。むしろそのプロジェクトマネージャーです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "完成不是完美的敌人，它是完美的项目经理。"
          }
        }
      }
    },
    "pet.inspiration.8": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read twice, mark once. Very professional. Suspiciously wise."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee dos veces, marca una. Muy profesional. Sospechosamente sabio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Relire deux fois, marquer une fois. Très professionnel. Étonnamment sage."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दो बार पढ़ें, एक बार चिह्नित करें। बहुत पेशेवर। शक होने लायक समझदार।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "二度読んで、一度だけマークする。とてもプロフェッショナルで、妙に賢いやり方です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "读两遍，标一次。非常专业，透着一股可疑的智慧。"
          }
        }
      }
    },
    "pet.inspiration.9": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Momentum loves a modest checklist and a good export."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El impulso ama una lista modesta y una buena exportación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’élan aime une checklist modeste et un bon export."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "गति एक मामूली चेकलिस्ट और एक अच्छे एक्सपोर्ट को पसंद करती है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "勢いは、控えめなチェックリストと良い書き出しを好みます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "势头喜欢朴素的清单和一次顺利的导出。"
          }
        }
      }
    },
