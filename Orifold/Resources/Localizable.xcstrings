    "guidePopover.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bring scattered files together, clean them up, and send out the version people actually need."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reúne archivos dispersos, ordénalos y envía la versión que la gente realmente necesita."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rassemblez des fichiers épars, nettoyez-les et envoyez la version que vos destinataires attendent vraiment."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बिखरी फ़ाइलों को एक साथ लाएं, उन्हें व्यवस्थित करें, और लोगों को जो वाकई चाहिए वह भेजें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "散らばったファイルを1か所に集め、整理して、本当に必要な形にして送り出しましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "把零散的文件汇集到一起，整理妥当，再发送出大家真正需要的版本。"
          }
        }
      }
    },
