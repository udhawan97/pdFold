          "stringUnit": {
            "state": "translated",
            "value": "Orifold 在该位置未找到可编辑文本。"
          }
        }
      }
    },
    "error.editing.fontConversionFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not preserve the original font, so it used a system font."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo conservar la fuente original, por lo que usó una fuente del sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu conserver la police d'origine ; il a donc utilisé une police système."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold मूल फ़ॉन्ट बनाए नहीं रख सका, इसलिए इसने एक सिस्टम फ़ॉन्ट का उपयोग किया।"
          }
        },
        "ja": {
