            "state": "translated",
            "value": "Orifold n'a pas pu vérifier le PDF réduit. Essayez d'exporter sans réduire la taille du fichier."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold घटाए गए PDF को सत्यापित नहीं कर सका। फ़ाइल आकार घटाए बिना निर्यात करने का प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは縮小後のPDFを検証できませんでした。ファイルサイズを縮小せずに書き出してみてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法验证缩减后的 PDF。请尝试在不缩减文件大小的情况下导出。"
          }
        }
      }
    },
    "error.export.writeEmptyFile": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold wrote an empty file, so the export was discarded. Check that the destination has free space and permission to write, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold escribió un archivo vacío, por lo que se descartó la exportación. Verifica que el destino tenga espacio libre y permiso de escritura, luego inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold a écrit un fichier vide ; l'exportation a donc été annulée. Vérifiez que la destination dispose d'espace libre et de l'autorisation d'écriture, puis réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold ने एक खाली फ़ाइल लिखी, इसलिए निर्यात को छोड़ दिया गया। जाँचें कि गंतव्य में खाली स्थान और लिखने की अनुमति है, फिर फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは空のファイルを書き込んだため、書き出しは破棄されました。保存先に空き容量と書き込み権限があることを確認して、再試行してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 写入了一个空文件，因此该导出已被丢弃。请确认目标位置有可用空间和写入权限，然后重试。"
          }
        }
      }
    },
    "error.export.writeFileNotFound": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not confirm the export was written to disk. The destination folder may have rejected the write -- check permissions and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo confirmar que la exportación se escribió en el disco. Es posible que la carpeta de destino haya rechazado la escritura; verifica los permisos e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu confirmer que l'exportation a été écrite sur le disque. Le dossier de destination a peut-être refusé l'écriture ; vérifiez les autorisations et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold यह पुष्टि नहीं कर सका कि निर्यात डिस्क पर लिखा गया। हो सकता है गंतव्य फ़ोल्डर ने लेखन को अस्वीकार कर दिया हो; अनुमतियाँ जाँचें और फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは書き出しがディスクに書き込まれたことを確認できませんでした。保存先フォルダが書き込みを拒否した可能性があります。権限を確認して再試行してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法确认导出内容已写入磁盘。目标文件夹可能拒绝了写入操作，请检查权限后重试。"
          }
        }
      }
    },
    "error.form.invalidPDF": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not lock the form answers in this PDF. Reopen the document and try exporting again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo bloquear las respuestas del formulario en este PDF. Vuelve a abrir el documento e intenta exportar de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n’a pas pu verrouiller les réponses du formulaire dans ce PDF. Rouvrez le document et réessayez d’exporter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold इस PDF में फ़ॉर्म के जवाबों को लॉक नहीं कर सका। दस्तावेज़ को फिर से खोलें और फिर से एक्सपोर्ट करने की कोशिश करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OrifoldはこのPDFのフォーム入力内容を固定できませんでした。書類を開き直してもう一度書き出してみてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法锁定此 PDF 中的表单答案。请重新打开文档后再次导出。"
          }
        }
      }
    },
    "error.form.pageOrderMismatch": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not match form fields to the current page order. Reopen the document and try exporting again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo hacer coincidir los campos del formulario con el orden de página actual. Vuelve a abrir el documento e intenta exportar de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n’a pas pu associer les champs du formulaire à l’ordre actuel des pages. Rouvrez le document et réessayez d’exporter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold फ़ॉर्म फ़ील्ड को मौजूदा पेज क्रम से मैच नहीं कर सका। दस्तावेज़ को फिर से खोलें और फिर से एक्सपोर्ट करने की कोशिश करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはフォームフィールドを現在のページ順序に一致させられませんでした。書類を開き直してもう一度書き出してみてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法将表单字段与当前页面顺序匹配。请重新打开文档后再次导出。"
          }
        }
      }
    },
    "error.import.binaryDataMislabelledAsText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This looks like binary data, not a supported text document. Check the file type and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto parece ser datos binarios, no un documento de texto compatible. Verifica el tipo de archivo e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela ressemble à des données binaires, pas à un document texte pris en charge. Vérifiez le type de fichier et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह बाइनरी डेटा जैसा लगता है, समर्थित टेक्स्ट दस्तावेज़ नहीं। फ़ाइल प्रकार जाँचें और फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これはサポートされているテキスト文書ではなく、バイナリデータのようです。ファイル形式を確認してもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这看起来是二进制数据，而非受支持的文本文档。请检查文件类型后重试。"
          }
        }
      }
    },
    "error.import.emptyDocument": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file is empty."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo está vacío."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier est vide."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल खाली है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルが空です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该文件为空。"
          }
        }
      }
    },
    "error.import.passwordProtected": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This PDF is password-protected. Add it to an open workspace with Add Files or drag-and-drop so Orifold can prompt for the password."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este PDF está protegido con contraseña. Agrégalo a un espacio de trabajo abierto con Agregar archivos o arrastrándolo, para que Orifold pueda solicitar la contraseña."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce PDF est protégé par un mot de passe. Ajoutez-le à un espace de travail ouvert via Ajouter des fichiers ou par glisser-déposer afin qu'Orifold puisse demander le mot de passe."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह PDF पासवर्ड-सुरक्षित है। इसे किसी खुले वर्कस्पेस में फ़ाइलें जोड़ें या खींचकर छोड़ें से जोड़ें, ताकि Orifold पासवर्ड माँग सके।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このPDFはパスワードで保護されています。「ファイルを追加」またはドラッグ＆ドロップで開いているワークスペースに追加すると、Orifoldがパスワードの入力を求めます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此 PDF 已设置密码保护。请通过“添加文件”或拖放将其加入已打开的工作区，以便 Orifold 提示输入密码。"
          }
        }
      }
    },
    "error.import.preparePDFForSaving": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not prepare this file for saving. Try exporting it to PDF first, then import the exported file."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo preparar este archivo para guardarlo. Intenta exportarlo primero a PDF y luego importa el archivo exportado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu préparer ce fichier pour l'enregistrement. Essayez de l'exporter d'abord en PDF, puis importez le fichier exporté."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold इस फ़ाइल को सहेजने के लिए तैयार नहीं कर सका। पहले इसे PDF में एक्सपोर्ट करने का प्रयास करें, फिर एक्सपोर्ट की गई फ़ाइल आयात करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはこのファイルを保存用に準備できませんでした。まずPDFとして書き出してから、その書き出したファイルを読み込んでください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法为保存准备此文件。请先将其导出为 PDF，然后再导入导出的文件。"
          }
        }
      }
    },
    "error.import.renderTimedOut": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file took too long to render. Try exporting it to PDF from its original app, then import the PDF."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo tardó demasiado en procesarse. Intenta exportarlo a PDF desde su aplicación original y luego importa el PDF."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier a mis trop de temps à s'afficher. Essayez de l'exporter en PDF depuis son application d'origine, puis importez le PDF."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल को रेंडर होने में बहुत समय लगा। इसे मूल ऐप से PDF में एक्सपोर्ट करने का प्रयास करें, फिर PDF आयात करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルのレンダリングに時間がかかりすぎました。元のアプリからPDFとして書き出してから、そのPDFを読み込んでください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文件渲染耗时过长。请尝试先在原始应用中将其导出为 PDF，然后再导入该 PDF。"
          }
        }
      }
    },
    "error.import.renderingFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file opened, but Orifold could not render it into a PDF."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo se abrió, pero Orifold no pudo convertirlo en un PDF."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier s'est ouvert, mais Orifold n'a pas pu le convertir en PDF."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल खुल गई, लेकिन Orifold इसे PDF में रेंडर नहीं कर सका।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルは開けましたが、OrifoldがPDFに変換できませんでした。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文件已打开，但 Orifold 无法将其渲染为 PDF。"
          }
        }
      }
    },
    "error.import.unreadableDocument": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file could not be read. It may be corrupt, encrypted, or incomplete."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo leer el archivo. Puede estar dañado, cifrado o incompleto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier n'a pas pu être lu. Il est peut-être corrompu, chiffré ou incomplet."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल पढ़ी नहीं जा सकी। यह ख़राब, एन्क्रिप्टेड या अधूरी हो सकती है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルを読み込めませんでした。破損、暗号化、または不完全な可能性があります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法读取该文件，它可能已损坏、已加密或不完整。"
          }
        }
      }
    },
    "error.import.unsupportedFileType": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This file type is not supported yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este tipo de archivo aún no es compatible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce type de fichier n'est pas encore pris en charge."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह फ़ाइल प्रकार अभी समर्थित नहीं है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このファイル形式はまだサポートされていません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂不支持此文件类型。"
          }
        }
      }
    },
    "error.markup.eraseTargetMissing": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click a highlight, underline, or strikeout to erase it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en un resaltado, subrayado o tachado para borrarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur un surlignage, un soulignement ou une barre pour l’effacer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी हाइलाइट, अंडरलाइन, या स्ट्राइकआउट को मिटाने के लिए उस पर क्लिक करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ハイライト、下線、取り消し線をクリックして消去してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点按高亮、下划线或删除线以将其擦除。"
          }
        }
      }
    },
    "error.ocr.cancelled": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Making this document searchable was cancelled. The original document is unchanged."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se canceló la conversión de este documento a buscable. El documento original no ha cambiado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La mise en consultable de ce document a été annulée. Le document d’origine est inchangé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस दस्तावेज़ को खोजने योग्य बनाना रद्द कर दिया गया। मूल दस्तावेज़ अपरिवर्तित है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この書類を検索可能にする処理はキャンセルされました。元の書類は変更されていません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使此文档可搜索的操作已取消，原始文档未发生变化。"
          }
        }
      }
    },
    "error.ocr.noScannedPages": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This document already has searchable text."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este documento ya tiene texto buscable."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce document contient déjà du texte consultable."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस दस्तावेज़ में पहले से ही खोजने योग्य टेक्स्ट है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この書類にはすでに検索可能なテキストがあります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此文档已包含可搜索的文本。"
          }
        }
      }
    },
    "error.pageEdit.cannotAccessOriginal": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not access the original page for editing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo acceder a la página original para editarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n’a pas pu accéder à la page d’origine pour la modifier."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold संपादन के लिए मूल पेज तक नहीं पहुंच सका।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは編集のために元のページにアクセスできませんでした。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法访问原始页面以进行编辑。"
          }
        }
      }
    },
    "error.pageEdit.regenerateFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not regenerate that edited page. The original page is unchanged."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo regenerar esa página editada. La página original no ha cambiado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n’a pas pu régénérer cette page modifiée. La page d’origine est inchangée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold उस संपादित पेज को फिर से नहीं बना सका। मूल पेज अपरिवर्तित है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは編集済みのそのページを再生成できませんでした。元のページは変更されていません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法重新生成该编辑后的页面，原始页面未发生变化。"
          }
        }
      }
    },
    "error.pageEdit.restoreFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not restore that page. The edit was left in place."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo restaurar esa página. La edición se mantuvo tal cual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n’a pas pu restaurer cette page. La modification a été conservée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold उस पेज को वापस नहीं ला सका। संपादन को वैसे ही छोड़ दिया गया था।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはそのページを復元できませんでした。編集内容はそのまま残されています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法恢复该页面，编辑内容已保留。"
          }
        }
      }
    },
    "error.pageEdit.restoreSomeFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not restore some pages; their edits were left in place."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo restaurar algunas páginas; sus ediciones se mantuvieron tal cual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n’a pas pu restaurer certaines pages ; leurs modifications ont été conservées."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold कुछ पेजों को वापस नहीं ला सका; उनके संपादन को वैसे ही छोड़ दिया गया था।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは一部のページを復元できませんでした。それらの編集内容はそのまま残されています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
