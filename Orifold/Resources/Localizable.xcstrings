          }
        }
      }
    },
    "status.textEdit.replacementCannotBeEmpty": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Replacement text cannot be empty. Use a text box or a future redaction tool for removal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El texto de reemplazo no puede estar vacío. Usa un cuadro de texto o una futura herramienta de redacción para eliminarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le texte de remplacement ne peut pas être vide. Utilisez une zone de texte ou un futur outil de rédaction pour le supprimer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रतिस्थापन टेक्स्ट खाली नहीं हो सकता। हटाने के लिए टेक्स्ट बॉक्स या भविष्य के रिडैक्शन टूल का उपयोग करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "置換テキストを空にすることはできません。削除するにはテキストボックスまたは今後追加される墨消しツールを使用してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "替换文本不能为空。如需删除,请使用文本框或未来推出的编辑遮盖工具。"
          }
        }
      }
    },
    "status.textEdit.restoredOriginal": {
      "extractionState": "manual",
      "localizations": {
