    "documentComfort.appTheme.info": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sets the app window's light or dark appearance. It doesn't change the PDF itself."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Define la apariencia clara u oscura de la ventana de la app. No cambia el PDF en sí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définit l'apparence claire ou sombre de la fenêtre de l'app. Cela ne modifie pas le PDF."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप विंडो की लाइट या डार्क शक्ल तय करता है। इससे PDF में कोई बदलाव नहीं होता।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリウィンドウの明暗表示を設定します。PDF自体は変更されません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置应用窗口的浅色或深色外观，不会更改 PDF 本身。"
          }
        }
      }
    },
    "documentComfort.brightness.info": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dims or brightens the page on screen without editing the document."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Atenúa o aumenta el brillo de la página en pantalla sin editar el documento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Assombrit ou éclaircit la page à l'écran sans modifier le document."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दस्तावेज़ में बदलाव किए बिना स्क्रीन पर पेज को धीमा या तेज़ चमकीला करता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "文書を編集せずに画面上のページを暗くしたり明るくしたりします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在不修改文档的情况下调暗或调亮屏幕上的页面。"
          }
        }
      }
    },
