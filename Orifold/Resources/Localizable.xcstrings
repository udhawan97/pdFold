    "inspector.ocr.detail.textFoundNoAutoRun": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold found existing PDF text, so it did not auto-run OCR. If search misses visible words, the text layer may be partial or incorrect."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold encontrГі texto de PDF existente, por lo que no ejecutГі el OCR automГЎticamente. Si la bГәsqueda no encuentra palabras visibles, la capa de texto podrГӯa estar incompleta o ser incorrecta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold a trouvГ© du texte PDF existant et nвҖҷa donc pas lancГ© lвҖҷOCR automatiquement. Si la recherche ne trouve pas des mots visibles, la couche de texte est peut-ГӘtre partielle ou incorrecte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold аӨ•аҘӢ аӨ®аҘҢаӨңаҘӮаӨҰаӨҫ PDF аӨҹаҘҮаӨ•аҘҚаӨёаҘҚаӨҹ аӨ®аӨҝаӨІаӨҫ, аӨҮаӨёаӨІаӨҝаӨҸ аӨҮаӨёаӨЁаҘҮ OCR аӨ…аӨӘаӨЁаҘҮ аӨҶаӨӘ аӨЁаӨ№аҘҖаӨӮ аӨҡаӨІаӨҫаӨҜаӨҫаҘӨ аӨ…аӨ—аӨ° аӨ–аҘӢаӨң аӨ®аҘҮаӨӮ аӨҰаӨҝаӨ–аӨЁаҘҮ аӨөаӨҫаӨІаҘҮ аӨ¶аӨ¬аҘҚаӨҰ аӨЁаӨ№аҘҖаӨӮ аӨ®аӨҝаӨІаӨӨаҘҮ, аӨӨаҘӢ аӨҹаҘҮаӨ•аҘҚаӨёаҘҚаӨҹ аӨІаҘҮаӨҜаӨ° аӨ…аӨ§аҘӮаӨ°аҘҖ аӨҜаӨҫ аӨ—аӨІаӨӨ аӨ№аҘӢ аӨёаӨ•аӨӨаҘҖ аӨ№аҘҲаҘӨ"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OrifoldгҒҜж—ўеӯҳгҒ®PDFгғҶгӮӯгӮ№гғҲгӮ’жӨңеҮәгҒ—гҒҹгҒҹгӮҒгҖҒOCRгӮ’иҮӘеӢ•е®ҹиЎҢгҒ—гҒҫгҒӣгӮ“гҒ§гҒ—гҒҹгҖӮжӨңзҙўгҒ§иЎЁзӨәдёӯгҒ®еҚҳиӘһгҒҢиҰӢгҒӨгҒӢгӮүгҒӘгҒ„е ҙеҗҲгҖҒгғҶгӮӯгӮ№гғҲгғ¬гӮӨгғӨгғјгҒҢдёҚе®Ңе…ЁгҒҫгҒҹгҒҜдёҚжӯЈзўәгҒӘеҸҜиғҪжҖ§гҒҢгҒӮгӮҠгҒҫгҒҷгҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
