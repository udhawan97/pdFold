    "error.editing.invalidSelectionBounds": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That PDF text selection has invalid bounds, so Orifold added a normal text box instead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esa selección de texto del PDF tiene límites no válidos, por lo que Orifold agregó un cuadro de texto normal en su lugar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette sélection de texte du PDF a des limites non valides ; Orifold a donc ajouté une zone de texte normale à la place."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उस PDF टेक्स्ट चयन की सीमाएँ अमान्य हैं, इसलिए Orifold ने इसके बजाय एक सामान्य टेक्स्ट बॉक्स जोड़ा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのPDFテキスト選択範囲は無効なため、Orifoldは代わりに通常のテキストボックスを追加しました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该 PDF 文本选区边界无效，因此 Orifold 改为添加了一个普通文本框。"
          }
        }
      }
    },
    "error.editing.serializationFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not serialize the edited PDF. Your workspace remains open."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo serializar el PDF editado. Tu espacio de trabajo permanece abierto."
          }
