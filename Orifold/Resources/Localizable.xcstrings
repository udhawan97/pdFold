    "documentComfort.presets.info": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One-tap starting points. Pick one, then fine-tune below if you like."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puntos de partida con un solo toque. Elige uno y, si quieres, ajústalo abajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des points de départ en un clic. Choisissez-en un, puis ajustez ci-dessous si besoin."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक-टैप शुरुआती बिंदु। एक चुनें, फिर चाहें तो नीचे बारीक समायोजन करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワンタップで使える出発点です。選んだ後、必要なら下で微調整できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一键预设起点。选择一个，如果需要可在下方微调。"
          }
        }
      }
    },
