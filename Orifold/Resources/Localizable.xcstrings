    },
    "error.encryption.matchingOwnerAndUserPasswords": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not apply PDF permissions because the owner and user passwords matched. Try exporting again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo aplicar los permisos del PDF porque la contraseña de propietario y la de usuario coincidían. Vuelve a intentar la exportación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n’a pas pu appliquer les autorisations PDF, car le mot de passe propriétaire et le mot de passe utilisateur sont identiques. Réessayez d’exporter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold PDF अनुमतियां लागू नहीं कर सका क्योंकि मालिक और उपयोगकर्ता के पासवर्ड मेल खाते थे। फिर से एक्सपोर्ट करने की कोशिश करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "由于所有者密码和用户密码相同，Orifold 无法应用 PDF 权限。请重新导出。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "所有者パスワードとユーザーパスワードが一致していたため、OrifoldはPDFの権限を適用できませんでした。もう一度書き出してみてください。"
          }
        }
      }
    },
    "error.encryption.digitalSignatureConflict": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Password protection is unavailable because this PDF has a digital signature. Remove the signature, or export without password protection."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La protección con contraseña no está disponible porque este PDF tiene una firma digital. Elimina la firma o exporta sin protección con contraseña."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La protection par mot de passe est indisponible, car ce PDF comporte une signature numérique. Supprimez la signature ou exportez sans protection par mot de passe."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पासवर्ड सुरक्षा उपलब्ध नहीं है क्योंकि इस PDF पर डिजिटल हस्ताक्षर है। हस्ताक्षर हटाएं, या पासवर्ड सुरक्षा के बिना एक्सपोर्ट करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此 PDF 包含数字签名，因此无法使用密码保护。请移除签名，或在不使用密码保护的情况下导出。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このPDFにはデジタル署名があるため、パスワード保護は使用できません。署名を削除するか、パスワード保護なしで書き出してください。"
          }
        }
      }
    },
    "error.encryption.cannotOpenSourcePDF": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not open the final PDF for password protection. Export without password protection, or try again."
          }
