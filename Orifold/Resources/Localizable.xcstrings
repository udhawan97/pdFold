    "pet.event.greeting.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Back again? I never left."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿De vuelta? Yo nunca me fui."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "De retour ? Je n’étais jamais parti."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फिर से वापस? मैं तो कभी गया ही नहीं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "また戻ってきましたね? 私はずっとここにいましたよ。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "又来了？我可从没走开过。"
          }
        }
      }
    },
    "pet.event.greeting.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ready when you are."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Listo cuando tú lo estés."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prêt quand vous le serez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आप तैयार हों, मैं तैयार हूं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いつでもどうぞ。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "准备好了，随时等你。"
          }
        }
      }
    },
    "pet.event.highlight.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Highlighted. Future-you will pretend they read the rest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Resaltado. Tu yo futuro fingirá que leyó el resto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Surligné. Votre futur vous fera semblant d’avoir lu le reste."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हाइलाइट कर दिया। भविष्य वाले आप बाकी पढ़ने का नाटक करेंगे।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ハイライトしましたね。未来のあなたは残りも読んだふりをするはず。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已高亮。未来的你会假装读完了剩下的部分。"
          }
        }
      }
    },
    "pet.event.highlight.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That sentence never stood a chance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esa frase no tuvo ninguna oportunidad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette phrase n’avait aucune chance."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उस वाक्य के पास कोई मौका नहीं था।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あの一文はもう逃げられませんね。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这句话没能逃过一劫。"
          }
        }
      }
    },
    "pet.event.highlight.3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tip: drag over text, then pick a color — highlights stack, so go easy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consejo: arrastra sobre el texto y elige un color; los resaltados se acumulan, así que no te pases."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Astuce : sélectionnez du texte, puis choisissez une couleur — les surlignages s’accumulent, alors n’en abusez pas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टिप: टेक्स्ट पर ड्रैग करें, फिर एक रंग चुनें — हाइलाइट एक-दूसरे पर जमते हैं, इसलिए संभलकर करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ヒント: テキストをドラッグして色を選びましょう。ハイライトは重ねがけできるので、ほどほどに。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提示：拖过文字后选择颜色——高亮可以叠加，悠着点用。"
          }
        }
      }
    },
    "pet.event.highlight.4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yellow again? A classic never fails."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Amarillo otra vez? Un clásico nunca falla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Encore du jaune ? Un classique qui ne déçoit jamais."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फिर से पीला? एक क्लासिक कभी असफल नहीं होता।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "また黄色ですか? 定番は裏切りませんね。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "又是黄色？经典永不过时。"
          }
        }
      }
    },
    "pet.event.ink.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Freehand! Bob Ross would be proud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡A mano alzada! Bob Ross estaría orgulloso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À main levée ! Bob Ross en serait fier."
          }
        },
        "hi": {
          "stringUnit": {
