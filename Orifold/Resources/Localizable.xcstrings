    "pet.event.comment.4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sharp feedback. Speaking of which… the dev would love yours 👀"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comentario certero. Hablando de eso… al desarrollador le encantaría leer el tuyo 👀"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Retour pertinent. D’ailleurs… le développeur adorerait aussi recevoir le vôtre 👀"
