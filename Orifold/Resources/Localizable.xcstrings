    "sidebar.removePages.confirmation.plural": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes %lld pages and their page-bound signatures, stamps, and anchors."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina %lld pГЎginas y sus firmas, sellos y anclas asociados a la pГЎgina."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime %lld pages ainsi que leurs signatures, tampons et ancrages associГ©s."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "аӨҮаӨёаӨёаҘҮ %lld аӨӘаҘғаӨ·аҘҚаӨ  аӨ”аӨ° аӨүаӨЁаӨёаҘҮ аӨңаҘҒаӨЎаӨјаҘҮ аӨ№аӨёаҘҚаӨӨаӨҫаӨ•аҘҚаӨ·аӨ°, аӨёаҘҚаӨҹаҘҲаӨ®аҘҚаӨӘ аӨ”аӨ° аӨҸаӨӮаӨ•аӨ° аӨ№аӨҹ аӨңаӨҫаӨҸаӨӮаӨ—аҘҮаҘӨ"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld гғҡгғјгӮёгҒЁгҖҒгҒқгӮҢгӮүгҒ«зҙҗгҒҘгҒҸзҪІеҗҚгҖҒгӮ№гӮҝгғігғ—гҖҒгӮўгғігӮ«гғјгҒҢеүҠйҷӨгҒ•гӮҢгҒҫгҒҷгҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "иҝҷе°ҶеҲ йҷӨ %lld дёӘйЎөйқўеҸҠе…¶йЎөйқўз»‘е®ҡзҡ„зӯҫеҗҚгҖҒеҚ°з« е’Ңй”ҡзӮ№гҖӮ"
          }
        }
      }
    },
