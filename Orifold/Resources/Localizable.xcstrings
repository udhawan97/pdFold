    "readingCanvas.formatting.matchFormat.tooltip": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Match the nearby PDF text's full style вҖ” font, size, color, alignment, margins and wrapping вҖ” for this edit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Igualar todo el estilo del texto cercano del PDF (fuente, tamaГұo, color, alineaciГіn, mГЎrgenes y ajuste de lГӯnea) para esta ediciГіn."
          }
