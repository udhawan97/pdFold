          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文本已恢复为原始状态。按“完成”以保存。"
          }
        }
      }
    },
    "status.textEdit.selectTextBeforeComment": {
      "extractionState": "manual",
      "localizations": {
