    "petPicker.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick a paper friend to fold along with you. You can switch anytime."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un amigo de papel que te acompañe. Puedes cambiarlo cuando quieras."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisis un ami en papier qui te suivra. Tu peux en changer à tout moment."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने साथ चलने के लिए एक काग़ज़ी दोस्त चुनें। आप कभी भी बदल सकते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一緒に折り進む紙の友だちを選ぼう。いつでも変えられるよ。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "挑一个陪你一起折纸的纸上伙伴。随时可以更换。"
          }
        }
      }
    },
