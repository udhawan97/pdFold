    "guideFeature.review.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track workspace comments, anchored notes, tags, metadata, and search results."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla los comentarios del espacio de trabajo, notas ancladas, etiquetas, metadatos y resultados de búsqueda."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez les commentaires de l’espace de travail, les notes ancrées, les étiquettes, les métadonnées et les résultats de recherche."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वर्कस्पेस की टिप्पणियां, एंकर किए गए नोट्स, टैग, मेटाडेटा और खोज परिणाम ट्रैक करें।"
          }
