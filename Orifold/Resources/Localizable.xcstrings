    "appAbout.description.chores": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Built for the small-but-real PDF chores: combine the pieces, mark what matters, and send out something tidy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "DiseГұado para las tareas pequeГұas pero reales con PDF: combina las partes, marca lo importante y envГӯa algo ordenado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ConГ§u pour les petites tГўches PDF bien rГ©elles : combiner les Г©lГ©ments, marquer lвҖҷessentiel et envoyer quelque chose de soignГ©."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "аӨӣаҘӢаӨҹаҘҮ аӨ®аӨ—аӨ° аӨңаӨјаӨ°аҘӮаӨ°аҘҖ PDF аӨ•аӨҫаӨ®аҘӢаӨӮ аӨ•аҘҮ аӨІаӨҝаӨҸ аӨ¬аӨЁаӨҫаӨҜаӨҫ аӨ—аӨҜаӨҫ: аӨҹаҘҒаӨ•аӨЎаӨјаҘӢаӨӮ аӨ•аҘӢ аӨңаҘӢаӨЎаӨјаҘҮаӨӮ, аӨңаӨјаӨ°аҘӮаӨ°аҘҖ аӨ№аӨҝаӨёаҘҚаӨёаҘӢаӨӮ аӨ•аҘӢ аӨҡаӨҝаӨ№аҘҚаӨЁаӨҝаӨӨ аӨ•аӨ°аҘҮаӨӮ, аӨ”аӨ° аӨ•аҘҒаӨӣ аӨөаҘҚаӨҜаӨөаӨёаҘҚаӨҘаӨҝаӨӨ аӨӯаҘҮаӨңаҘҮаӨӮаҘӨ"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ең°е‘ігҒ гҒ‘гҒ©еӨ§дәӢгҒӘPDFдҪңжҘӯгҒ®гҒҹгӮҒгҒ«гҖӮзҙ жқҗгӮ’гҒҫгҒЁгӮҒгҖҒиҰҒзӮ№гҒ«гғһгғјгӮҜгӮ’д»ҳгҒ‘гҖҒгҒҚгҒЎгӮ“гҒЁж•ҙгҒҲгҒҹгӮӮгҒ®гӮ’йҖҒгӮҠеҮәгҒ—гҒҫгҒ—гӮҮгҒҶгҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "дё“дёәеӨ„зҗҶйӮЈдәӣзҗҗзўҺеҚҙзңҹе®һзҡ„ PDF д»»еҠЎиҖҢз”ҹпјҡеҗҲе№¶еҗ„дёӘйғЁеҲҶгҖҒж ҮеҮәйҮҚзӮ№пјҢеҶҚеҸ‘йҖҒеҮәж•ҙжҙҒзҡ„жҲҗжһңгҖӮ"
          }
        }
      }
    },
    "appAbout.description.noCeremony": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No ceremony. No mystery panels вҖ” just a focused workspace, and a little quiet in the margins."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin rodeos ni paneles misteriosos, solo un espacio de trabajo enfocado y un poco de calma en los mГЎrgenes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sans chichis. Pas de panneaux mystГ©rieux вҖ” juste un espace de travail concentrГ©, et un peu de calme dans les marges."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "аӨ•аҘӢаӨҲ аӨӨаӨҫаӨ®аӨқаӨҫаӨ® аӨЁаӨ№аҘҖаӨӮаҘӨ аӨ•аҘӢаӨҲ аӨ°аӨ№аӨёаҘҚаӨҜаӨ®аӨҜ аӨӘаҘҲаӨЁаӨІ аӨЁаӨ№аҘҖаӨӮ вҖ” аӨ¬аӨё аӨҸаӨ• аӨ•аҘҮаӨӮаӨҰаҘҚаӨ°аӨҝаӨӨ аӨөаӨ°аҘҚаӨ•аӨёаҘҚаӨӘаҘҮаӨё, аӨ”аӨ° аӨҘаҘӢаӨЎаӨјаҘҖ аӨ¶аӨҫаӨӮаӨӨаӨҝаҘӨ"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "дҪҷиЁҲгҒӘжј”еҮәгӮӮгҖҒи¬ҺгӮҒгҒ„гҒҹгғ‘гғҚгғ«гӮӮгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮйӣҶдёӯгҒ§гҒҚгӮӢгғҜгғјгӮҜгӮ№гғҡгғјгӮ№гҒЁгҖҒе°‘гҒ—гҒ®йқҷгҒ‘гҒ•гҒ гҒ‘гҒҢгҒӮгӮҠгҒҫгҒҷгҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "жІЎжңүз№Ғж–ҮзјӣиҠӮпјҢжІЎжңүзҘһз§ҳзҡ„йқўжқҝвҖ”вҖ”еҸӘжңүдёҖдёӘдё“жіЁзҡ„е·ҘдҪңеҢәпјҢе’ҢдёҖзӮ№д»Һе®№зҡ„з•ҷзҷҪгҖӮ"
          }
        }
      }
    },
