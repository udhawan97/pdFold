          }
        }
      }
    },
    "error.editing.invalidAnnotationBounds": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That annotation has invalid geometry and could not be edited safely."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esa anotación tiene una geometría no válida y no pudo editarse de forma segura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette annotation a une géométrie non valide et n'a pas pu être modifiée en toute sécurité."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उस एनोटेशन की ज्यामिति अमान्य है और इसे सुरक्षित रूप से संपादित नहीं किया जा सका।"
          }
        },
