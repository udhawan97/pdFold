        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appliquer Г  cette modification le style complet du texte PDF voisin вҖ” police, taille, couleur, alignement, marges et retour Г  la ligne."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "аӨҮаӨё аӨёаӨӮаӨӘаӨҫаӨҰаӨЁ аӨ•аҘҮ аӨІаӨҝаӨҸ аӨҶаӨё-аӨӘаӨҫаӨё аӨ•аҘҮ PDF аӨҹаҘҮаӨ•аҘҚаӨёаҘҚаӨҹ аӨ•аҘҖ аӨӘаҘӮаӨ°аҘҖ аӨёаҘҚаӨҹаӨҫаӨҮаӨІ вҖ” аӨ«аӨјаҘүаӨЁаҘҚаӨҹ, аӨҶаӨ•аӨҫаӨ°, аӨ°аӨӮаӨ—, аӨ…аӨІаӨҫаӨҮаӨЁаӨ®аҘҮаӨӮаӨҹ, аӨ®аӨҫаӨ°аҘҚаӨңаӨҝаӨЁ аӨ”аӨ° аӨ°аҘҲаӨӘаӨҝаӨӮаӨ— вҖ” аӨёаҘҮ аӨ®аҘҲаӨҡ аӨ•аӨ°аҘҮаӨӮаҘӨ"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "иҝ‘гҒҸгҒ®PDFгғҶгӮӯгӮ№гғҲгҒ®гӮ№гӮҝгӮӨгғ«(гғ•гӮ©гғігғҲгҖҒгӮөгӮӨгӮәгҖҒиүІгҖҒй…ҚзҪ®гҖҒдҪҷзҷҪгҖҒжҠҳгӮҠиҝ”гҒ—)гӮ’гҒ“гҒ®з·ЁйӣҶгҒ«гҒҷгҒ№гҒҰеҗҲгӮҸгҒӣгҒҫгҒҷгҖӮ"
          }
