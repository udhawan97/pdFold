    "error.export.documentTooLargeForDecoration": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not decorate this PDF because it is too large to process safely. Export without decorations, or split the PDF into smaller files."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo decorar este PDF porque es demasiado grande para procesarlo de forma segura. Exporta sin decoraciones, o divide el PDF en archivos más pequeños."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu décorer ce PDF car il est trop volumineux pour être traité en toute sécurité. Exportez sans décorations ou divisez le PDF en fichiers plus petits."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold इस PDF को सजा नहीं सका क्योंकि यह सुरक्षित रूप से प्रोसेस करने के लिए बहुत बड़ा है। बिना सजावट के निर्यात करें, या PDF को छोटी फ़ाइलों में विभाजित करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OrifoldはこのPDFを安全に処理するには大きすぎるため、装飾できませんでした。装飾なしで書き出すか、PDFをより小さいファイルに分割してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法为该 PDF 添加装饰，因为文件过大，无法安全处理。请不添加装饰导出，或将该 PDF 拆分为更小的文件。"
          }
        }
      }
    },
    "error.export.emptyDocument": {
