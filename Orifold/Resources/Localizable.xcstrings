        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold аӨ•аҘҒаӨӣ аӨӘаҘҮаӨңаҘӢаӨӮ аӨ•аҘӢ аӨөаӨҫаӨӘаӨё аӨЁаӨ№аҘҖаӨӮ аӨІаӨҫ аӨёаӨ•аӨҫ; аӨүаӨЁаӨ•аҘҮ аӨёаӨӮаӨӘаӨҫаӨҰаӨЁ аӨ•аҘӢ аӨөаҘҲаӨёаҘҮ аӨ№аҘҖ аӨӣаҘӢаӨЎаӨј аӨҰаӨҝаӨҜаӨҫ аӨ—аӨҜаӨҫ аӨҘаӨҫаҘӨ"
