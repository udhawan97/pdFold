    "appAbout.description.chores": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Built for the small-but-real PDF chores: combine the pieces, mark what matters, and send out something tidy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Diseñado para las tareas pequeñas pero reales con PDF: combina las partes, marca lo importante y envía algo ordenado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conçu pour les petites tâches PDF bien réelles : combiner les éléments, marquer l’essentiel et envoyer quelque chose de soigné."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "छोटे मगर ज़रूरी PDF कामों के लिए बनाया गया: टुकड़ों को जोड़ें, ज़रूरी हिस्सों को चिह्नित करें, और कुछ व्यवस्थित भेजें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "地味だけど大事なPDF作業のために。素材をまとめ、要点にマークを付け、きちんと整えたものを送り出しましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "专为处理那些琐碎却真实的 PDF 任务而生：合并各个部分、标出重点，再发送出整洁的成果。"
          }
        }
      }
    },
    "appAbout.description.noCeremony": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No ceremony. No mystery panels — just a focused workspace, and a little quiet in the margins."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin rodeos ni paneles misteriosos, solo un espacio de trabajo enfocado y un poco de calma en los márgenes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sans chichis. Pas de panneaux mystérieux — juste un espace de travail concentré, et un peu de calme dans les marges."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई तामझाम नहीं। कोई रहस्यमय पैनल नहीं — बस एक केंद्रित वर्कस्पेस, और थोड़ी शांति।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "余計な演出も、謎めいたパネルもありません。集中できるワークスペースと、少しの静けさだけがあります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有繁文缛节，没有神秘的面板——只有一个专注的工作区，和一点从容的留白。"
          }
        }
      }
    },
