    "annotationTool.ink.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Draw freehand marks on the page."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dibuja marcas a mano alzada en la página."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessinez des marques à main levée sur la page."
          }
