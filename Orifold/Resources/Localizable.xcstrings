    "status.signature.timestampUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Timestamp authority unavailable; exported as PAdES B-B without trusted timestamp."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La autoridad de sellado de tiempo no está disponible; se exportó como PAdES B-B sin marca de tiempo verificada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorité d’horodatage indisponible ; exporté au format PAdES B-B sans horodatage de confiance."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टाइमस्टैम्प प्राधिकरण उपलब्ध नहीं है; भरोसेमंद टाइमस्टैम्प के बिना PAdES B-B के रूप में एक्सपोर्ट किया गया।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "时间戳颁发机构不可用；已导出为不含可信时间戳的 PAdES B-B。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タイムスタンプ局を利用できないため、信頼できるタイムスタンプなしのPAdES B-Bとして書き出しました。"
          }
        }
      }
    },
