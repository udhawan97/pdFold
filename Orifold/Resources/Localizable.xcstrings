    "pet.species.cat.tagline": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Origami cat · clever, composed, quietly in charge."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gato de origami · astuto, sereno, al mando en silencio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat en origami · malin, posé, aux commandes en silence."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ओरिगामी बिल्ली · चतुर, शांत, चुपचाप सब संभालने वाली।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "折り紙の猫 · 賢く、落ち着いていて、静かに仕切る。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "折纸猫 · 聪慧、沉着，不动声色地掌控全局。"
          }
        }
      }
    },
