    "status.readerMode.on": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reader Mode is on. Text editing and signing are hidden; study tools stay available."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo lectura está activado. La edición de texto y la firma están ocultas; las herramientas de estudio siguen disponibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le mode lecture est activé. La modification du texte et la signature sont masquées ; les outils d’étude restent disponibles."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रीडर मोड चालू है। टेक्स्ट संपादन और हस्ताक्षर छिपे हुए हैं; स्टडी टूल उपलब्ध रहते हैं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阅读模式已开启。文本编辑和签名功能已隐藏，学习工具仍可使用。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リーダーモードがオンです。テキスト編集と署名は非表示になりますが、学習ツールは引き続き利用できます。"
          }
        }
      }
    },
    "status.readerMode.off": {
      "extractionState": "manual",
      "localizations": {
