    "readingCanvas.formatting.copyFormat.tooltip": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy the nearby PDF text's style so you can paste it onto another text edit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiar el estilo del texto cercano del PDF para pegarlo en otra edición de texto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Copier le style du texte PDF voisin pour le coller sur une autre modification de texte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आस-पास के PDF टेक्स्ट की स्टाइल कॉपी करें ताकि आप उसे किसी और टेक्स्ट संपादन पर पेस्ट कर सकें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拷贝附近 PDF 文本的样式，以便粘贴到其他文本编辑中。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "近くのPDFテキストのスタイルをコピーして、別のテキスト編集に貼り付けられるようにします。"
          }
        }
      }
    },
    "readingCanvas.formatting.pasteFormat.button": {
