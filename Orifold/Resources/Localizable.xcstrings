          }
        }
      }
    },
    "error.pageEdit.restoreFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not restore that page. The edit was left in place."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo restaurar esa página. La edición se mantuvo tal cual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n’a pas pu restaurer cette page. La modification a été conservée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold उस पेज को वापस नहीं ला सका। संपादन को वैसे ही छोड़ दिया गया था।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはそのページを復元できませんでした。編集内容はそのまま残されています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法恢复该页面，编辑内容已保留。"
          }
        }
      }
    },
    "error.pageEdit.restoreSomeFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not restore some pages; their edits were left in place."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo restaurar algunas páginas; sus ediciones se mantuvieron tal cual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
