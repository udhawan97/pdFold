    "pet.event.edit.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Editing a PDF? Bold. They said it couldn't be done."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Editando un PDF? Qué atrevido. Decían que no se podía."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Modifier un PDF ? Audacieux. On disait que c’était impossible."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "PDF संपादित कर रहे हैं? बहादुरी है। कहा जाता था कि यह हो ही नहीं सकता।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PDFを編集? 大胆ですね。無理だと言われていたのに。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "编辑 PDF？真大胆。他们都说这做不到呢。"
          }
        }
      }
    },
    "pet.event.edit.2": {
      "extractionState": "manual",
      "localizations": {
