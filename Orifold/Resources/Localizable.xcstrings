    "pet.feedback.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Psst — Orifold is brand new. The developer would genuinely love your thoughts: umangdhawan97@gmail.com"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Psst, Orifold es totalmente nuevo. Al desarrollador le encantaría conocer tu opinión: umangdhawan97@gmail.com"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Psst — Orifold est tout nouveau. Le développeur adorerait sincèrement avoir votre avis : umangdhawan97@gmail.com"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सुनिए — Orifold बिल्कुल नया है। डेवलपर को वाकई आपकी राय पसंद आएगी: umangdhawan97@gmail.com"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "悄悄说一句——Orifold 才刚刚起步。开发者真心想听听你的想法：umangdhawan97@gmail.com"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ちょっと一言。Orifoldは生まれたばかりです。開発者は本気であなたの感想を聞きたがっています: umangdhawan97@gmail.com"
          }
        }
      }
    },
    "pet.feedback.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enjoying this? Tell the human who made it: umangdhawan97@gmail.com — they read every message."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Te está gustando? Cuéntaselo a quien lo creó: umangdhawan97@gmail.com — lee todos los mensajes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous appréciez l’expérience ? Dites-le à la personne qui l’a créée : umangdhawan97@gmail.com — chaque message est lu."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह पसंद आ रहा है? इसे बनाने वाले इंसान को बताएं: umangdhawan97@gmail.com — वे हर संदेश पढ़ते हैं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用得还开心吗？告诉做出它的那个人吧：umangdhawan97@gmail.com——每条消息都会被认真读到。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "楽しんでいただけていますか? 作った人に伝えてあげてください: umangdhawan97@gmail.com — すべてのメッセージに目を通しています。"
          }
        }
      }
    },
    "pet.feedback.3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You've done real work today. Worth a quick note? umangdhawan97@gmail.com"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoy hiciste un trabajo de verdad. ¿Vale la pena una nota rápida? umangdhawan97@gmail.com"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez bien travaillé aujourd’hui. Ça vaut bien un petit mot ? umangdhawan97@gmail.com"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपने आज वाकई अच्छा काम किया है। एक छोटा नोट भेजना चाहेंगे? umangdhawan97@gmail.com"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今天做了不少实事呢。要不要留句话？umangdhawan97@gmail.com"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日はよく頑張りましたね。一言メモを残してみませんか? umangdhawan97@gmail.com"
          }
        }
      }
    },
    "pet.inspiration.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Progress counts, even when it arrives wearing a loading spinner."
