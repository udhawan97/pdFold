    "signaturePalette.digital.hint.caIssued": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CA-issued signatures are trusted automatically by readers that trust the issuing authority."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las firmas emitidas por una CA son de confianza automática para los lectores que confían en la autoridad emisora."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les signatures émises par une AC sont automatiquement approuvées par les lecteurs qui font confiance à l'autorité émettrice."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "CA-जारी हस्ताक्षर उन रीडरों द्वारा स्वतः विश्वसनीय माने जाते हैं जो जारीकर्ता प्राधिकरण पर भरोसा करते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CA発行の署名は、発行機関を信頼するリーダーによって自動的に信頼されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CA 签发的签名会被信任该颁发机构的阅读器自动信任。"
          }
        }
      }
    },
    "signaturePalette.digital.hint.chooseIdentity": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose or create a Digital ID to sign with."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige o crea una identificación digital con la que firmar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez ou créez une identité numérique pour signer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हस्ताक्षर करने के लिए एक डिजिटल आईडी चुनें या बनाएं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "署名に使用するデジタルIDを選択または作成してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择或创建用于签名的数字身份证明。"
          }
        }
      }
    },
    "signaturePalette.digital.hint.expired": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This certificate has expired. Choose another Digital ID or create a new one."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este certificado ha caducado. Elige otra identificación digital o crea una nueva."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce certificat a expiré. Choisissez une autre identité numérique ou créez-en une nouvelle."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह प्रमाणपत्र समाप्त हो चुका है। कोई अन्य डिजिटल आईडी चुनें या नई बनाएं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この証明書は有効期限が切れています。別のデジタルIDを選ぶか、新しく作成してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此证书已过期。请选择其他数字身份证明或新建一个。"
          }
        }
      }
    },
    "signaturePalette.digital.hint.selfSigned": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This PDF will contain a cryptographic signature. Recipients may see “identity not verified” unless they trust your certificate."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este PDF contendrá una firma criptográfica. Los destinatarios pueden ver “identidad no verificada” a menos que confíen en tu certificado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce PDF contiendra une signature cryptographique. Les destinataires peuvent voir « identité non vérifiée » à moins qu'ils ne fassent confiance à votre certificat."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस PDF में एक क्रिप्टोग्राफिक हस्ताक्षर होगा। जब तक प्राप्तकर्ता आपके प्रमाणपत्र पर भरोसा नहीं करते, उन्हें “पहचान असत्यापित” दिख सकता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このPDFには暗号署名が含まれます。証明書を信頼しない限り、受信者には「本人確認されていません」と表示される場合があります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此 PDF 将包含加密签名。除非收件人信任您的证书，否则可能会看到“身份未验证”。"
          }
        }
      }
    },
    "signaturePalette.digital.location.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
