    "error.editing.colorConversionFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not preserve the original text color, so it used the default document text color."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo conservar el color de texto original, por lo que usó el color de texto predeterminado del documento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu conserver la couleur de texte d'origine ; il a donc utilisé la couleur de texte par défaut du document."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold मूल टेक्स्ट रंग बनाए नहीं रख सका, इसलिए इसने दस्तावेज़ के डिफ़ॉल्ट टेक्स्ट रंग का उपयोग किया।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは元のテキストカラーを維持できなかったため、文書の既定のテキストカラーを使用しました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法保留原始文本颜色，因此使用了文档默认文本颜色。"
          }
        }
      }
    },
    "error.editing.emptySelection": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not find editable text at that location."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo encontrar texto editable en esa ubicación."
          }
