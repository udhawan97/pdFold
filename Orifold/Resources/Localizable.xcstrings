    "annotationTool.signature.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Place a saved signature on the page."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloca una firma guardada en la página."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Placez une signature enregistrée sur la page."
          }
        },
        "hi": {
