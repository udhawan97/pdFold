        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez la barre d’outils pour surligner,\\najouter des notes ou dessiner."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हाइलाइट करने,\\nनोट जोड़ने, या चित्र बनाने के लिए टूलबार का उपयोग करें।"
          }
        },
        "ja": {
          "stringUnit": {
