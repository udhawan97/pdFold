          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold घटाए गए PDF को सत्यापित नहीं कर सका। फ़ाइल आकार घटाए बिना निर्यात करने का प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは縮小後のPDFを検証できませんでした。ファイルサイズを縮小せずに書き出してみてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
