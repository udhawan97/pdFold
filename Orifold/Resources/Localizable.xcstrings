    "documentComfort.pageMode.info": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recolors how the page looks on screen — dark, sepia, dim, and more. Your file and exports stay unchanged."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia el color de la página en pantalla: oscuro, sepia, tenue y más. Tu archivo y las exportaciones no cambian."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Change l'aspect de la page à l'écran — sombre, sépia, tamisé, etc. Votre fichier et les exports restent inchangés."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्क्रीन पर पेज का रंग बदलता है — डार्क, सीपिया, डिम आदि। आपकी फ़ाइल और एक्सपोर्ट अपरिवर्तित रहते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画面上のページの色合いを変えます（ダーク、セピア、ディムなど）。ファイルや書き出しは変わりません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "改变页面在屏幕上的显示色调（深色、护眼黄、暗淡等），文件和导出内容保持不变。"
          }
        }
      }
    },
