    "signaturePalette.digital.signAndExport.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cryptographically signs the exported PDF. This cannot be undone — any later edit will invalidate the signature."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Firma criptográficamente el PDF exportado. Esto no se puede deshacer: cualquier edición posterior invalidará la firma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Signe cryptographiquement le PDF exporté. Cette action est irréversible : toute modification ultérieure invalidera la signature."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "निर्यातित PDF पर क्रिप्टोग्राफिक रूप से हस्ताक्षर करता है। इसे पूर्ववत नहीं किया जा सकता — कोई भी बाद का संपादन हस्ताक्षर को अमान्य कर देगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エクスポートされたPDFに暗号署名を行います。この操作は元に戻せません。後の編集は署名を無効にします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对导出的 PDF 进行加密签名。此操作无法撤销——之后的任何编辑都会使签名失效。"
          }
        }
      }
    },
    "signaturePalette.digital.signerName.placeholder": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Signer name"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nombre del firmante"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nom du signataire"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हस्ताक्षरकर्ता का नाम"
          }
        },
        "ja": {
