    "guideFeature.ocr.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make scanned pages searchable before sharing or archiving."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz que las páginas escaneadas sean buscables antes de compartirlas o archivarlas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rendez les pages numérisées consultables avant de les partager ou de les archiver."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साझा करने या संग्रहित करने से पहले स्कैन किए गए पेजों को खोजने योग्य बनाएं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "共有や保存の前に、スキャンしたページを検索可能にします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在分享或存档之前，使扫描页面可被搜索。"
          }
        }
      }
    },
    "guideFeature.ocr.title": {
      "extractionState": "manual",
