      }
    },
    "pet.event.tag.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tagged. Organized people are just tidy worriers with labels."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Etiquetado. Las personas organizadas solo son personas ansiosas con etiquetas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Étiqueté. Les gens organisés sont juste des inquiets méticuleux avec des étiquettes."
          }
