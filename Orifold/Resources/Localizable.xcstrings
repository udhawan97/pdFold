    "pet.species.cat.tagline": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Origami Siberian · curious, clever, elegant, quietly in charge."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Siberiano de origami · curiosa, inteligente, elegante, discretamente al mando."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sibérien en origami · curieuse, futée, élégante, discrètement aux commandes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ओरिगामी साइबेरियन · जिज्ञासु, चतुर, सुरुचिपूर्ण, चुपचाप प्रभारी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "折り紙のシベリアン猫・好奇心旺盛で賢く優雅、静かに仕切り屋。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "折纸西伯利亚猫 · 好奇、聪慧、优雅，悄悄地说了算。"
          }
        }
      }
    },
