    "guideFeature.import.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drop in up to 50 PDFs, Word, HTML, Markdown, text, data files, or images at once."
          }
        },
        "es": {
