    "status.textEdit.pastedStyleOntoEdit": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasted copied style onto this edit. Press Done to save it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se pegó el estilo copiado en esta edición. Pulsa Listo para guardarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Style copié collé sur cette modification. Appuyez sur Terminé pour enregistrer."
          }
