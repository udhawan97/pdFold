          }
        }
      }
    },
    "error.export.writeEmptyFile": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold wrote an empty file, so the export was discarded. Check that the destination has free space and permission to write, then try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold escribió un archivo vacío, por lo que se descartó la exportación. Verifica que el destino tenga espacio libre y permiso de escritura, luego inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold a écrit un fichier vide ; l'exportation a donc été annulée. Vérifiez que la destination dispose d'espace libre et de l'autorisation d'écriture, puis réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold ने एक खाली फ़ाइल लिखी, इसलिए निर्यात को छोड़ दिया गया। जाँचें कि गंतव्य में खाली स्थान और लिखने की अनुमति है, फिर फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは空のファイルを書き込んだため、書き出しは破棄されました。保存先に空き容量と書き込み権限があることを確認して、再試行してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 写入了一个空文件，因此该导出已被丢弃。请确认目标位置有可用空间和写入权限，然后重试。"
          }
        }
      }
    },
    "error.export.writeFileNotFound": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not confirm the export was written to disk. The destination folder may have rejected the write -- check permissions and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo confirmar que la exportación se escribió en el disco. Es posible que la carpeta de destino haya rechazado la escritura; verifica los permisos e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu confirmer que l'exportation a été écrite sur le disque. Le dossier de destination a peut-être refusé l'écriture ; vérifiez les autorisations et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold यह पुष्टि नहीं कर सका कि निर्यात डिस्क पर लिखा गया। हो सकता है गंतव्य फ़ोल्डर ने लेखन को अस्वीकार कर दिया हो; अनुमतियाँ जाँचें और फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは書き出しがディスクに書き込まれたことを確認できませんでした。保存先フォルダが書き込みを拒否した可能性があります。権限を確認して再試行してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法确认导出内容已写入磁盘。目标文件夹可能拒绝了写入操作，请检查权限后重试。"
          }
        }
      }
    },
    "error.form.invalidPDF": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not lock the form answers in this PDF. Reopen the document and try exporting again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo bloquear las respuestas del formulario en este PDF. Vuelve a abrir el documento e intenta exportar de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n’a pas pu verrouiller les réponses du formulaire dans ce PDF. Rouvrez le document et réessayez d’exporter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold इस PDF में फ़ॉर्म के जवाबों को लॉक नहीं कर सका। दस्तावेज़ को फिर से खोलें और फिर से एक्सपोर्ट करने की कोशिश करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OrifoldはこのPDFのフォーム入力内容を固定できませんでした。書類を開き直してもう一度書き出してみてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法锁定此 PDF 中的表单答案。请重新打开文档后再次导出。"
          }
        }
      }
    },
    "error.form.pageOrderMismatch": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not match form fields to the current page order. Reopen the document and try exporting again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo hacer coincidir los campos del formulario con el orden de página actual. Vuelve a abrir el documento e intenta exportar de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n’a pas pu associer les champs du formulaire à l’ordre actuel des pages. Rouvrez le document et réessayez d’exporter."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold फ़ॉर्म फ़ील्ड को मौजूदा पेज क्रम से मैच नहीं कर सका। दस्तावेज़ को फिर से खोलें और फिर से एक्सपोर्ट करने की कोशिश करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはフォームフィールドを現在のページ順序に一致させられませんでした。書類を開き直してもう一度書き出してみてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法将表单字段与当前页面顺序匹配。请重新打开文档后再次导出。"
          }
        }
      }
    },
    "error.import.binaryDataMislabelledAsText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This looks like binary data, not a supported text document. Check the file type and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto parece ser datos binarios, no un documento de texto compatible. Verifica el tipo de archivo e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela ressemble à des données binaires, pas à un document texte pris en charge. Vérifiez le type de fichier et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह बाइनरी डेटा जैसा लगता है, समर्थित टेक्स्ट दस्तावेज़ नहीं। फ़ाइल प्रकार जाँचें और फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これはサポートされているテキスト文書ではなく、バイナリデータのようです。ファイル形式を確認してもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这看起来是二进制数据，而非受支持的文本文档。请检查文件类型后重试。"
          }
        }
      }
    },
    "error.import.corruptOrEncrypted": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This PDF may be damaged or password-protected."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este PDF puede estar dañado o protegido con contraseña."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce PDF est peut-être endommagé ou protégé par un mot de passe."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह PDF क्षतिग्रस्त या पासवर्ड-सुरक्षित हो सकता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このPDFは破損しているか、パスワードで保護されている可能性があります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此 PDF 可能已损坏或受密码保护。"
          }
        }
      }
    },
    "error.import.emptyDocument": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file is empty."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo está vacío."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier est vide."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल खाली है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルが空です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该文件为空。"
          }
        }
      }
    },
    "error.import.exportTempMissing": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The edited file could not be found. Please export again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo encontrar el archivo editado. Vuelve a exportarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier modifié est introuvable. Veuillez l'exporter à nouveau."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "संपादित फ़ाइल नहीं मिली। कृपया पुनः निर्यात करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "編集済みファイルが見つかりませんでした。もう一度エクスポートしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "找不到已编辑的文件。请重新导出。"
          }
        }
      }
    },
    "error.import.fileMissing": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This file was moved, renamed, or deleted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este archivo se movió, renombró o eliminó."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce fichier a été déplacé, renommé ou supprimé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह फ़ाइल स्थानांतरित, नाम-परिवर्तित या हटा दी गई थी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このファイルは移動、名前変更、または削除されました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此文件已被移动、重命名或删除。"
          }
        }
      }
    },
    "error.import.fileTooLarge": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This file is too large for Orifold to open safely."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este archivo es demasiado grande para que Orifold lo abra de forma segura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce fichier est trop volumineux pour qu'Orifold puisse l'ouvrir en toute sécurité."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह फ़ाइल Orifold के सुरक्षित रूप से खोलने के लिए बहुत बड़ी है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このファイルはOrifoldが安全に開くには大きすぎます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此文件太大，Orifold 无法安全打开。"
          }
        }
      }
    },
    "error.import.iCloudNotDownloaded": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This file is stored in iCloud and may need to finish downloading first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este archivo está almacenado en iCloud y puede que primero deba terminar de descargarse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce fichier est stocké dans iCloud et peut nécessiter de terminer son téléchargement d'abord."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह फ़ाइल iCloud में संग्रहीत है और पहले इसे पूरी तरह डाउनलोड होने की आवश्यकता हो सकती है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このファイルはiCloudに保存されており、先にダウンロードを完了する必要がある場合があります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此文件存储在 iCloud 中，可能需要先完成下载。"
          }
        }
      }
    },
    "error.import.passwordProtected": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This PDF is password-protected. Add it to an open workspace with Add Files or drag-and-drop so Orifold can prompt for the password."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este PDF está protegido con contraseña. Agrégalo a un espacio de trabajo abierto con Agregar archivos o arrastrándolo, para que Orifold pueda solicitar la contraseña."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce PDF est protégé par un mot de passe. Ajoutez-le à un espace de travail ouvert via Ajouter des fichiers ou par glisser-déposer afin qu'Orifold puisse demander le mot de passe."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह PDF पासवर्ड-सुरक्षित है। इसे किसी खुले वर्कस्पेस में फ़ाइलें जोड़ें या खींचकर छोड़ें से जोड़ें, ताकि Orifold पासवर्ड माँग सके।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このPDFはパスワードで保護されています。「ファイルを追加」またはドラッグ＆ドロップで開いているワークスペースに追加すると、Orifoldがパスワードの入力を求めます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此 PDF 已设置密码保护。请通过“添加文件”或拖放将其加入已打开的工作区，以便 Orifold 提示输入密码。"
          }
        }
      }
    },
    "error.import.permissionDenied": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no longer has permission to access this file. Please reselect it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold ya no tiene permiso para acceder a este archivo. Vuelve a seleccionarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a plus la permission d'accéder à ce fichier. Veuillez le sélectionner à nouveau."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold के पास अब इस फ़ाइल तक पहुँचने की अनुमति नहीं है। कृपया इसे फिर से चुनें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはこのファイルにアクセスする権限がなくなりました。再度選択してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 不再有权访问此文件。请重新选择该文件。"
          }
        }
      }
    },
    "error.import.preparePDFForSaving": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not prepare this file for saving. Try exporting it to PDF first, then import the exported file."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo preparar este archivo para guardarlo. Intenta exportarlo primero a PDF y luego importa el archivo exportado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu préparer ce fichier pour l'enregistrement. Essayez de l'exporter d'abord en PDF, puis importez le fichier exporté."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold इस फ़ाइल को सहेजने के लिए तैयार नहीं कर सका। पहले इसे PDF में एक्सपोर्ट करने का प्रयास करें, फिर एक्सपोर्ट की गई फ़ाइल आयात करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはこのファイルを保存用に準備できませんでした。まずPDFとして書き出してから、その書き出したファイルを読み込んでください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法为保存准备此文件。请先将其导出为 PDF，然后再导入导出的文件。"
          }
        }
      }
    },
    "error.import.renderTimedOut": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file took too long to render. Try exporting it to PDF from its original app, then import the PDF."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo tardó demasiado en procesarse. Intenta exportarlo a PDF desde su aplicación original y luego importa el PDF."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier a mis trop de temps à s'afficher. Essayez de l'exporter en PDF depuis son application d'origine, puis importez le PDF."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल को रेंडर होने में बहुत समय लगा। इसे मूल ऐप से PDF में एक्सपोर्ट करने का प्रयास करें, फिर PDF आयात करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルのレンダリングに時間がかかりすぎました。元のアプリからPDFとして書き出してから、そのPDFを読み込んでください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文件渲染耗时过长。请尝试先在原始应用中将其导出为 PDF，然后再导入该 PDF。"
          }
        }
      }
    },
    "error.import.renderingFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file opened, but Orifold could not render it into a PDF."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo se abrió, pero Orifold no pudo convertirlo en un PDF."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier s'est ouvert, mais Orifold n'a pas pu le convertir en PDF."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल खुल गई, लेकिन Orifold इसे PDF में रेंडर नहीं कर सका।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルは開けましたが、OrifoldがPDFに変換できませんでした。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文件已打开，但 Orifold 无法将其渲染为 PDF。"
          }
        }
      }
    },
    "error.import.staleBookmark": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Access expired. Please choose the file again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso ha caducado. Vuelve a elegir el archivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès a expiré. Veuillez choisir le fichier à nouveau."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहुँच समाप्त हो गई है। कृपया फ़ाइल फिर से चुनें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセスの有効期限が切れました。もう一度ファイルを選択してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "访问已过期。请重新选择该文件。"
          }
        }
      }
    },
    "error.import.unreadableDocument": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file could not be read. It may be corrupt, encrypted, or incomplete."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo leer el archivo. Puede estar dañado, cifrado o incompleto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier n'a pas pu être lu. Il est peut-être corrompu, chiffré ou incomplet."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइल पढ़ी नहीं जा सकी। यह ख़राब, एन्क्रिप्टेड या अधूरी हो सकती है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルを読み込めませんでした。破損、暗号化、または不完全な可能性があります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法读取该文件，它可能已损坏、已加密或不完整。"
          }
        }
      }
    },
    "error.import.unreadableSavedMember": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Part of this workspace couldn’t be read and was removed from view. The unreadable file’s data is preserved in the document, but its pages can’t be shown or edited."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo leer una parte de este espacio de trabajo y se quitó de la vista. Los datos del archivo ilegible se conservan en el documento, pero sus páginas no se pueden mostrar ni editar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une partie de cet espace de travail n’a pas pu être lue et a été retirée de l’affichage. Les données du fichier illisible sont conservées dans le document, mais ses pages ne peuvent pas être affichées ni modifiées."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस वर्कस्पेस का एक हिस्सा पढ़ा नहीं जा सका और उसे दृश्य से हटा दिया गया। अपठनीय फ़ाइल का डेटा दस्तावेज़ में सुरक्षित है, लेकिन उसके पृष्ठ दिखाए या संपादित नहीं किए जा सकते।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このワークスペースの一部を読み込めなかったため、表示から除外しました。読み込めなかったファイルのデータは書類内に保持されていますが、そのページの表示や編集はできません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法读取此工作区的一部分，已将其从视图中移除。无法读取的文件数据仍保留在文档中，但其页面无法显示或编辑。"
          }
        }
      }
    },
    "error.import.unsupportedFileType": {
      "extractionState": "manual",
      "localizations": {
