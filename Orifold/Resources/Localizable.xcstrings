    "object.editability.artifact.lowConfidence": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This looks like a decorative element, but Orifold isn’t fully sure it’s a separate object. Edits may affect nearby graphics — check the result before saving."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto parece un elemento decorativo, pero Orifold no está del todo seguro de que sea un objeto separado. Las ediciones pueden afectar a gráficos cercanos; revisa el resultado antes de guardar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela ressemble à un élément décoratif, mais Orifold n’est pas totalement sûr qu’il s’agisse d’un objet distinct. Les modifications peuvent affecter les graphiques voisins — vérifiez le résultat avant d’enregistrer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह एक सजावटी तत्व जैसा दिखता है, पर Orifold पूरी तरह निश्चित नहीं है कि यह अलग ऑब्जेक्ट है। संपादन आस-पास के ग्राफ़िक्स को प्रभावित कर सकते हैं — सहेजने से पहले परिणाम जाँचें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これは装飾要素のように見えますが、独立したオブジェクトかどうかOrifoldは完全には確信していません。編集が近くのグラフィックに影響する場合があります。保存前に結果を確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这看起来像装饰元素，但 Orifold 无法完全确定它是独立对象。编辑可能影响附近的图形——保存前请检查结果。"
          }
        }
      }
    },
    "object.editability.editable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "editable"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "editable"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "modifiable"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "संपादन योग्य"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "編集可能"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可编辑"
          }
        }
      }
    },
    "object.editability.formWidget.restricted": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is a fillable form field. You can reposition or remove it, but its contents and duplication are managed in the form tools to avoid breaking the form."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este es un campo de formulario rellenable. Puedes reposicionarlo o quitarlo, pero su contenido y duplicación se gestionan en las herramientas de formulario para no dañar el formulario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il s’agit d’un champ de formulaire à remplir. Vous pouvez le repositionner ou le supprimer, mais son contenu et sa duplication sont gérés dans les outils de formulaire pour ne pas casser le formulaire."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह एक भरने योग्य फ़ॉर्म फ़ील्ड है। आप इसे पुनः स्थान दे सकते हैं या हटा सकते हैं, लेकिन फ़ॉर्म को टूटने से बचाने के लिए इसकी सामग्री और नकल फ़ॉर्म टूल में प्रबंधित होती है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これは入力可能なフォームフィールドです。位置の変更や削除はできますが、内容や複製はフォームを壊さないためフォームツールで管理されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这是一个可填写的表单字段。你可以重新定位或删除它，但为避免破坏表单，其内容和复制由表单工具管理。"
          }
        }
      }
    },
    "object.editability.formXObject.instanceOnly": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is a reused graphic placed in several spots. You can move, resize, or remove this copy — but its interior look-and-feel can’t be changed yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este es un gráfico reutilizado colocado en varios lugares. Puedes mover, redimensionar o quitar esta copia, pero su aspecto interior aún no se puede cambiar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il s’agit d’un graphique réutilisé placé à plusieurs endroits. Vous pouvez déplacer, redimensionner ou supprimer cette copie, mais son apparence interne ne peut pas encore être modifiée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह एक पुनः उपयोग किया गया ग्राफ़िक है जो कई जगह रखा गया है। आप इस प्रति को ले जा सकते हैं, आकार बदल सकते हैं या हटा सकते हैं — लेकिन इसका आंतरिक रूप अभी नहीं बदला जा सकता।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これは複数の場所に配置された再利用グラフィックです。このコピーの移動・サイズ変更・削除はできますが、内部の見た目はまだ変更できません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这是一个在多处使用的重复图形。你可以移动、调整大小或删除此副本——但其内部外观暂时无法更改。"
          }
        }
      }
    },
    "object.editability.formXObject.sourceDeferred": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Changing this reused graphic everywhere at once isn’t available yet — edit an individual copy instead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambiar este gráfico reutilizado en todas partes a la vez aún no está disponible; edita una copia individual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Modifier ce graphique réutilisé partout à la fois n’est pas encore possible — modifiez plutôt une copie individuelle."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस पुनः उपयोग किए गए ग्राफ़िक को एक साथ हर जगह बदलना अभी उपलब्ध नहीं है — इसके बजाय किसी एक प्रति को संपादित करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この再利用グラフィックを一度にすべて変更する機能はまだ利用できません。個別のコピーを編集してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂不支持一次性更改所有位置的此重复图形——请改为编辑单个副本。"
          }
        }
      }
    },
    "object.editability.group.hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Selected a group of %lld lines. Edits apply to all of them — click again to pick a single line."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se seleccionó un grupo de %lld líneas. Las ediciones se aplican a todas; haz clic de nuevo para elegir una sola línea."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Groupe de %lld lignes sélectionné. Les modifications s’appliquent à toutes — cliquez à nouveau pour choisir une seule ligne."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld रेखाओं का समूह चुना गया। संपादन सभी पर लागू होते हैं — किसी एक रेखा को चुनने के लिए फिर से क्लिक करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld本の線のグループを選択しました。編集はすべてに適用されます。もう一度クリックすると1本の線を選べます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已选择一组 %lld 条线。编辑将应用于全部——再次点击可选择单条线。"
          }
        }
      }
    },
    "object.editability.image.styleUnsupported": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stroke and fill styling don’t apply to images. You can move, resize, rotate, replace, or delete this picture."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El estilo de trazo y relleno no se aplica a las imágenes. Puedes mover, redimensionar, rotar, reemplazar o eliminar esta imagen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les styles de contour et de remplissage ne s’appliquent pas aux images. Vous pouvez déplacer, redimensionner, faire pivoter, remplacer ou supprimer cette image."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्ट्रोक और भरण शैली छवियों पर लागू नहीं होती। आप इस चित्र को ले जा सकते हैं, आकार बदल सकते हैं, घुमा सकते हैं, बदल सकते हैं या हटा सकते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "線と塗りのスタイルは画像には適用されません。この画像は移動・サイズ変更・回転・置き換え・削除できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "描边和填充样式不适用于图像。你可以移动、调整大小、旋转、替换或删除这张图片。"
          }
        }
      }
    },
    "object.editability.locked": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This document restricts edits to its content. Remove the restriction (or the signature) to edit this object."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este documento restringe las ediciones de su contenido. Quita la restricción (o la firma) para editar este objeto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce document restreint les modifications de son contenu. Supprimez la restriction (ou la signature) pour modifier cet objet."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह दस्तावेज़ अपनी सामग्री में संपादन प्रतिबंधित करता है। इस ऑब्जेक्ट को संपादित करने के लिए प्रतिबंध (या हस्ताक्षर) हटाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この書類は内容の編集を制限しています。このオブジェクトを編集するには制限（または署名）を解除してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此文档限制对其内容的编辑。请移除限制（或签名）以编辑此对象。"
          }
        }
      }
    },
    "object.editability.raster.regionOnly": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This area is part of a scanned or flattened image with no separate objects. You can cover or replace a region, but individual shapes here can’t be moved or restyled."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta zona es parte de una imagen escaneada o aplanada sin objetos separados. Puedes cubrir o reemplazar una región, pero las formas individuales aquí no se pueden mover ni recolorear."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette zone fait partie d’une image numérisée ou aplatie sans objets distincts. Vous pouvez couvrir ou remplacer une région, mais les formes individuelles ne peuvent pas être déplacées ni restylées."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह क्षेत्र बिना अलग ऑब्जेक्ट वाली स्कैन या समतल छवि का हिस्सा है। आप किसी क्षेत्र को ढक या बदल सकते हैं, पर यहाँ अलग-अलग आकृतियों को न हिलाया न पुनः शैलीबद्ध किया जा सकता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この領域は個別のオブジェクトを持たないスキャンまたは統合された画像の一部です。領域を覆ったり置き換えたりはできますが、個々の図形の移動やスタイル変更はできません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该区域属于扫描或已拼合的图像，没有独立对象。你可以覆盖或替换某个区域，但无法移动或重设此处单个图形的样式。"
          }
        }
      }
    },
    "object.editability.unsupported": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold can’t edit this kind of object yet. It’s shown for reference only."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold aún no puede editar este tipo de objeto. Se muestra solo como referencia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold ne peut pas encore modifier ce type d’objet. Il est affiché à titre de référence uniquement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold अभी इस प्रकार के ऑब्जेक्ट को संपादित नहीं कर सकता। यह केवल संदर्भ के लिए दिखाया गया है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはこの種類のオブジェクトをまだ編集できません。参考のために表示されています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 暂时无法编辑此类对象。此处仅供参考显示。"
          }
        }
      }
    },
    "object.editability.visualOnly": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "visual-only"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "solo visual"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "visuel uniquement"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल दृश्य"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "表示のみ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅视觉"
          }
        }
      }
    },
    "object.error.commitFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t apply that object change — nothing was modified."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo aplicar ese cambio de objeto: no se modificó nada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d’appliquer cette modification d’objet — rien n’a été modifié."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वह ऑब्जेक्ट परिवर्तन लागू नहीं हो सका — कुछ भी नहीं बदला गया।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのオブジェクトの変更を適用できませんでした。何も変更されていません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法应用该对象更改——未做任何修改。"
          }
        }
      }
    },
    "object.error.exportVerifyFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The exported file didn’t verify after saving your object edits, so the export was stopped."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo exportado no se verificó tras guardar tus ediciones de objetos, así que se detuvo la exportación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier exporté n’a pas pu être vérifié après l’enregistrement de vos modifications d’objets ; l’exportation a été interrompue."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके ऑब्जेक्ट संपादनों को सहेजने के बाद निर्यात की गई फ़ाइल सत्यापित नहीं हुई, इसलिए निर्यात रोक दिया गया।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オブジェクト編集の保存後に書き出したファイルを検証できなかったため、書き出しを中止しました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存对象编辑后导出的文件未通过校验，已停止导出。"
          }
        }
      }
    },
    "object.error.mixedEditsUnsupported": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can’t mix text edits and object edits on the same document yet — finish or undo one before starting the other."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todavía no puedes combinar ediciones de texto y de objetos en el mismo documento: termina o deshaz una antes de empezar la otra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous ne pouvez pas encore mélanger les modifications de texte et d’objets dans le même document — terminez ou annulez l’une avant de commencer l’autre."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप अभी एक ही दस्तावेज़ पर टेक्स्ट संपादन और ऑब्जेक्ट संपादन एक साथ नहीं कर सकते — दूसरा शुरू करने से पहले एक को पूरा करें या पूर्ववत करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同じ書類でテキスト編集とオブジェクト編集をまだ併用できません。片方を終えるか取り消してからもう片方を始めてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂时无法在同一文档中同时进行文本编辑和对象编辑——请先完成或撤销其中一个再开始另一个。"
          }
        }
      }
    },
    "object.error.rotatedPageUnsupported": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Object editing isn’t available on rotated pages yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La edición de objetos aún no está disponible en páginas giradas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La modification d’objets n’est pas encore disponible sur les pages pivotées."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "घुमाए गए पृष्ठों पर ऑब्जेक्ट संपादन अभी उपलब्ध नहीं है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "回転したページではオブジェクト編集はまだ利用できません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "旋转的页面暂不支持对象编辑。"
          }
        }
      }
    },
