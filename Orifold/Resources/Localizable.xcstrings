    "status.undo.nothingToUndo": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nothing to undo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay nada que deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rien à annuler."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पूर्ववत करने के लिए कुछ नहीं है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "取り消せる操作はありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有可以还原的操作。"
          }
        }
      }
    },
    "textEdit.privacyNotice.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Editing or deleting text here changes how the page looks, but the original wording can sometimes still be found in the exported PDF — through search, copy-paste, or accessibility tools. For sensitive content, review the exported file carefully before sharing it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Editar o eliminar texto aquí cambia el aspecto de la página, pero el texto original a veces todavía puede encontrarse en el PDF exportado, mediante búsqueda, copiar y pegar o herramientas de accesibilidad. Para contenido sensible, revisa cuidadosamente el archivo exportado antes de compartirlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Modifier ou supprimer du texte ici change l’apparence de la page, mais le texte d’origine peut parfois encore être retrouvé dans le PDF exporté — via la recherche, le copier-coller ou les outils d’accessibilité. Pour un contenu sensible, vérifiez soigneusement le fichier exporté avant de le partager."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यहाँ टेक्स्ट संपादित या हटाने से पृष्ठ का स्वरूप बदल जाता है, लेकिन मूल शब्द कभी-कभी निर्यात किए गए PDF में खोज, कॉपी-पेस्ट या एक्सेसिबिलिटी टूल के ज़रिए अब भी मिल सकते हैं। संवेदनशील सामग्री के लिए, साझा करने से पहले निर्यात की गई फ़ाइल को ध्यान से जाँचें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ここでテキストを編集または削除するとページの見た目は変わりますが、元の文言は検索・コピー＆ペースト・アクセシビリティツールを通じて書き出したPDFから見つかる場合があります。機密性の高い内容は、共有する前に書き出したファイルをよく確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在此编辑或删除文本会改变页面的外观，但原始文字有时仍可通过搜索、复制粘贴或辅助功能工具在导出的 PDF 中找到。对于敏感内容，请在分享前仔细检查导出的文件。"
          }
        }
      }
    },
    "textEdit.privacyNotice.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Edited text may still be recoverable"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El texto editado aún puede recuperarse"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le texte modifié peut encore être récupéré"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "संशोधित टेक्स्ट अब भी पुनर्प्राप्त किया जा सकता है"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "編集したテキストは復元できる場合があります"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已编辑的文本仍可能被恢复"
          }
        }
      }
    },
