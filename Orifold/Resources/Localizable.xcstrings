    "readingCanvas.formatting.matchFormat.tooltip": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Match the nearby PDF text's full style — font, size, color, alignment, margins and wrapping — for this edit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Igualar todo el estilo del texto cercano del PDF (fuente, tamaño, color, alineación, márgenes y ajuste de línea) para esta edición."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appliquer à cette modification le style complet du texte PDF voisin — police, taille, couleur, alignement, marges et retour à la ligne."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस संपादन के लिए आस-पास के PDF टेक्स्ट की पूरी स्टाइल — फ़ॉन्ट, आकार, रंग, अलाइनमेंट, मार्जिन और रैपिंग — से मैच करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为此编辑匹配附近 PDF 文本的完整样式——字体、大小、颜色、对齐方式、页边距和换行方式。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "近くのPDFテキストのスタイル(フォント、サイズ、色、配置、余白、折り返し)をこの編集にすべて合わせます。"
          }
        }
      }
    },
    "readingCanvas.formatting.copyFormat.button": {
      "extractionState": "manual",
      "localizations": {
