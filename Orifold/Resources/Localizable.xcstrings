        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OrifoldгҒҜдёҖйғЁгҒ®гғҡгғјгӮёгӮ’еҫ©е…ғгҒ§гҒҚгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹгҖӮгҒқгӮҢгӮүгҒ®з·ЁйӣҶеҶ…е®№гҒҜгҒқгҒ®гҒҫгҒҫж®ӢгҒ•гӮҢгҒҰгҒ„гҒҫгҒҷгҖӮ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold ж— жі•жҒўеӨҚйғЁеҲҶйЎөйқўпјҢиҝҷдәӣйЎөйқўзҡ„зј–иҫ‘еҶ…е®№е·Ідҝқз•ҷгҖӮ"
          }
        }
      }
    },
    "error.sanitization.failed": {
      "extractionState": "manual",
