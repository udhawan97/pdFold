    "certificateSheet.manage.checkTrust.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Checks this certificate's chain against your Mac's trusted roots, and asks the issuer whether it has been revoked. Self-signed certificates are expected to show as not trusted here — that's normal, not an error."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprueba la cadena de este certificado con las raíces de confianza de tu Mac y le pregunta al emisor si ha sido revocado. Se espera que los certificados autofirmados aparezcan como no confiables aquí; eso es normal, no un error."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vérifie la chaîne de ce certificat par rapport aux racines de confiance de votre Mac et demande à l'émetteur s'il a été révoqué. Les certificats autosignés doivent normalement apparaître comme non fiables ici — c'est normal, pas une erreur."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह इस प्रमाणपत्र की श्रृंखला की जांच आपके Mac की विश्वसनीय जड़ों के विरुद्ध करता है, और जारीकर्ता से पूछता है कि क्या इसे निरस्त किया गया है। स्व-हस्ताक्षरित प्रमाणपत्रों का यहां 'भरोसेमंद नहीं' दिखना सामान्य है — यह कोई त्रुटि नहीं है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この証明書のチェーンをMacの信頼されたルートと照合し、発行者に失効しているかどうかを確認します。自己署名証明書がここで「信頼されていない」と表示されるのは正常であり、エラーではありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "根据您 Mac 的受信任根证书检查此证书的证书链，并向颁发者询问是否已被吊销。自签名证书在此处显示为不受信任是正常现象，并非错误。"
          }
        }
      }
    },
    "certificateSheet.manage.empty": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Digital IDs yet. Create a self-signed one or import a .p12/.pfx from the Signatures panel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay identificaciones digitales. Crea una autofirmada o importa un .p12/.pfx desde el panel de Firmas."
