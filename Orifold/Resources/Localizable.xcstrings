    "annotationTool.none.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select annotations on the page. Press Delete to remove the selected annotation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona anotaciones en la página. Pulsa Suprimir para eliminar la anotación seleccionada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez des annotations sur la page. Appuyez sur Suppr pour supprimer l'annotation sélectionnée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पृष्ठ पर एनोटेशन चुनें। चयनित एनोटेशन हटाने के लिए Delete दबाएँ।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择页面上的注释。按 Delete 键删除所选注释。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ページ上の注釈を選択します。選択した注釈を削除するにはDeleteキーを押してください。"
          }
        }
      }
    },
    "annotationTool.highlight.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select PDF text to mark it with color."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona texto del PDF para marcarlo con color."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez du texte du PDF pour le marquer avec une couleur."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रंग से चिह्नित करने के लिए PDF टेक्स्ट चुनें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 PDF 文本以用颜色标记。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "色で強調表示するPDFテキストを選択します。"
          }
        }
      }
    },
    "annotationTool.note.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click the page to add a sticky note, or click an existing note to edit it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en la página para agregar una nota adhesiva, o haz clic en una nota existente para editarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur la page pour ajouter une note autocollante, ou cliquez sur une note existante pour la modifier."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्टिकी नोट जोड़ने के लिए पृष्ठ पर क्लिक करें, या संपादित करने के लिए किसी मौजूदा नोट पर क्लिक करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击页面添加便签，或点击现有便签进行编辑。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ページをクリックして付箋を追加するか、既存のメモをクリックして編集します。"
          }
        }
      }
    },
    "annotationTool.comment.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select PDF text, then create an anchored comment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona texto del PDF y luego crea un comentario anclado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez du texte du PDF, puis créez un commentaire ancré."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "PDF टेक्स्ट चुनें, फिर एक एंकर की गई टिप्पणी बनाएं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 PDF 文本，然后创建锚定评论。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PDFテキストを選択してから、アンカー付きコメントを作成します。"
          }
        }
      }
    },
    "annotationTool.commentRegion.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag a rectangle over a figure or region to create an anchored comment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra un rectángulo sobre una figura o región para crear un comentario anclado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faites glisser un rectangle sur une figure ou une zone pour créer un commentaire ancré."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एंकर की गई टिप्पणी बनाने के लिए किसी आकृति या क्षेत्र पर आयत खींचें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在图形或区域上拖出一个矩形以创建锚定评论。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "図や範囲の上に四角形をドラッグしてアンカー付きコメントを作成します。"
          }
        }
      }
    },
    "annotationTool.editText.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click existing text to replace it, or click blank space to add text."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en el texto existente para reemplazarlo, o haz clic en un espacio en blanco para agregar texto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur du texte existant pour le remplacer, ou cliquez sur un espace vide pour ajouter du texte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मौजूदा टेक्स्ट बदलने के लिए उस पर क्लिक करें, या टेक्स्ट जोड़ने के लिए खाली जगह पर क्लिक करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击现有文本进行替换，或点击空白处添加文本。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "既存のテキストをクリックして置き換えるか、空白部分をクリックしてテキストを追加します。"
          }
        }
      }
    },
    "annotationTool.ink.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Draw freehand marks on the page."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dibuja marcas a mano alzada en la página."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dessinez des marques à main levée sur la page."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पृष्ठ पर फ़्रीहैंड निशान बनाएं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在页面上绘制手绘标记。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ページにフリーハンドで描画します。"
          }
        }
      }
    },
    "annotationTool.eraser.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click a highlight, underline, or strikeout to remove it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en un resaltado, subrayado o tachado para eliminarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur un surlignage, un soulignement ou un barré pour le supprimer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हटाने के लिए किसी हाइलाइट, अंडरलाइन या स्ट्राइकआउट पर क्लिक करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击高亮、下划线或删除线以将其移除。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ハイライト、下線、取り消し線をクリックして削除します。"
          }
        }
      }
    },
    "annotationTool.underline.helpText": {
      "extractionState": "manual",
