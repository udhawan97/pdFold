          "stringUnit": {
            "state": "translated",
            "value": "डिजिटल हस्ताक्षर लगाने से पहले एक हस्ताक्षर पहचान चुनें या आयात करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デジタル署名を配置する前に、署名用のIDを選択またはインポートしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先选择或导入签名身份，然后再放置数字签名。"
          }
        }
      }
    },
