    "guideFeature.protect.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Password-protect compatible exports and control copy or print permissions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Protege con contraseña las exportaciones compatibles y controla los permisos de copia e impresión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Protégez par mot de passe les exports compatibles et contrôlez les autorisations de copie ou d’impression."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "संगत एक्सपोर्ट को पासवर्ड से सुरक्षित करें और कॉपी या प्रिंट अनुमतियों को नियंत्रित करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "対応する書き出し形式にパスワードを設定し、コピーやプリントの権限を管理できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为支持的导出添加密码保护，并控制拷贝或打印权限。"
          }
        }
      }
    },
    "guideFeature.protect.title": {
      "extractionState": "manual",
