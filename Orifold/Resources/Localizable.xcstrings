    "signSelfCheck.coverageWarning": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not confirm the signature covers the whole document — please re-verify this file before relying on it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo confirmar que la firma cubra todo el documento; verifica este archivo antes de confiar en él."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu confirmer que la signature couvre l'intégralité du document — veuillez revérifier ce fichier avant de vous y fier."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold यह पुष्टि नहीं कर सका कि हस्ताक्षर पूरे दस्तावेज़ को कवर करता है — इस पर भरोसा करने से पहले कृपया इस फ़ाइल को फिर से सत्यापित करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは署名が文書全体をカバーしていることを確認できませんでした。信頼する前にこのファイルを再確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法确认签名覆盖了整个文档——在信任此文件之前，请重新验证。"
          }
        }
      }
    },
    "signSelfCheck.wholeDocumentVerified": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold verified: the signature covers the complete document."
