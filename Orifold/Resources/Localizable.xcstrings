    "status.signature.editInvalidates": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Editing after a digital signature invalidates existing signatures."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Editar después de una firma digital invalida las firmas existentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toute modification après une signature numérique invalide les signatures existantes."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिजिटल हस्ताक्षर के बाद संपादन करने से मौजूदा हस्ताक्षर अमान्य हो जाते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デジタル署名の後に編集すると、既存の署名が無効になります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在数字签名之后进行编辑会使现有签名失效。"
          }
        }
      }
    },
    "status.signature.thirdPartyEditInvalidates": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This document already contains a digital signature from another source. Editing it will invalidate that signature."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este documento ya contiene una firma digital de otro origen. Editarlo invalidará esa firma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce document contient déjà une signature numérique provenant d’une autre source. Le modifier invalidera cette signature."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस दस्तावेज़ में पहले से ही किसी अन्य स्रोत का डिजिटल हस्ताक्षर मौजूद है। इसे संपादित करने से वह हस्ताक्षर अमान्य हो जाएगा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この書類には既に他の作成元によるデジタル署名が含まれています。編集するとその署名が無効になります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此文档已包含来自其他来源的数字签名。编辑将使该签名失效。"
          }
        }
      }
    },
