    "annotationTool.note.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click the page to add a sticky note, or click an existing note to edit it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en la página para agregar una nota adhesiva, o haz clic en una nota existente para editarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur la page pour ajouter une note autocollante, ou cliquez sur une note existante pour la modifier."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्टिकी नोट जोड़ने के लिए पृष्ठ पर क्लिक करें, या संपादित करने के लिए किसी मौजूदा नोट पर क्लिक करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ページをクリックして付箋を追加するか、既存のメモをクリックして編集します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击页面添加便签，或点击现有便签进行编辑。"
          }
        }
      }
    },
    "annotationTool.note.label": {
