    "documentComfort.focusMode.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dims surrounding app chrome to emphasize the document."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Atenúa la interfaz de la aplicación para resaltar el documento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Atténue l'interface de l'application pour mettre en valeur le document."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दस्तावेज़ पर ज़ोर देने के लिए आसपास के ऐप इंटरफ़ेस को मंद करता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ドキュメントを際立たせるために周囲のアプリUIを暗くします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使周围的应用界面变暗以突出文档。"
          }
        }
      }
    },
    "documentComfort.focusMode.info": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dims the surrounding toolbar and sidebar to spotlight the page."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Atenúa la barra de herramientas y la barra lateral para destacar la página."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Assombrit la barre d'outils et la barre latérale pour mettre la page en valeur."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पेज को उभारने के लिए आस-पास के टूलबार और साइडबार को धीमा करता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ページを際立たせるため、周囲のツールバーとサイドバーを暗くします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调暗周围的工具栏和侧边栏，突出显示页面。"
          }
        }
      }
    },
