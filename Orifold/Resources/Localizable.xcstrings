          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस Mac द्वारा विश्वसनीय"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このMacで信頼済み"
          }
