          }
        }
      }
    },
    "error.sanitization.failed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not sanitize this PDF. Export without \"Sanitize for sharing,\" or try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo sanear este PDF. Exporta sin \"Sanear para compartir\" o vuelve a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n’a pas pu nettoyer ce PDF. Exportez sans « Nettoyer avant partage », ou réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold इस PDF को सैनिटाइज़ नहीं कर सका। \"साझा करने के लिए सैनिटाइज़ करें\" के बिना एक्सपोर्ट करें, या फिर से कोशिश करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OrifoldはこのPDFをサニタイズできませんでした。「共有用にサニタイズ」を外して書き出すか、もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法清理此 PDF。请在导出时关闭“清理后再分享”，或重试。"
          }
        }
      }
    },
    "error.signature.missingIdentity": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose or import a signing identity before exporting a digital signature."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige o importa una identidad de firma antes de exportar una firma digital."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez ou importez une identité de signature avant d’exporter une signature numérique."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिजिटल हस्ताक्षर एक्सपोर्ट करने से पहले एक हस्ताक्षर पहचान चुनें या आयात करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デジタル署名を書き出す前に、署名用のIDを選択またはインポートしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先选择或导入签名身份，然后再导出数字签名。"
          }
        }
      }
    },
    "error.signature.notImplemented": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Digital signing is not available in this build yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
