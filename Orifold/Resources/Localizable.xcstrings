    "error.export.identityExpired": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This certificate has already expired. Choose a different Digital ID, or create/import a new one, before signing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este certificado ya ha caducado. Elige otra identificación digital, o crea/importa una nueva, antes de firmar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce certificat a déjà expiré. Choisissez une autre identité numérique, ou créez-en/importez-en une nouvelle, avant de signer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह प्रमाणपत्र पहले ही समाप्त हो चुका है। हस्ताक्षर करने से पहले एक अलग डिजिटल आईडी चुनें, या नई बनाएं/आयात करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
