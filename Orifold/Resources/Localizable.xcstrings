    "error.signatureAppearance.imageEncodingFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold couldn't turn that signature into an image. Try again, or choose a different signature style."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo convertir esa firma en una imagen. Inténtalo de nuevo o elige otro estilo de firma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu convertir cette signature en image. Réessayez ou choisissez un autre style de signature."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold उस हस्ताक्षर को इमेज में नहीं बदल सका। फिर से प्रयास करें, या कोई दूसरी हस्ताक्षर शैली चुनें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはその署名を画像に変換できませんでした。もう一度お試しになるか、別の署名スタイルを選んでください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法将该签名转换为图像。请重试，或选择其他签名样式。"
          }
        }
      }
    },
    "error.signatureAppearance.invalidImageData": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That signature image couldn't be read. Try drawing or uploading it again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo leer esa imagen de firma. Intenta dibujarla o cargarla de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette image de signature n'a pas pu être lue. Essayez de la redessiner ou de la retélécharger."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वह हस्ताक्षर इमेज पढ़ी नहीं जा सकी। इसे फिर से बनाएं या अपलोड करने का प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "その署名画像を読み込めませんでした。もう一度描画するかアップロードしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法读取该签名图像。请重新绘制或上传。"
          }
        }
      }
    },
    "error.signatureAppearance.invalidSize": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold couldn't create a signature at that size. Try a different size or a shorter name."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo crear una firma con ese tamaño. Prueba con un tamaño diferente o un nombre más corto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu créer de signature à cette taille. Essayez une autre taille ou un nom plus court."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold उस आकार में हस्ताक्षर नहीं बना सका। एक अलग आकार या छोटा नाम आज़माएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはそのサイズで署名を作成できませんでした。別のサイズにするか、名前を短くしてお試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法以该尺寸创建签名。请尝试其他尺寸或缩短姓名。"
          }
        }
      }
    },
    "error.signing.identityExpired": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This certificate has expired and can no longer be used to sign. Choose a different certificate, or renew this one."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este certificado ha caducado y ya no se puede usar para firmar. Elige otro certificado o renueva este."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce certificat a expiré et ne peut plus être utilisé pour signer. Choisissez un autre certificat ou renouvelez celui-ci."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस प्रमाणपत्र की अवधि समाप्त हो गई है और अब इसका उपयोग हस्ताक्षर के लिए नहीं किया जा सकता। कोई दूसरा प्रमाणपत्र चुनें, या इसे नवीनीकृत करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この証明書は有効期限が切れており、署名には使用できません。別の証明書を選ぶか、この証明書を更新してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该证书已过期，无法再用于签名。请选择其他证书，或续订此证书。"
          }
        }
      }
    },
    "error.signing.invalidPDF": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This PDF's structure isn't one Orifold can add a digital signature to. Try flattening or re-exporting the PDF first, then sign it again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La estructura de este PDF no permite que Orifold le añada una firma digital. Prueba a aplanarlo o exportarlo de nuevo y luego fírmalo otra vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La structure de ce PDF ne permet pas à Orifold d'y ajouter une signature numérique. Essayez d'aplatir ou de réexporter le PDF, puis signez-le à nouveau."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस PDF की संरचना ऐसी नहीं है कि Orifold इसमें डिजिटल हस्ताक्षर जोड़ सके। पहले PDF को फ़्लैटन या दोबारा एक्सपोर्ट करें, फिर से हस्ताक्षर करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このPDFの構造にはOrifoldでデジタル署名を追加できません。まずPDFをフラット化するか再書き出ししてから、もう一度署名してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此 PDF 的结构不支持 Orifold 添加数字签名。请先展平或重新导出该 PDF，然后再次签署。"
          }
        }
      }
    },
    "error.signing.placeholderReservationFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold couldn't reserve space for the signature in this PDF. Try flattening or re-exporting the PDF first, then sign it again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo reservar espacio para la firma en este PDF. Prueba a aplanarlo o exportarlo de nuevo y luego fírmalo otra vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu réserver d'espace pour la signature dans ce PDF. Essayez d'aplatir ou de réexporter le PDF, puis signez-le à nouveau."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold इस PDF में हस्ताक्षर के लिए जगह आरक्षित नहीं कर सका। पहले PDF को फ़्लैटन या दोबारा एक्सपोर्ट करें, फिर से हस्ताक्षर करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはこの PDF内に署名用の領域を確保できませんでした。まずPDFをフラット化するか再書き出ししてから、もう一度署名してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法在此 PDF 中为签名预留空间。请先展平或重新导出该 PDF，然后再次签署。"
          }
        }
      }
    },
    "error.signing.timestampUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold couldn't reach the timestamp server. Check your internet connection, or turn off timestamping and sign again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo conectarse al servidor de sellado de tiempo. Comprueba tu conexión a internet o desactiva el sellado de tiempo y firma de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu joindre le serveur d'horodatage. Vérifiez votre connexion internet, ou désactivez l'horodatage et signez à nouveau."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold टाइमस्टैंप सर्वर तक नहीं पहुँच सका। अपना इंटरनेट कनेक्शन जाँचें, या टाइमस्टैंपिंग बंद करके फिर से हस्ताक्षर करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはタイムスタンプサーバーに接続できませんでした。インターネット接続を確認するか、タイムスタンプをオフにしてもう一度署名してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 无法连接到时间戳服务器。请检查您的网络连接，或关闭时间戳后重新签署。"
          }
        }
      }
    },
    "error.signingIdentity.alreadyInKeychain": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That certificate is already in Keychain Access."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ese certificado ya está en Acceso a Llaveros."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce certificat se trouve déjà dans le Trousseau d'accès."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वह प्रमाणपत्र पहले से ही Keychain Access में मौजूद है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "その証明書はすでにキーチェーンアクセスに存在します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该证书已存在于钥匙串访问中。"
          }
        }
      }
    },
    "error.signingIdentity.invalidCertificateData": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The certificate bytes could not be parsed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudieron analizar los bytes del certificado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les octets du certificat n'ont pas pu être analysés."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रमाणपत्र बाइट्स पार्स नहीं किए जा सके।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "証明書のバイトデータを解析できませんでした。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法解析证书数据。"
          }
        }
      }
    },
    "error.signingIdentity.invalidPKCS12": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The PKCS#12 file could not be decoded."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo decodificar el archivo PKCS#12."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier PKCS#12 n'a pas pu être décodé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "PKCS#12 फ़ाइल को डिकोड नहीं किया जा सका।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PKCS#12ファイルをデコードできませんでした。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法解码 PKCS#12 文件。"
          }
        }
      }
    },
    "error.signingIdentity.itemNotFoundInKeychain": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold couldn't find that certificate in Keychain Access. It may have been removed — try re-adding it or choosing a different certificate."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo encontrar ese certificado en Acceso a Llaveros. Es posible que se haya eliminado; intenta volver a añadirlo o elige otro certificado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas trouvé ce certificat dans le Trousseau d'accès. Il a peut-être été supprimé — essayez de le rajouter ou choisissez un autre certificat."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold को Keychain Access में वह प्रमाणपत्र नहीं मिला। हो सकता है इसे हटा दिया गया हो — इसे फिर से जोड़ने का प्रयास करें या कोई दूसरा प्रमाणपत्र चुनें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldはそのキーチェーンアクセスに証明書を見つけられませんでした。削除された可能性があります — 再度追加するか、別の証明書を選択してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 在钥匙串访问中找不到该证书。它可能已被移除——请尝试重新添加，或选择其他证书。"
          }
        }
      }
    },
    "error.signingIdentity.keychainLocked": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keychain Access needs to be unlocked before Orifold can use this certificate. Unlock your keychain and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Es necesario desbloquear Acceso a Llaveros antes de que Orifold pueda usar este certificado. Desbloquea tu llavero e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Trousseau d'accès doit être déverrouillé avant qu'Orifold puisse utiliser ce certificat. Déverrouillez votre trousseau et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold इस प्रमाणपत्र का उपयोग करे उससे पहले Keychain Access को अनलॉक करना ज़रूरी है। अपनी कीचेन अनलॉक करें और फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldがこの証明書を使用する前に、キーチェーンアクセスのロックを解除する必要があります。キーチェーンのロックを解除してもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 使用此证书前需要先解锁钥匙串访问。请解锁您的钥匙串后重试。"
          }
        }
      }
    },
    "error.signingIdentity.missingCertificate": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The identity did not include a certificate."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La identidad no incluía un certificado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'identité ne comportait pas de certificat."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहचान में कोई प्रमाणपत्र शामिल नहीं था।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "IDに証明書が含まれていませんでした。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该身份未包含证书。"
          }
        }
      }
    },
    "error.signingIdentity.missingPrivateKey": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The identity did not include an accessible private key."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La identidad no incluía una clave privada accesible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'identité ne comportait pas de clé privée accessible."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहचान में कोई सुलभ निजी कुंजी शामिल नहीं थी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "IDにアクセス可能な秘密鍵が含まれていませんでした。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该身份未包含可访问的私钥。"
          }
        }
      }
    },
    "error.signingIdentity.noIdentityInPKCS12": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The PKCS#12 file did not contain a signing identity."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo PKCS#12 no contenía una identidad de firma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier PKCS#12 ne contenait pas d'identité de signature."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "PKCS#12 फ़ाइल में हस्ताक्षर पहचान नहीं थी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PKCS#12ファイルに署名用のIDが含まれていませんでした。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PKCS#12 文件中未包含签名身份。"
          }
        }
      }
    },
    "error.signingIdentity.selfSignedCertificateCreationFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The self-signed certificate could not be created."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo crear el certificado autofirmado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le certificat auto-signé n'a pas pu être créé."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्व-हस्ताक्षरित प्रमाणपत्र नहीं बनाया जा सका।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自己署名証明書を作成できませんでした。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法创建自签名证书。"
          }
        }
      }
    },
    "error.signingIdentity.userCancelled": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The operation was cancelled."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se canceló la operación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'opération a été annulée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कार्रवाई रद्द कर दी गई थी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "操作はキャンセルされました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "操作已取消。"
          }
        }
      }
    },
    "error.signingIdentity.wrongPassword": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That password isn't correct for this file. Check it and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esa contraseña no es correcta para este archivo. Revísala e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce mot de passe n'est pas correct pour ce fichier. Vérifiez-le et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वह पासवर्ड इस फ़ाइल के लिए सही नहीं है। इसे जाँचें और फिर से प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そのパスワードはこのファイルには正しくありません。確認してもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该密码对此文件不正确。请检查后重试。"
          }
        }
      }
    },
