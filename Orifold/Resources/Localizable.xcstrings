          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्व-हस्ताक्षरित डिजिटल आईडी बनाएं"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
