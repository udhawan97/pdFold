    "signaturePalette.selfSigned.notice": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Free — but recipients see 'identity not verified' until they trust it once."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gratis, pero los destinatarios verán \"identidad no verificada\" hasta que confíen en ella una vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gratuit — mais les destinataires verront « identité non vérifiée » tant qu’ils ne l’auront pas approuvée une première fois."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मुफ़्त — लेकिन जब तक प्राप्तकर्ता एक बार भरोसा नहीं करते, उन्हें 'पहचान सत्यापित नहीं' दिखता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無料ですが、受信者が一度信頼するまで「本人確認未検証」と表示されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "免费——但在接收者首次信任之前，会看到“身份未验证”的提示。"
          }
        }
      }
    },
