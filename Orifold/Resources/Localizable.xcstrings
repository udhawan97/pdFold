    "annotationTool.comment.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select PDF text, then create an anchored comment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona texto del PDF y luego crea un comentario anclado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez du texte du PDF, puis créez un commentaire ancré."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "PDF टेक्स्ट चुनें, फिर एक एंकर की गई टिप्पणी बनाएं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PDFテキストを選択してから、アンカー付きコメントを作成します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 PDF 文本，然后创建锚定评论。"
          }
        }
      }
    },
    "annotationTool.comment.label": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Comment"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comentario"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commentaire"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टिप्पणी"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コメント"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "评论"
          }
        }
      }
    },
    "annotationTool.commentRegion.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag a rectangle over a figure or region to create an anchored comment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra un rectángulo sobre una figura o región para crear un comentario anclado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faites glisser un rectangle sur une figure ou une zone pour créer un commentaire ancré."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एंकर की गई टिप्पणी बनाने के लिए किसी आकृति या क्षेत्र पर आयत खींचें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "図や範囲の上に四角形をドラッグしてアンカー付きコメントを作成します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在图形或区域上拖出一个矩形以创建锚定评论。"
          }
        }
      }
    },
    "annotationTool.commentRegion.label": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Region Comment"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comentario de región"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commentaire de zone"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्षेत्र टिप्पणी"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "範囲コメント"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "区域评论"
          }
        }
      }
    },
    "annotationTool.editText.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click existing text to replace it, or click blank space to add text."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en el texto existente para reemplazarlo, o haz clic en un espacio en blanco para agregar texto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur du texte existant pour le remplacer, ou cliquez sur un espace vide pour ajouter du texte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मौजूदा टेक्स्ट बदलने के लिए उस पर क्लिक करें, या टेक्स्ट जोड़ने के लिए खाली जगह पर क्लिक करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "既存のテキストをクリックして置き換えるか、空白部分をクリックしてテキストを追加します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击现有文本进行替换，或点击空白处添加文本。"
          }
        }
      }
    },
    "annotationTool.editText.label": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Edit Text"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Editar texto"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Modifier le texte"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टेक्स्ट संपादित करें"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テキストを編集"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "编辑文本"
          }
        }
      }
    },
    "annotationTool.eraser.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click a highlight, underline, or strikeout to remove it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en un resaltado, subrayado o tachado para eliminarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur un surlignage, un soulignement ou un barré pour le supprimer."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हटाने के लिए किसी हाइलाइट, अंडरलाइन या स्ट्राइकआउट पर क्लिक करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ハイライト、下線、取り消し線をクリックして削除します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击高亮、下划线或删除线以将其移除。"
          }
        }
      }
    },
    "annotationTool.eraser.label": {
      "extractionState": "manual",
