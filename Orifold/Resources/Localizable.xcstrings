    "annotationTool.none.helpText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select annotations on the page. Press Delete to remove the selected annotation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona anotaciones en la página. Pulsa Suprimir para eliminar la anotación seleccionada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez des annotations sur la page. Appuyez sur Suppr pour supprimer l'annotation sélectionnée."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पृष्ठ पर एनोटेशन चुनें। चयनित एनोटेशन हटाने के लिए Delete दबाएँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ページ上の注釈を選択します。選択した注釈を削除するにはDeleteキーを押してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择页面上的注释。按 Delete 键删除所选注释。"
          }
        }
      }
    },
    "annotationTool.none.label": {
