    "guideFeature.assemble.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Combine files, reorder pages, rotate, delete, and reshape the packet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Combina archivos, reordena páginas, gira, elimina y reorganiza el paquete."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Combinez des fichiers, réorganisez les pages, pivotez, supprimez et remaniez le dossier."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
