    "update.install.unsavedMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have unsaved changes in %@. Save or close them, then install so no work is lost."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tienes cambios sin guardar en %@. Guárdalos o ciérralos y luego instala para no perder trabajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez des modifications non enregistrées dans %@. Enregistrez-les ou fermez-les, puis installez pour ne rien perdre."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ में असहेजे बदलाव हैं। उन्हें सहेजें या बंद करें, फिर इंस्टॉल करें ताकि कोई काम न खोए।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ に未保存の変更があります。保存または閉じてからインストールしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 中有未保存的更改。请先保存或关闭，然后再安装，以免丢失工作。"
          }
        }
      }
    },
