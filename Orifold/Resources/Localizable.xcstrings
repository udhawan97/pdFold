    "emptyState.petIntro.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose files and I will help keep the PDF chores moving."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige archivos y te ayudaré a avanzar con tus tareas de PDF."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez des fichiers et je vous aiderai à avancer sur vos tâches PDF."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइलें चुनें और मैं PDF से जुड़े काम आसान बनाने में मदद करूंगा।"
          }
        },
        "ja": {
