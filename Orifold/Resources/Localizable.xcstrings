    "ori.export.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporting? I found a cleaner path through this. Follow me."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Vas a exportar? Encontré un camino más limpio. Sígueme."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous exportez ? J'ai trouvé une voie plus nette. Suivez-moi."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक्सपोर्ट कर रहे हैं? मुझे एक बेहतर तरीका मिला। मेरा अनुसरण करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "書き出しますか？ もっと綺麗な道を見つけました。ついてきて。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要导出了？我找到了更简洁的路径。跟我来。"
          }
        }
      }
    },
    "ori.export.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Export approved. Naturally, I checked it first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportación aprobada. Naturalmente, lo revisé primero."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Export approuvé. Naturellement, j'ai vérifié avant."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक्सपोर्ट स्वीकृत। स्वाभाविक रूप से, मैंने पहले जांचा।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "書き出し承認。もちろん、先に確認済みです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出已批准。当然，我先检查过了。"
          }
        }
      }
    },
    "ori.greeting.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're back. I kept everything exactly where you left it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has vuelto. Dejé todo exactamente donde lo tenías."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous voilà. J'ai gardé chaque chose exactement à sa place."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप वापस आ गए। मैंने सब कुछ वहीं रखा जहाँ आपने छोड़ा था।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "お帰りなさい。すべて置いたままにしておきました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你回来了。一切都保持在你离开时的样子。"
          }
        }
      }
    },
    "ori.greeting.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Proceed. I've already reviewed the room."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Adelante. Ya revisé la sala."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Allez-y. J'ai déjà tout inspecté."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आगे बढ़िए। मैं पहले ही सब जांच चुकी हूँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どうぞ。もう確認は済んでいます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请继续。我已经检查过了。"
          }
        }
      }
    },
    "ori.hoverTip.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yes? I was already watching."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Sí? Ya estaba observando."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oui ? J'observais déjà."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हाँ? मैं पहले से देख रही थी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "はい？ もう見ていましたよ。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "怎么？我早就在看着了。"
          }
        }
      }
    },
    "ori.hoverTip.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click me if you require guidance. Or company."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en mí si necesitas guía. O compañía."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur moi si vous avez besoin d'un guide. Ou de compagnie."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मार्गदर्शन चाहिए तो मुझ पर क्लिक करें। या साथ चाहिए तो भी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "案内が必要なら私をクリックして。話し相手でも。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要指引就点我。或者只是想有个伴。"
          }
        }
      }
    },
    "ori.hoverTip.3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everything stays on this Mac. I insist on it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo permanece en este Mac. Insisto en ello."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout reste sur ce Mac. J'y tiens absolument."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सब कुछ इसी Mac पर रहता है। मैं इस पर ज़ोर देती हूँ।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてこの Mac の中に留まります。私がそう決めています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一切都留在这台 Mac 上。这一点我坚持。"
          }
        }
      }
    },
    "ori.hoverTip.4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Gami would chase the cursor. I prefer strategy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gami perseguiría el cursor. Yo prefiero la estrategia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gami poursuivrait le curseur. Je préfère la stratégie."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "गामी कर्सर के पीछे भागता। मुझे रणनीति पसंद है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ガミならカーソルを追いかけるでしょう。私は戦略派です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Gami 会去追光标。我更喜欢讲策略。"
          }
        }
      }
    },
    "ori.hoverTip.5": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your margins are acceptable. Barely."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus márgenes son aceptables. A duras penas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos marges sont acceptables. À peine."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके मार्जिन ठीक हैं। बस मुश्किल से।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マージンは合格です。ぎりぎりですが。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的页边距还算过得去。勉强而已。"
          }
        }
      }
    },
    "ori.hoverTip.6": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Proceed, human. You may."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Adelante, humano. Puedes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Allez-y, humain. Vous pouvez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आगे बढ़िए, मनुष्य। आप कर सकते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どうぞ、人間さん。許可します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "继续吧，人类。准许了。"
          }
        }
      }
    },
    "ori.intro.greeting": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'm Ori. I'll be supervising. You'll do wonderfully."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Soy Ori. Yo superviso. Lo harás muy bien."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je suis Ori. Je supervise. Vous vous en sortirez à merveille."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मैं ओरी हूँ। मैं निगरानी करूँगी। आप बहुत अच्छा करेंगे।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "私はオリ。監督はお任せください。きっとうまくいきます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我是 Ori。我来监督。你会做得很好的。"
          }
        }
      }
    },
    "ori.intro.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everything stays on this Mac. I'll offer a clever tip when one is warranted — your files stay yours."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo permanece en este Mac. Ofreceré un consejo inteligente cuando lo amerite; tus archivos siguen siendo tuyos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout reste sur ce Mac. Je proposerai un conseil avisé quand il le faudra — vos fichiers restent les vôtres."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सब कुछ इसी Mac पर रहता है। जब ज़रूरी होगा, मैं एक चतुर सुझाव दूँगी — आपकी फ़ाइलें आपकी ही रहती हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてこの Mac の中に留まります。必要な時だけ気の利いたヒントを。書類はあなたのものです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一切都保留在这台 Mac 上。需要的时候我会给出一句聪明的提示——你的文件始终是你的。"
          }
        }
      }
    },
    "ori.save.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Saved. Your work stays here, under my supervision."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guardado. Tu trabajo se queda aquí, bajo mi supervisión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistré. Votre travail reste ici, sous ma supervision."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सहेजा गया। आपका काम यहीं है, मेरी निगरानी में।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存しました。作業はここに、私の監督のもとで。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已保存。你的内容留在这里，由我看管。"
          }
        }
      }
    },
    "ori.save.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Noted and kept. Elegant edits only, please."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Anotado y guardado. Solo ediciones elegantes, por favor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Noté et conservé. Des modifications élégantes, je vous prie."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दर्ज और सुरक्षित। कृपया केवल सुरुचिपूर्ण बदलाव करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記録して保存しました。上品な編集でお願いします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已记录并保存。请只做优雅的修改。"
          }
        }
      }
    },
    "ori.sibling.switch": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You've met my brother Gami. Different fold, same paper."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya conociste a mi hermano Gami. Otro pliegue, el mismo papel."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez rencontré mon frère Gami. Pli différent, même papier."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप मेरे भाई गामी से मिल चुके हैं। अलग तह, वही कागज़।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "弟のガミには会いましたね。折り方は違っても、紙は同じです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已经见过我弟弟 Gami 了。折法不同，纸是一样的。"
          }
        }
      }
    },
    "ori.warning.1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Something needs your attention. I noticed it first, obviously."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algo requiere tu atención. Lo noté primero, obviamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelque chose requiert votre attention. Je l'ai remarqué en premier, évidemment."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी चीज़ पर ध्यान चाहिए। मैंने पहले ही देख लिया, जाहिर है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "何かが注意を必要としています。もちろん、私が先に気づきました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有件事需要你注意。当然，我先发现的。"
          }
        }
      }
    },
    "ori.warning.2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A small problem. Handle it; I'll observe."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un pequeño problema. Encárgate; yo observaré."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un petit problème. Occupez-vous-en ; j'observerai."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक छोटी सी समस्या। इसे संभालिए; मैं देखूँगी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "小さな問題です。対処してください。私は見ています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一个小问题。你来处理，我在旁边看着。"
          }
        }
      }
    },
