    "folderImport.overLimit.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This folder contains %lld supported documents. Orifold can import up to 50 at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta carpeta contiene %lld documentos admitidos. Orifold puede importar hasta 50 a la vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce dossier contient %lld documents pris en charge. Orifold peut en importer jusqu’à 50 à la fois."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस फ़ोल्डर में %lld समर्थित दस्तावेज़ हैं। Orifold एक बार में अधिकतम 50 आयात कर सकता है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このフォルダには対応するドキュメントが%lld個あります。Orifoldは一度に最大50個まで読み込めます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此文件夹包含 %lld 个受支持的文档。Orifold 一次最多可导入 50 个。"
          }
        }
      }
    },
