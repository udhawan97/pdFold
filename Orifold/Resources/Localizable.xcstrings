          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold सजावट को वर्तमान पृष्ठ क्रम से मिला नहीं सका। दस्तावेज़ फिर से खोलें और फिर से निर्यात करने का प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
