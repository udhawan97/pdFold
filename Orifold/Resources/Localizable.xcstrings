        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रीडर मोड दस्तावेज़ के टेक्स्ट को लॉक रखता है। PDF टेक्स्ट संपादित करने के लिए इसे बंद करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リーダーモードでは書類のテキストがロックされています。編集するにはオフにしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
