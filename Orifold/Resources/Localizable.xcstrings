    "error.export.chooseSigningIdentity": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose or import a signing identity before exporting a digital signature."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige o importa una identidad de firma antes de exportar una firma digital."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez ou importez une identité de signature avant d'exporter une signature numérique."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिजिटल हस्ताक्षर निर्यात करने से पहले एक हस्ताक्षर पहचान चुनें या आयात करें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出数字签名前，请先选择或导入签名身份。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デジタル署名を書き出す前に、署名用IDを選択またはインポートしてください。"
          }
        }
      }
    },
    "error.export.locatePageForSignature": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold could not locate the page for that signature."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold no pudo ubicar la página de esa firma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold n'a pas pu localiser la page de cette signature."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
