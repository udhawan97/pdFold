      }
    },
    "status.readerMode.blockedEditText": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reader Mode keeps the document text locked. Turn it off to edit PDF text."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo lectura mantiene bloqueado el texto del documento. Desactívalo para editar el texto del PDF."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le mode lecture garde le texte du document verrouillé. Désactivez-le pour modifier le texte du PDF."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रीडर मोड दस्तावेज़ के टेक्स्ट को लॉक रखता है। PDF टेक्स्ट संपादित करने के लिए इसे बंद करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リーダーモードでは書類のテキストがロックされています。編集するにはオフにしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阅读模式下文档文本处于锁定状态。请将其关闭以编辑 PDF 文本。"
          }
        }
      }
    },
    "status.readerMode.blockedGeneric": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reader Mode keeps authoring tools locked."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
