    "guideFeature.assemble.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Combine files, reorder pages, rotate, delete, and reshape the packet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Combina archivos, reordena páginas, gira, elimina y reorganiza el paquete."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Combinez des fichiers, réorganisez les pages, pivotez, supprimez et remaniez le dossier."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ाइलें मिलाएं, पेजों को फिर से व्यवस्थित करें, घुमाएं, हटाएं और पैकेट को नया रूप दें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルを結合し、ページの並べ替え、回転、削除など、まとめ資料を自由に組み立てます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "合并文件，重新排列、旋转、删除页面，重塑文件包。"
          }
        }
      }
    },
