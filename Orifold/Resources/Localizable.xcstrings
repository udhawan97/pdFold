    "status.readerMode.blockedSignature": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reader Mode keeps signing locked. Turn it off to place or export signatures."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo lectura mantiene bloqueada la firma. Desactívalo para colocar o exportar firmas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le mode lecture garde la signature verrouillée. Désactivez-le pour placer ou exporter des signatures."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रीडर मोड हस्ताक्षर करना लॉक रखता है। हस्ताक्षर लगाने या एक्सपोर्ट करने के लिए इसे बंद करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リーダーモードでは署名がロックされています。署名を配置または書き出すにはオフにしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阅读模式下签名功能处于锁定状态。请将其关闭以放置或导出签名。"
          }
        }
      }
    },
    "status.readerMode.off": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reader Mode is off. Editing and signing tools are available again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo lectura está desactivado. Las herramientas de edición y firma vuelven a estar disponibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le mode lecture est désactivé. Les outils de modification et de signature sont de nouveau disponibles."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रीडर मोड बंद है। संपादन और हस्ताक्षर टूल फिर से उपलब्ध हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リーダーモードがオフです。編集と署名のツールが再び利用できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阅读模式已关闭。编辑和签名工具已恢复可用。"
          }
        }
      }
    },
    "status.readerMode.on": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reader Mode is on. Text editing and signing are hidden; study tools stay available."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo lectura está activado. La edición de texto y la firma están ocultas; las herramientas de estudio siguen disponibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le mode lecture est activé. La modification du texte et la signature sont masquées ; les outils d’étude restent disponibles."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रीडर मोड चालू है। टेक्स्ट संपादन और हस्ताक्षर छिपे हुए हैं; स्टडी टूल उपलब्ध रहते हैं।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リーダーモードがオンです。テキスト編集と署名は非表示になりますが、学習ツールは引き続き利用できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阅读模式已开启。文本编辑和签名功能已隐藏，学习工具仍可使用。"
          }
        }
      }
    },
    "status.sign.placeCertificateFirst": {
