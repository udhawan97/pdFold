            "state": "translated",
            "value": "Ajusta el texto detectado del PDF o añade cuadros de texto nuevos directamente en la página."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajustez le texte détecté du PDF ou ajoutez de nouvelles zones de texte directement sur la page."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहचाने गए PDF टेक्स्ट को समायोजित करें या सीधे पेज पर नए टेक्स्ट बॉक्स जोड़ें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调整检测到的 PDF 文本，或直接在页面上添加新的文本框。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検出されたPDFテキストを編集したり、ページ上に直接新しいテキストボックスを追加したりできます。"
          }
        }
      }
