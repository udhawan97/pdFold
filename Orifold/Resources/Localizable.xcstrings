    "inspector.ocr.detail.textFoundNoAutoRun": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold found existing PDF text, so it did not auto-run OCR. If search misses visible words, the text layer may be partial or incorrect."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold encontró texto de PDF existente, por lo que no ejecutó el OCR automáticamente. Si la búsqueda no encuentra palabras visibles, la capa de texto podría estar incompleta o ser incorrecta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold a trouvé du texte PDF existant et n’a donc pas lancé l’OCR automatiquement. Si la recherche ne trouve pas des mots visibles, la couche de texte est peut-être partielle ou incorrecte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold को मौजूदा PDF टेक्स्ट मिला, इसलिए इसने OCR अपने आप नहीं चलाया। अगर खोज में दिखने वाले शब्द नहीं मिलते, तो टेक्स्ट लेयर अधूरी या गलत हो सकती है।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldは既存のPDFテキストを検出したため、OCRを自動実行しませんでした。検索で表示中の単語が見つからない場合、テキストレイヤーが不完全または不正確な可能性があります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 发现了现有的 PDF 文本，因此未自动运行 OCR。如果搜索找不到可见的文字，说明文本层可能不完整或有误。"
          }
        }
      }
    },
