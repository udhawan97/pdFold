          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifoldが確認しました：署名は文書全体をカバーしています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Orifold 已验证：签名覆盖了整个文档。"
          }
        }
      }
    },
