      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the toolbar to highlight,\\nadd notes, or draw."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la barra de herramientas para resaltar,\\nañadir notas o dibujar."
          }
